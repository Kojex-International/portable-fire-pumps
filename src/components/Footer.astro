---
import { getLocaleFromPathname, getNavigation, localizePath, SOCIAL_LINKS, SITE } from '@config/site';
import { Linkedin, Twitter, Facebook } from 'lucide-react';

const locale = getLocaleFromPathname(Astro.url.pathname);
const navigation = getNavigation(locale);
const footerLinks = navigation.filter(
  (item) => !['Applications', 'Distributors', 'Resources'].includes(item.name)
);
const productsHref = localizePath('/products', locale);
const requestQuoteHref = localizePath('/request-a-quote', locale);
const distributorsHref = localizePath('/distributors', locale);
const resourcesHref = localizePath('/resources', locale);
---

<footer class="bg-slate-900 text-slate-300">
  <div class="container mx-auto px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-4">
      <!-- Company Info -->
      <div class="lg:col-span-1 space-y-6">
        <a href={localizePath('/', locale)} class="flex items-center space-x-3 group">
          <div class="flex items-center justify-center w-12 h-12 rounded-lg bg-linear-to-br from-blue-600 to-teal-600">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-7 h-7 text-white"
              aria-hidden="true"
            >
              <path d="M12 3q1 4 4 6.5t3 5.5a1 1 0 0 1-14 0 5 5 0 0 1 1-3 1 1 0 0 0 5 0c0-2-1.5-3-1.5-5q0-2 2.5-4" />
            </svg>
          </div>
          <span class="text-2xl font-bold text-white">
            Kojex International
          </span>
        </a>
        <p class="text-sm text-slate-400 leading-relaxed max-w-xs">
          {SITE.description}
        </p>
        <div class="flex space-x-4">
          <a
            href={SOCIAL_LINKS.linkedin}
            class="w-10 h-10 flex items-center justify-center rounded-lg bg-slate-800 text-slate-400 hover:bg-blue-600 hover:text-white transition-all"
            aria-label="LinkedIn"
          >
            <Linkedin className="w-5 h-5" />
          </a>
          <a
            href={SOCIAL_LINKS.twitter}
            class="w-10 h-10 flex items-center justify-center rounded-lg bg-slate-800 text-slate-400 hover:bg-blue-400 hover:text-white transition-all"
            aria-label="Twitter"
          >
            <Twitter className="w-5 h-5" />
          </a>
          <a
            href={SOCIAL_LINKS.facebook}
            class="w-10 h-10 flex items-center justify-center rounded-lg bg-slate-800 text-slate-400 hover:bg-blue-500 hover:text-white transition-all"
            aria-label="Facebook"
          >
            <Facebook className="w-5 h-5" />
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white mb-6">
          Quick Links
        </h3>
        <ul class="space-y-3">
          {footerLinks.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-sm text-slate-400 hover:text-blue-400 transition-colors inline-flex items-center group"
              >
                <span class="w-0 group-hover:w-2 h-0.5 bg-blue-400 transition-all mr-0 group-hover:mr-2"></span>
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white mb-6">
          Services
        </h3>
        <ul class="space-y-3">
          <li>
            <a href={distributorsHref} class="text-sm text-slate-400 hover:text-blue-400 transition-colors inline-flex items-center group">
              <span class="w-0 group-hover:w-2 h-0.5 bg-blue-400 transition-all mr-0 group-hover:mr-2"></span>
              Distributors
            </a>
          </li>
          <li>
            <a href="#" class="text-sm text-slate-400 hover:text-blue-400 transition-colors inline-flex items-center group">
              <span class="w-0 group-hover:w-2 h-0.5 bg-blue-400 transition-all mr-0 group-hover:mr-2"></span>
              Repairs
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white mb-6">
          Get Started
        </h3>
        <ul class="space-y-3 text-sm">
          <li>
            <a href={requestQuoteHref} class="text-slate-400 hover:text-blue-400 transition-colors inline-flex items-center group">
              <span class="w-0 group-hover:w-2 h-0.5 bg-blue-400 transition-all mr-0 group-hover:mr-2"></span>
              Request a Quote
            </a>
          </li>
          <li>
            <a href={resourcesHref} class="text-slate-400 hover:text-blue-400 transition-colors inline-flex items-center group">
              <span class="w-0 group-hover:w-2 h-0.5 bg-blue-400 transition-all mr-0 group-hover:mr-2"></span>
              Resources
            </a>
          </li>
        </ul>
        
        <div class="mt-8">
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-16 pt-8 border-t border-slate-800">
      <div class="flex flex-col md:flex-row items-center justify-between space-y-4 md:space-y-0">
        <p class="text-sm text-slate-400">
          &copy; {new Date().getFullYear()} {SITE.author}. All rights reserved.
        </p>
        <div class="flex items-center space-x-6 text-sm">
          <a href={localizePath('/', locale)} class="text-slate-400 hover:text-blue-400 transition-colors">
            Privacy Policy
          </a>
          <span class="text-slate-700">•</span>
          <a href={localizePath('/', locale)} class="text-slate-400 hover:text-blue-400 transition-colors">
            Terms of Service
          </a>
          <span class="text-slate-700">•</span>
          <a href={localizePath('/', locale)} class="text-slate-400 hover:text-blue-400 transition-colors">
            Cookie Policy
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
