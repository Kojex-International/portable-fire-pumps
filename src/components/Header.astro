---
import { getLocaleFromPathname, getNavigation, localizePath } from '@config/site';
import { Image } from 'astro:assets';
import logoMark from '@assets/shibaura-logo-mark.svg';
import MobileMenu from '@components/react/MobileMenu';
import { Globe } from 'lucide-react';

const { currentPathname } = Astro.props;
const locale = getLocaleFromPathname(currentPathname);
const navigation = getNavigation(locale);
const rfqHref = localizePath('/contact-us', locale);
const enHref = localizePath(currentPathname, 'en');
const frHref = localizePath(currentPathname, 'fr');
const isEnglish = locale === 'en';
const isFrench = locale === 'fr';
const contactLabel = isFrench ? 'Contact' : 'Contact';
const normalizePath = (path: string): string => {
  const base = path.split(/[?#]/)[0] || '/';
  if (base !== '/' && base.endsWith('/')) return base.slice(0, -1);
  return base;
};

const normalizedCurrentPath = normalizePath(currentPathname);
const localeRootPath = `/${locale}`;

const isActiveLink = (href: string): boolean => {
  const normalizedHref = normalizePath(href);
  if (normalizedHref === localeRootPath) {
    return normalizedCurrentPath === localeRootPath;
  }
  if (normalizedCurrentPath === normalizedHref) {
    return true;
  }
  return normalizedCurrentPath.startsWith(`${normalizedHref}/`);
};

---

<header class="sticky top-0 z-50 w-full border-b border-slate-200 bg-white shadow-sm pt-[env(safe-area-inset-top)]">
  <nav class="mx-auto flex h-20 items-center justify-between max-w-[1440px] px-4 sm:px-5 lg:px-6">
    <!-- Logo -->
    <div class="flex items-center">
      <a href={localizePath('/', locale)} class="flex items-center space-x-2.5 group">
        <div class="flex items-center justify-center w-[52px] h-[52px] rounded-lg group-hover:scale-110 transition-transform">
          <span
            aria-hidden="true"
            class="w-[52px] h-[52px] brand-gradient-bg"
            style={`-webkit-mask-image: url(${logoMark.src}); mask-image: url(${logoMark.src}); -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat; -webkit-mask-position: center; mask-position: center; -webkit-mask-size: contain; mask-size: contain;`}
          ></span>
        </div>
        <span class="text-2xl font-extrabold tracking-tight brand-gradient-text brand-title-font text-center leading-tight">
          Portable Fire Pumps
        </span>
      </a>
    </div>

    <!-- Desktop Navigation -->
    <div class="hidden lg:flex lg:items-center lg:space-x-1">
      {navigation.map((item) => {
        const isActive = isActiveLink(item.href);
        const hasChildren = item.children && item.children.length > 0;
        if (!hasChildren) {
          return (
            <a
              href={item.href}
              class={`px-4 py-2 text-sm font-medium text-center leading-tight text-slate-700 hover:text-[var(--brand-1)] hover:bg-[var(--brand-1-10)] rounded-lg transition-all relative group ${isActive ? 'nav-active' : ''}`}
            >
              {item.name}
              {isActive && <span aria-hidden="true" class="pointer-events-none absolute left-1/2 -bottom-1.5 -translate-x-1/2 w-1.5 h-1.5 rounded-full bg-[var(--brand-1-20)]"></span>}
            </a>
          );
        }

        return (
          <div class="relative group">
            <a
              href={item.href}
              class={`px-4 py-2 text-sm font-medium text-center leading-tight text-slate-700 hover:text-[var(--brand-1)] hover:bg-[var(--brand-1-10)] rounded-lg transition-all relative group ${isActive ? 'nav-active' : ''}`}
            >
              {item.name}
              {isActive && <span aria-hidden="true" class="pointer-events-none absolute left-1/2 -bottom-1.5 -translate-x-1/2 w-1.5 h-1.5 rounded-full bg-[var(--brand-1-20)]"></span>}
            </a>
            <div class="absolute left-0 top-full pt-2 opacity-0 translate-y-2 pointer-events-none group-hover:opacity-100 group-hover:translate-y-0 group-hover:pointer-events-auto group-focus-within:opacity-100 group-focus-within:translate-y-0 group-focus-within:pointer-events-auto transition-all duration-200">
              <div class="w-56 rounded-xl border border-slate-200 bg-white shadow-xl p-2">
                {item.children?.map((child) => (
                  <a
                    href={child.href}
                    class="block px-3 py-2 text-sm font-medium text-slate-700 hover:text-[var(--brand-1)] hover:bg-[var(--brand-1-10)] rounded-lg transition-colors"
                  >
                    {child.name}
                  </a>
                ))}
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Right Actions -->
    <div class="hidden lg:flex lg:items-center lg:gap-4">
      <div class="min-w-[78px] flex items-center justify-end space-x-1.5 text-xs font-semibold uppercase tracking-wide leading-none">
        <Globe className="w-3.5 h-3.5 text-slate-500 mr-1.5 shrink-0" />
        <div class="inline-flex items-center space-x-1.5 px-1.5 py-0.5 rounded-md bg-slate-100/80">
        <a
          href={enHref}
          aria-current={isEnglish ? 'page' : undefined}
          class={`inline-flex items-center leading-none py-0.5 border-b-2 transition-colors ${isEnglish ? 'text-slate-900 border-[var(--brand-1)]' : 'text-slate-500 border-transparent hover:text-[var(--brand-1)]'}`}
        >
          EN
        </a>
        <span class="inline-flex items-start self-start translate-y-[1px] text-slate-300 leading-none">|</span>
        <a
          href={frHref}
          aria-current={isFrench ? 'page' : undefined}
          class={`inline-flex items-center leading-none py-0.5 border-b-2 transition-colors ${isFrench ? 'text-slate-900 border-[var(--brand-1)]' : 'text-slate-500 border-transparent hover:text-[var(--brand-1)]'}`}
        >
          FR
        </a>
        </div>
      </div>
      <a
        href={rfqHref}
        class="brand-cta px-6 py-2.5 text-sm"
      >
        {contactLabel}
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <MobileMenu client:idle items={navigation} rfqHref={rfqHref} enHref={enHref} frHref={frHref} locale={locale} />
  </nav>
</header>
