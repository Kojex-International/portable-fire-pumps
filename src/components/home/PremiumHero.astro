---
import { Image } from 'astro:assets';
import Button from '../ui/Button.astro';
import { getLocaleFromPathname, localizePath } from '@config/site';

const locale = getLocaleFromPathname(Astro.url.pathname);
const requestQuoteHref = localizePath('/request-a-quote', locale);
const productsHref = localizePath('/products', locale);
---

<section class="relative h-screen min-h-[600px] flex items-center overflow-hidden safari-hero-offset">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0">
    <video
      class="w-full h-full object-cover object-[35%_20%] sm:object-center motion-reduce:hidden"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster="/hero-firepump-loop-poster.png"
      aria-hidden="true"
      tabindex="-1"
    >
      <source src="/hero-firepump-loop.mp4" type="video/mp4" />
    </video>
    <img
      src="/hero-firepump-loop-poster.png"
      alt=""
      class="hidden w-full h-full object-cover object-[35%_20%] sm:object-center motion-reduce:block"
      loading="eager"
      decoding="async"
    />
    <div class="absolute inset-0 bg-linear-to-r from-black/70 via-black/50 to-black/25"></div>
  </div>

  <!-- Content -->
  <div class="container mx-auto relative z-10 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl relative">
      <div class="relative z-10">
        <div class="inline-flex items-center px-4 py-2 mb-6 brand-gradient-bg text-white text-sm font-semibold rounded-full shadow-lg">
        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd" />
        </svg>
        Engineered for Firefighting, Rescue, and Disaster Response
      </div>
      
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight animate-fadeInUp">
        High-Performance
        <span class="block brand-gradient-text mt-2">
          Portable Fire Pumps
        </span>
      </h1>
      
      <p class="text-xl md:text-2xl text-slate-200 mb-8 max-w-2xl leading-relaxed animate-fadeInUp" style="animation-delay: 0.1s">
        Since 1952, Shibaura has set the standard for portable fire-fighting pumps. 
        Delivering proven reliability and performance through an established distributor network.
      </p>

      
      <div class="flex flex-col sm:flex-row gap-4 mb-12 animate-fadeInUp" style="animation-delay: 0.2s">
        <Button href={requestQuoteHref} size="lg" class="brand-cta">
          Request a Quote
        </Button>
        <Button href={productsHref} size="lg" variant="outline" class="border-2! border-white! text-white! hover:bg-white/10! shadow-2xl!">
          View Products
        </Button>
      </div>

      <!-- Quick Stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 pt-8 border-t border-white/20 animate-fadeInUp" style="animation-delay: 0.3s">
        <div class="group">
          <div class="text-xl md:text-2xl lg:text-3xl font-bold text-transparent bg-clip-text bg-linear-to-r from-white to-[var(--brand-2)] mb-1 leading-tight">FF500AR-A</div>
          <div class="flex items-center gap-2 text-sm text-slate-300 transition-colors brand-accent-hover">
            <svg class="w-5 h-5 text-[var(--brand-2)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M3 11l8.586 8.586a2 2 0 002.828 0l6.586-6.586a2 2 0 000-2.828L12.414 3H5a2 2 0 00-2 2v6z" />
            </svg>
            <span>Pump model</span>
          </div>
        </div>
        <div class="group">
          <div class="text-xl md:text-2xl lg:text-3xl font-bold text-transparent bg-clip-text bg-linear-to-r from-white to-[var(--brand-2)] mb-1 leading-tight">1,550 L/min</div>
          <div class="flex items-center gap-2 text-sm text-slate-300 transition-colors brand-accent-hover">
            <svg
              class="w-5 h-5 text-[var(--brand-2)]"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M12 2v8" />
              <path d="M2 15c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1" />
              <path d="M2 21c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1" />
              <path d="m8 6 4-4 4 4" />
            </svg>
            <span>Max discharge @ 0.5 MPa</span>
          </div>
        </div>
        <div class="group">
          <div class="text-xl md:text-2xl lg:text-3xl font-bold text-transparent bg-clip-text bg-linear-to-r from-white to-[var(--brand-2)] mb-1 leading-tight">1.0 MPa</div>
          <div class="flex items-center gap-2 text-sm text-slate-300 transition-colors brand-accent-hover">
            <svg
              class="w-5 h-5 text-[var(--brand-2)]"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="m12 14 4-4" />
              <path d="M3.34 19a10 10 0 1 1 17.32 0" />
            </svg>
            <span>Max Pressure</span>
          </div>
        </div>
        <div class="group">
          <div class="text-xl md:text-2xl lg:text-3xl font-bold text-transparent bg-clip-text bg-linear-to-r from-white to-[var(--brand-2)] mb-1 leading-tight">2.2 sec</div>
          <div class="flex items-center gap-2 text-sm text-slate-300 transition-colors brand-accent-hover">
            <svg class="w-5 h-5 text-[var(--brand-2)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6l3 3M12 21a9 9 0 100-18 9 9 0 000 18z" />
            </svg>
            <span>Priming performance</span>
          </div>
        </div>
      </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
