---
import { Image } from 'astro:assets';
import Button from '../ui/Button.astro';
import { getLocaleFromPathname, localizePath } from '@config/site';
import logoMark from '@assets/shibaura-logo-mark.svg';

const locale = getLocaleFromPathname(Astro.url.pathname);
const productsHref = localizePath('/products', locale);
---

<section class="relative h-screen min-h-[600px] flex items-center overflow-hidden safari-hero-offset">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0">
    <video
      class="w-full h-full object-cover object-[35%_20%] sm:object-center motion-reduce:hidden"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster="/hero-firepump-loop-poster.png"
      aria-hidden="true"
      tabindex="-1"
    >
      <source src="/hero-firepump-loop.mp4" type="video/mp4" />
    </video>
    <img
      src="/hero-firepump-loop-poster.png"
      alt=""
      class="hidden w-full h-full object-cover object-[35%_20%] sm:object-center motion-reduce:block"
      loading="eager"
      decoding="async"
    />
    <div class="absolute inset-0 bg-linear-to-r from-black/58 via-black/38 to-black/18"></div>
  </div>

  <!-- Content -->
  <div class="container mx-auto relative z-10 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl relative">
      <div class="relative z-10">
        <div class="relative inline-flex items-center px-4 py-2 mb-6 bg-white/10 backdrop-blur-[6px] text-white text-sm leading-none font-semibold rounded-full shadow-lg border border-white/15">
          <span class="absolute left-3 inset-y-0.5 flex items-center pointer-events-none" aria-hidden="true">
            <span
              class="h-full aspect-square inline-block"
              style={`background-color: currentColor; -webkit-mask-image: url(${logoMark.src}); mask-image: url(${logoMark.src}); -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat; -webkit-mask-position: center; mask-position: center; -webkit-mask-size: contain; mask-size: contain;`}
            />
          </span>
          <span class="pl-7">Engineered for Firefighting & Rescue</span>
        </div>
      
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight animate-fadeInUp">
        High-Performance
        <span class="block text-[var(--brand-400)] mt-2">
          Portable Fire Pumps
        </span>
      </h1>
      
      <p class="text-lg md:text-xl text-slate-200 mb-8 max-w-2xl leading-relaxed animate-fadeInUp" style="animation-delay: 0.1s">
        Since 1952, Shibaura has delivered proven portable fire pump performance.
      </p>

      
      <div class="flex flex-col sm:flex-row items-start gap-4 mb-12 animate-fadeInUp" style="animation-delay: 0.2s">
        <Button href={productsHref} size="lg" class="group !bg-transparent !border-0 !shadow-none hover:!bg-transparent !px-0">
          View Products
          <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </Button>
      </div>

      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
