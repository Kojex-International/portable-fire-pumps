---
import { Image } from 'astro:assets';
import Button from '../ui/Button.astro';
import heroBgImg from '@assets/portable-fire-pumps-hero.jpg';
import heroBgImgAi from '@assets/forestfire.png';
import ft510Img from '@assets/ft510-removebg-preview.png';
import { getLocaleFromPathname, localizePath } from '@config/site';

const locale = getLocaleFromPathname(Astro.url.pathname);
const requestQuoteHref = localizePath('/request-a-quote', locale);
const productsHref = localizePath('/products', locale);
---

<section class="relative h-screen min-h-[600px] flex items-center overflow-hidden safari-hero-offset">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0">
    <video
      class="w-full h-full object-cover object-[35%_20%] sm:object-center motion-reduce:hidden"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster={heroBgImgAi.src}
      aria-hidden="true"
      tabindex="-1"
    >
      <source src="/hero-firepump-loop.mp4" type="video/mp4" />
    </video>
    <Image 
      src={heroBgImgAi}
      alt=""
      class="hidden w-full h-full object-cover object-[35%_20%] sm:object-center motion-reduce:block"
      width={2070}
      height={1380}
      decoding="async"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-linear-to-r from-black/70 via-black/50 to-black/25"></div>
  </div>

  <!-- Content -->
  <div class="container mx-auto relative z-10 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl relative">
      <div class="relative z-10">
        <div class="inline-flex items-center px-4 py-2 mb-6 brand-gradient-bg text-white text-sm font-semibold rounded-full shadow-lg">
        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd" />
        </svg>
        Engineered for Firefighting, Rescue, and Disaster Response
      </div>
      
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight animate-fadeInUp">
        High-Performance
        <span class="block brand-gradient-text mt-2">
          Portable Fire Pumps
        </span>
      </h1>
      
      <p class="text-xl md:text-2xl text-slate-200 mb-8 max-w-2xl leading-relaxed animate-fadeInUp" style="animation-delay: 0.1s">
        Since 1952, Shibaura has set the standard for portable fire-fighting pumps. 
        Delivering proven reliability and performance through an established distributor network.
      </p>

      
      <div class="flex flex-col sm:flex-row gap-4 mb-12 animate-fadeInUp" style="animation-delay: 0.2s">
        <Button href={requestQuoteHref} size="lg" class="brand-cta">
          Request a Quote
        </Button>
        <Button href={productsHref} size="lg" variant="outline" class="border-2! border-white! text-white! hover:bg-white/10! shadow-2xl!">
          View Products
        </Button>
      </div>

      <!-- Quick Stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 pt-8 border-t border-white/20 animate-fadeInUp" style="animation-delay: 0.3s">
        <div class="group">
          <div class="text-xl md:text-2xl lg:text-3xl font-bold text-transparent bg-clip-text bg-linear-to-r from-white to-[var(--brand-2)] mb-1 leading-tight">500+</div>
          <div class="text-sm text-slate-300 transition-colors brand-accent-hover">Pumps Deployed</div>
        </div>
        <div class="group">
          <div class="text-xl md:text-2xl lg:text-3xl font-bold text-transparent bg-clip-text bg-linear-to-r from-white to-[var(--brand-2)] mb-1 leading-tight">1,650 L/min</div>
          <div class="text-sm text-slate-300 transition-colors brand-accent-hover">Max Flow Rate</div>
        </div>
        <div class="group">
          <div class="text-xl md:text-2xl lg:text-3xl font-bold text-transparent bg-clip-text bg-linear-to-r from-white to-[var(--brand-2)] mb-1 leading-tight">1.0 MPa</div>
          <div class="text-sm text-slate-300 transition-colors brand-accent-hover">Max Pressure</div>
        </div>
        <div class="group">
          <div class="text-xl md:text-2xl lg:text-3xl font-bold text-transparent bg-clip-text bg-linear-to-r from-white to-[var(--brand-2)] mb-1 leading-tight">2.1 sec</div>
          <div class="text-sm text-slate-300 transition-colors brand-accent-hover">Fastest Priming</div>
        </div>
      </div>
      </div>
    </div>
  </div>

  <!-- Foreground Pump Image -->
  <div class="pointer-events-none absolute inset-0 z-0 hidden lg:block">
    <div class="absolute bottom-32 right-10 w-[30rem] max-w-[36vw] opacity-100">
      <div
        class="absolute inset-0 -z-10"
        style="background: radial-gradient(circle at 55% 75%, rgba(15, 23, 42, 0.7), rgba(15, 23, 42, 0.35) 50%, transparent 85%);"
      ></div>
      <div class="absolute -bottom-6 left-1/2 h-8 w-3/4 -translate-x-1/2 rounded-full bg-black/40 blur-2xl"></div>
      <Image
        src={ft510Img}
        alt="FT510 fire pump"
        class="w-full h-auto brightness-85 drop-shadow-[0_40px_110px_rgba(0,0,0,0.6)]"
        width={1200}
        height={800}
      />
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
