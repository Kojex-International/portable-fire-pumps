---
import FeatureShowcase from '../react/FeatureShowcase';
import SectionHeader from '../ui/SectionHeader.astro';
import { getLocaleFromPathname, localizePath } from '@config/site';
import logoMark from '@assets/shibaura-logo-mark.svg';

const locale = getLocaleFromPathname(Astro.url.pathname);
const productsHref = localizePath('/products', locale);
const isFrench = locale === 'fr';
---

<section class="py-16 md:py-24 bg-slate-50">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeader
      badge={isFrench ? 'Gamme de produits' : 'Product Lineup'}
      badgeIcon={logoMark.src}
      title={isFrench ? 'Pompes à incendie' : 'Portable'}
      highlight={isFrench ? 'portatives' : 'Fire Pumps'}
      description={isFrench ? "Comparez les performances, l'amorçage et l'usage terrain de nos principaux modèles." : 'Compare performance, priming speed, and deployment fit across our core pump models.'}
      class="mb-16"
    />

    <FeatureShowcase detailsBaseHref={productsHref} locale={isFrench ? 'fr' : 'en'} client:load />
    
    <!-- Bottom CTA -->
    <div class="text-center mt-16">
      <a 
        href={productsHref} 
        class="brand-cta !px-8 !py-4 text-base hover:shadow-xl transition-all group"
      >
        {isFrench ? 'Voir toutes les pompes' : 'View All Pumps'}
        <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
