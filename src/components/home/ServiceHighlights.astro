---
import FeatureShowcase from '../react/FeatureShowcase';
import { getLocaleFromPathname, localizePath } from '@config/site';

const locale = getLocaleFromPathname(Astro.url.pathname);
const productsHref = localizePath('/products', locale);
---

<section class="py-16 md:py-24 bg-slate-50">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <div class="inline-block px-4 py-2 mb-4 bg-blue-100 text-blue-800 text-sm font-semibold rounded-full">
        Product Lineup
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6">
        Portable <span class="brand-gradient-text">Fire Pumps</span>
      </h2>
      <p class="text-xl text-slate-600 max-w-3xl mx-auto leading-relaxed">
        Compare performance, priming speed, and deployment fit across our core pump models.
      </p>
    </div>

    <FeatureShowcase detailsBaseHref={productsHref} client:load />
    
    <!-- Bottom CTA -->
    <div class="text-center mt-16">
      <a 
        href={productsHref} 
        class="brand-cta !px-8 !py-4 text-base hover:shadow-xl transition-all group"
      >
        View All Pumps
        <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
