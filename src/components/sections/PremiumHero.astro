---
import { Image } from 'astro:assets';
import { getLocaleFromPathname, localizePath } from '@config/site';
import HeroQuickLinks from '../react/HeroQuickLinks';
import logoMark from '@assets/shibaura-logo-mark.svg';
import heroPoster from '@assets/hero-firepump-loop-poster.webp';

const locale = getLocaleFromPathname(Astro.url.pathname);
const productsHref = localizePath('/products', locale);
const airCooledHref = localizePath('/products/air-cooled', locale);
const waterCooledHref = localizePath('/products/water-cooled', locale);
const useCasesHref = localizePath('/use-cases', locale);
const relayHref = localizePath('/long-distance-relay-pumping', locale);
const remoteFirefightingHref = `${useCasesHref}#remote-firefighting`;
const wildfireFirefightingHref = `${useCasesHref}#wildfire-firefighting`;
const isFrench = locale === 'fr';
const quickLinkItems = [
  {
    label: isFrench ? 'Catégories' : 'Categories',
    title: '',
    links: [
      {
        label: isFrench ? 'Pompes refroidies à l’air' : 'Air-Cooled Pumps',
        href: airCooledHref,
      },
      {
        label: isFrench ? 'Pompes refroidies à l’eau' : 'Water-Cooled Pumps',
        href: waterCooledHref,
      },
    ],
  },
  {
    label: isFrench ? 'Cas d’usage' : 'Use Cases',
    title: '',
    links: [
      {
        label: isFrench ? 'Interventions éloignées' : 'Remote Firefighting',
        href: remoteFirefightingHref,
      },
      {
        label: isFrench ? 'Feux de forêt' : 'Wildfire Firefighting',
        href: wildfireFirefightingHref,
      },
      {
        label: isFrench ? 'Relais d’eau longue distance' : 'Long-Distance Relay Pumping',
        href: relayHref,
      },
    ],
  },
  {
    label: isFrench ? 'Vue d’ensemble' : 'Overview',
    title: isFrench ? 'Voir toutes les pompes' : 'Browse All Pumps',
    href: productsHref,
    showArrow: true,
  },
];
---

<section class="relative min-h-[560px] sm:h-screen sm:min-h-[680px] flex items-start sm:items-center overflow-hidden safari-hero-offset">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0">
    <video
      class="block w-full h-full object-cover object-center sm:object-center motion-reduce:hidden"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster={heroPoster.src}
      aria-hidden="true"
      tabindex="-1"
    >
      <source media="(max-width: 767px)" src="/hero-firepump-loop-mobile.mp4" type="video/mp4" />
      <source src="/hero-firepump-loop.mp4" type="video/mp4" />
    </video>
    <Image
      src={heroPoster}
      alt=""
      class="hidden w-full h-full object-cover object-center sm:object-center motion-reduce:block"
      loading="eager"
      decoding="async"
      fetchpriority="high"
      width={1280}
      height={720}
    />
    <div class="absolute inset-0 bg-linear-to-r from-black/46 via-black/30 to-black/14 sm:from-black/58 sm:via-black/38 sm:to-black/18"></div>
  </div>

  <!-- Content -->
  <div class="container mx-auto relative z-10 mobile-container-gutter pt-14 pb-16 sm:py-28 lg:py-24">
    <div class="max-w-5xl relative text-center sm:text-left">
      <div class="relative z-10">
        <div class="relative mx-auto inline-flex items-center px-3.5 py-1.5 sm:mx-0 sm:px-4 sm:py-2 mb-4 sm:mb-6 bg-white/10 backdrop-blur-[6px] text-white text-xs sm:text-sm leading-none font-semibold rounded-full shadow-lg border border-white/15">
          <span class="absolute left-3 inset-y-0.5 flex items-center pointer-events-none" aria-hidden="true">
            <span
              class="h-full aspect-square inline-block"
              style={`background-color: currentColor; -webkit-mask-image: url(${logoMark.src}); mask-image: url(${logoMark.src}); -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat; -webkit-mask-position: center; mask-position: center; -webkit-mask-size: contain; mask-size: contain;`}
            />
          </span>
          <span class="pl-7">{isFrench ? 'Conçues pour les services d’incendie' : 'Engineered for Firefighting & Rescue'}</span>
        </div>
      
      <h1 class:list={[
        'font-bold text-white mb-4 sm:mb-6 animate-fadeInUp',
        isFrench
          ? 'text-[1.85rem] leading-[1.05] sm:text-4xl md:text-5xl lg:text-6xl'
          : 'text-3xl leading-tight sm:text-4xl md:text-6xl lg:text-7xl',
      ]}>
        {isFrench ? <span>Pompes incendie portatives</span> : 'High-Performance'}
        <span class="block brand-gradient-text-fill mt-2">
          {isFrench ? 'haute performance' : 'Portable Fire Pumps'}
        </span>
      </h1>
      
      <p class="text-base sm:text-lg md:text-xl text-slate-200 mb-10 sm:mb-10 max-w-2xl leading-relaxed animate-fadeInUp" style="animation-delay: 0.1s">
        {isFrench
          ? 'Depuis 1952, Shibaura conçoit et fabrique des pompes à incendie portatives reconnues pour leur fiabilité sur le terrain.'
          : 'Since 1952, Shibaura has delivered proven portable fire pump performance.'}
      </p>

      <div class="mt-1 inline-block max-w-full animate-fadeInUp text-left" style="animation-delay: 0.3s">
        <HeroQuickLinks client:load items={quickLinkItems} />
      </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-4 sm:bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
