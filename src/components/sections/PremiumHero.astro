---
import { Image } from 'astro:assets';
import Button from '../ui/Button.astro';
import { getLocaleFromPathname, localizePath } from '@config/site';
import logoMark from '@assets/shibaura-logo-mark.svg';
import heroPoster from '@assets/hero-firepump-loop-poster.webp';

const locale = getLocaleFromPathname(Astro.url.pathname);
const productsHref = localizePath('/products', locale);
const isFrench = locale === 'fr';
---

<section class="relative h-[72vh] min-h-[460px] sm:h-screen sm:min-h-[600px] flex items-center overflow-hidden safari-hero-offset">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0">
    <video
      class="hidden md:block w-full h-full object-cover object-center sm:object-center motion-reduce:hidden"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster={heroPoster.src}
      aria-hidden="true"
      tabindex="-1"
    >
      <source src="/hero-firepump-loop.mp4" type="video/mp4" />
    </video>
    <Image
      src={heroPoster}
      alt=""
      class="block w-full h-full object-cover object-center sm:object-center md:hidden motion-reduce:block md:motion-reduce:block"
      loading="eager"
      decoding="async"
      fetchpriority="high"
      width={1280}
      height={720}
    />
    <div class="absolute inset-0 bg-linear-to-r from-black/46 via-black/30 to-black/14 sm:from-black/58 sm:via-black/38 sm:to-black/18"></div>
  </div>

  <!-- Content -->
  <div class="container mx-auto relative z-10 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl relative">
      <div class="relative z-10">
        <div class="relative inline-flex items-center px-3.5 py-1.5 sm:px-4 sm:py-2 mb-4 sm:mb-6 bg-white/10 backdrop-blur-[6px] text-white text-xs sm:text-sm leading-none font-semibold rounded-full shadow-lg border border-white/15">
          <span class="absolute left-3 inset-y-0.5 flex items-center pointer-events-none" aria-hidden="true">
            <span
              class="h-full aspect-square inline-block"
              style={`background-color: currentColor; -webkit-mask-image: url(${logoMark.src}); mask-image: url(${logoMark.src}); -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat; -webkit-mask-position: center; mask-position: center; -webkit-mask-size: contain; mask-size: contain;`}
            />
          </span>
          <span class="pl-7">{isFrench ? 'Conçues pour les services d’incendie' : 'Engineered for Firefighting & Rescue'}</span>
        </div>
      
      <h1 class:list={[
        'font-bold text-white mb-4 sm:mb-6 animate-fadeInUp',
        isFrench
          ? 'text-[2.1rem] leading-[1.05] sm:text-4xl md:text-6xl lg:text-7xl'
          : 'text-3xl leading-tight sm:text-4xl md:text-6xl lg:text-7xl',
      ]}>
        {isFrench ? <span class="sm:whitespace-nowrap">Pompes incendie portatives</span> : 'High-Performance'}
        <span class="block brand-gradient-text-fill mt-2">
          {isFrench ? 'haute performance' : 'Portable Fire Pumps'}
        </span>
      </h1>
      
      <p class="text-base sm:text-lg md:text-xl text-slate-200 mb-6 sm:mb-8 max-w-2xl leading-relaxed animate-fadeInUp" style="animation-delay: 0.1s">
        {isFrench
          ? 'Depuis 1952, Shibaura conçoit et fabrique des pompes incendie portatives reconnues pour leur fiabilité sur le terrain.'
          : 'Since 1952, Shibaura has delivered proven portable fire pump performance.'}
      </p>

      
      <div class="flex flex-col sm:flex-row items-start gap-3 sm:gap-4 mb-8 sm:mb-12 animate-fadeInUp" style="animation-delay: 0.2s">
        <Button href={productsHref} size="lg" class="group !bg-transparent !border-0 !shadow-none hover:!bg-transparent !px-0">
          {isFrench ? 'Voir les produits' : 'View Products'}
          <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </Button>
      </div>

      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-4 sm:bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
