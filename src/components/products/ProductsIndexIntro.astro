---
interface LinkItem {
  label: string;
  href: string;
}

interface Props {
  badge: string;
  title: string;
  description: string;
  bullets: string[];
  categoryLabel: string;
  airLink: LinkItem;
  waterLink: LinkItem;
}

const { badge, title, description, bullets, categoryLabel, airLink, waterLink } = Astro.props;
---

<div class="mb-10 lg:mb-12">
  <div class="max-w-5xl mx-auto rounded-2xl border border-slate-200 bg-slate-50/80 p-6 lg:p-8">
    <div class="max-w-3xl">
      <div class="inline-flex items-center rounded-full bg-blue-100 px-4 py-2 text-sm font-semibold leading-none text-blue-800">
        {badge}
      </div>
      <h2 class="mt-4 text-3xl font-bold text-slate-900 md:text-4xl">
        {title}
      </h2>
      <p class="mt-4 text-base leading-relaxed text-slate-600">
        {description}
      </p>
    </div>

    <div class="mt-6 grid gap-4 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
      <ul class="space-y-3">
        {bullets.map((bullet) => (
          <li class="flex items-start gap-3 text-sm leading-relaxed text-slate-700">
            <span class="mt-1 inline-block h-2.5 w-2.5 shrink-0 rounded-full bg-[var(--brand-1)]"></span>
            <span>{bullet}</span>
          </li>
        ))}
      </ul>

      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1">
        <a href={airLink.href} class="rounded-xl border border-slate-200 bg-white p-4 transition-colors hover:border-[var(--brand-1)] hover:bg-[var(--brand-1-10)]">
          <div class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-500">{categoryLabel}</div>
          <div class="mt-1 text-lg font-bold text-slate-900">{airLink.label}</div>
        </a>
        <a href={waterLink.href} class="rounded-xl border border-slate-200 bg-white p-4 transition-colors hover:border-[var(--brand-1)] hover:bg-[var(--brand-1-10)]">
          <div class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-500">{categoryLabel}</div>
          <div class="mt-1 text-lg font-bold text-slate-900">{waterLink.label}</div>
        </a>
      </div>
    </div>
  </div>
</div>
