---
import type { ImageMetadata } from 'astro:assets';
import ProductDetailHero from './ProductDetailHero.astro';
import ProductPerformanceMedia from './ProductPerformanceMedia.astro';
import ProductSpecsTable from './ProductSpecsTable.astro';
import ProductRelatedPumps from './ProductRelatedPumps.astro';
import { localizePath } from '@config/site';
import { getFirepumps, type Firepump } from '../../data/firepumps';
import catalogPdf from '../../data/Shibaura_Catalog2024_9.pdf';
import ft500CurveImg from '@assets/graphs/ft500-performance-curve.jpg';
import ft500DimensionsImg from '@assets/graphs/ft500-dimensions-diagram.webp';
import ft300CurveImg from '@assets/graphs/ft300-performance-curve.jpg';
import ft300DimensionsImg from '@assets/graphs/ft300-dimensions-diagram.webp';
import fk500CurveImg from '@assets/graphs/fk500-performance-curve.jpg';
import fk500DimensionsImg from '@assets/graphs/fk500-dimensions-diagram.webp';
import ff500CurveImg from '@assets/graphs/ff500-performance-curve.jpg';
import ff500DimensionsImg from '@assets/graphs/ff500-dimensions-diagram.webp';
import p572sCurveImg from '@assets/graphs/p572s-performance-curve.jpg';
import p572sDimensionsImg from '@assets/graphs/p572s-dimensions-diagram.webp';
import tfCurveImg from '@assets/graphs/tf516mh-performance-curve.jpg';
import tfDimensionsImg from '@assets/graphs/tf516mh-dimensions-diagram.webp';
import shibauraLogoMark from '@assets/shibaura-logo-mark.svg?url';
import ff500PosterImg from '@assets/videos/1kmFF500relay-poster.webp';

interface Props {
  pump: Firepump;
  locale: 'en' | 'fr';
}

const { pump, locale } = Astro.props;
const isFrench = locale === 'fr';

const productsHref = localizePath('/products', locale);
const airCooledHref = localizePath('/products/air-cooled', locale);
const waterCooledHref = localizePath('/products/water-cooled', locale);
const manualPdf = pump.manualPdf ?? catalogPdf;
const manualLabel = pump.manualPdf
  ? isFrench
    ? 'Manuel d’utilisation'
    : 'Operations Manual'
  : isFrench
    ? 'Spécifications'
    : 'Specifications';

const localizedPumps = getFirepumps(locale);
const relatedPumps = localizedPumps.filter((item) => item.slug !== pump.slug).slice(0, 3);

const keySpecByKey = new Map(pump.keySpecs.map((spec) => [spec.key, spec]));
const leftSpecKeys = ['coolingSystem', 'pumpModel', 'engineType'] as const;
const rightSpecKeys = ['maxPressure', 'primingTime', 'flowRate'] as const;
const leftSpecs = leftSpecKeys.map((key) => keySpecByKey.get(key)).filter(Boolean);
const rightSpecs = rightSpecKeys.map((key) => keySpecByKey.get(key)).filter(Boolean);
const heroSpecs = [...leftSpecs, ...rightSpecs];

const operationVideo =
  pump.slug === 'ft300-400-a'
    ? {
        kind: 'youtube' as const,
        model: 'FT300-A',
        title: isFrench ? 'Fonctionnement de la pompe FT300-A' : 'FT300-A Pump Operation',
        description: isFrench
          ? 'Vidéo de démonstration du fonctionnement complet de la FT300-A.'
          : 'See the FT300-A in action with a full operation walkthrough.',
        url: 'https://www.youtube.com/embed/zQEbmyU3i28'
      }
    : pump.slug === 'fk500-a'
      ? {
          kind: 'youtube' as const,
          model: 'FK500-A',
          title: isFrench ? 'Fonctionnement de la pompe FK500-A' : 'FK500-A Pump Operation',
          description: isFrench
            ? 'Vidéo de démonstration du fonctionnement complet de la FK500-A.'
            : 'Watch the FK500-A running through a full pump operation demo.',
          url: 'https://www.youtube.com/embed/_pmvc3Xizew'
        }
      : pump.slug === 'ft510-a'
        ? {
            kind: 'youtube' as const,
            model: 'FT510-A',
            title: isFrench ? 'Fonctionnement de la pompe FT510-A' : 'FT510-A Pump Operation',
            description: isFrench
              ? 'Vidéo de démonstration du fonctionnement complet de la FT510-A.'
              : 'See the FT510-A in action with a full pump operation walkthrough.',
            url: 'https://www.youtube.com/embed/wUKDQSCwxiA'
          }
        : pump.slug === 'ff500ar-a'
          ? {
              kind: 'local' as const,
              model: 'FF500-AR',
              title: isFrench ? 'Fonctionnement de la pompe FF500-AR' : 'FF500-AR Pump Operation',
              description: isFrench
                ? 'Vidéo de démonstration du fonctionnement complet de la FF500-AR.'
                : 'Watch the FF500-AR running through a complete pump operation demo.',
              desktopUrl: '/videos/products/1kmFF500relay-desktop.mp4',
              mobileUrl: '/videos/products/1kmFF500relay-mobile.mp4',
              posterUrl: ff500PosterImg.src
            }
          : pump.slug === 'p572s-a'
            ? {
                kind: 'youtube' as const,
                model: 'P572S-A',
                title: isFrench ? 'Fonctionnement de la pompe P572S-A' : 'P572S-A Pump Operation',
                description: isFrench
                  ? 'Vidéo de démonstration du fonctionnement complet de la P572S-A.'
                  : 'See the P572S-A in action with a full pump operation walkthrough.',
                url: 'https://www.youtube.com/embed/AOhStVKJxqE'
              }
            : pump.slug === 'tf516mh-ab'
              ? {
                  kind: 'youtube' as const,
                  model: 'TF516MH-AB',
                  title: isFrench ? 'Fonctionnement de la pompe TF516MH-AB' : 'TF516MH-AB Pump Operation',
                  description: isFrench
                    ? 'Vidéo de démonstration du fonctionnement de la TF516MH-AB sur le terrain.'
                    : 'See the TF516MH-AB pump operating in the field.',
                  url: 'https://www.youtube.com/embed/pn0K14dIxho'
                }
              : null;

const performanceImagesBySlug: Record<string, { curve: ImageMetadata; dimensions: ImageMetadata }> = {
  'ft510-a': { curve: ft500CurveImg, dimensions: ft500DimensionsImg },
  'ft300-400-a': { curve: ft300CurveImg, dimensions: ft300DimensionsImg },
  'fk500-a': { curve: fk500CurveImg, dimensions: fk500DimensionsImg },
  'ff500ar-a': { curve: ff500CurveImg, dimensions: ff500DimensionsImg },
  'p572s-a': { curve: p572sCurveImg, dimensions: p572sDimensionsImg },
  'tf516mh-ab': { curve: tfCurveImg, dimensions: tfDimensionsImg }
};

const performanceImages = performanceImagesBySlug[pump.slug];

const relayUseCaseSlugs = new Set(['ff500ar-a', 'p572s-a', 'fk500-a']);
const wildlandUseCaseSlugs = new Set(['ft510-a', 'ft300-400-a', 'tf516mh-ab']);
const categoryLink = relayUseCaseSlugs.has(pump.slug)
  ? {
      href: waterCooledHref,
      label: isFrench ? 'pompes refroidies à l’eau' : 'water-cooled pumps',
    }
  : {
      href: airCooledHref,
      label: isFrench ? 'pompes refroidies à l’air' : 'air-cooled pumps',
    };
const useCaseLink = relayUseCaseSlugs.has(pump.slug)
  ? {
      href: localizePath('/long-distance-relay-pumping', locale),
      label: isFrench ? 'Voir le cas d’usage relais d’eau longue distance' : 'View the long-distance relay pumping page',
      text: isFrench
        ? 'Ce modèle convient particulièrement aux configurations relais et aux transferts d’eau soutenus.'
        : 'This model is especially relevant for relay layouts and sustained water-transfer operations.',
    }
  : wildlandUseCaseSlugs.has(pump.slug)
    ? {
        href: localizePath('/use-cases#remote-firefighting', locale),
        label: isFrench ? 'Voir le cas d’usage interventions éloignées' : 'View the remote firefighting section',
        text: isFrench
          ? 'Ce modèle mérite aussi d’être comparé pour les interventions rurales, les sites isolés et les accès éloignés.'
          : 'This model is also worth comparing for rural response, remote sites, and limited-infrastructure deployment.',
      }
    : null;

const text = {
  specButton: isFrench ? 'Spécifications' : 'Specifications',
  performanceCurve: isFrench ? 'Courbe de performance' : 'Performance Curve',
  dimensions: isFrench ? 'Dimensions' : 'Dimensions',
  operationHeadingSuffix: isFrench ? 'Fonctionnement de la pompe' : 'Pump Operation',
  relatedTitleLeading: isFrench ? 'Pompes' : 'Related',
  relatedTitleHighlight: isFrench ? 'associées' : 'Pumps',
};
---

<ProductDetailHero
  pump={pump}
  locale={locale}
  heroSpecs={heroSpecs}
  manualPdf={manualPdf}
  manualLabel={manualLabel}
  specButtonLabel={text.specButton}
  shibauraLogoMark={shibauraLogoMark}
/>

<section class="bg-white">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 pb-6">
    <div class="mx-auto max-w-5xl rounded-2xl border border-slate-200 bg-slate-50 p-6">
      <p class="text-sm leading-relaxed text-slate-600">
        {isFrench ? 'Comparez ce modèle dans la catégorie des ' : 'Compare this model within the '}
        <a href={categoryLink.href} class="font-semibold text-[var(--brand-1)] hover:underline">{categoryLink.label}</a>
        {useCaseLink
          ? isFrench
            ? ' et consultez aussi le contenu lié aux scénarios d’intervention correspondants.'
            : ' and review the related operational scenario page as part of your selection process.'
          : isFrench
            ? ' lors de votre sélection.'
            : ' as part of your selection process.'}
      </p>
    </div>
  </div>
</section>

<ProductPerformanceMedia
  pumpTitle={pump.title}
  locale={locale}
  performanceImages={performanceImages}
  operationVideo={operationVideo}
  performanceCurveLabel={text.performanceCurve}
  dimensionsLabel={text.dimensions}
  operationHeadingSuffix={text.operationHeadingSuffix}
/>

<ProductSpecsTable pump={pump} locale={locale} />

{useCaseLink && (
  <section class="bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 pb-6">
      <div class="mx-auto max-w-5xl rounded-2xl border border-slate-200 bg-slate-50 p-6">
        <p class="text-sm leading-relaxed text-slate-600">{useCaseLink.text}</p>
        <a href={useCaseLink.href} class="mt-4 inline-flex text-sm font-semibold text-[var(--brand-1)] hover:underline">
          {useCaseLink.label}
        </a>
      </div>
    </div>
  </section>
)}

<ProductRelatedPumps
  relatedPumps={relatedPumps}
  productsHref={productsHref}
  titleLeading={text.relatedTitleLeading}
  titleHighlight={text.relatedTitleHighlight}
  shibauraLogoMark={shibauraLogoMark}
  locale={locale}
/>
