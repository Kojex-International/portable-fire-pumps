---
interface Props {
  badge?: string;
  badgeIcon?: string;
  badgeIconComponent?: any;
  title: string;
  highlight?: string;
  description?: string;
  align?: 'left' | 'center';
  class?: string;
}

const {
  badge,
  badgeIcon,
  badgeIconComponent,
  title,
  highlight,
  description,
  align = 'center',
  class: className = ''
} = Astro.props;

const BadgeIcon = badgeIconComponent;

const alignClasses = align === 'left' ? 'text-left' : 'text-center';
const maxWidthClasses = align === 'left' ? 'max-w-4xl' : 'max-w-5xl mx-auto';
---

<div class={`px-3 sm:px-0 ${alignClasses} ${maxWidthClasses} ${className}`}>
  {badge && (
    <div class="relative inline-flex items-center px-4 py-2 mb-4 bg-blue-100 text-blue-800 text-sm leading-none font-semibold rounded-full">
      {badgeIcon && (
        <span class="absolute left-3 inset-y-0.5 flex items-center pointer-events-none" aria-hidden="true">
          <span
            class="h-full aspect-square inline-block"
            style={`background-color: currentColor; -webkit-mask-image: url(${badgeIcon}); mask-image: url(${badgeIcon}); -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat; -webkit-mask-position: center; mask-position: center; -webkit-mask-size: contain; mask-size: contain;`}
          />
        </span>
      )}
      {!badgeIcon && BadgeIcon && <BadgeIcon className="w-4 h-4 mr-2" />}
      <span class={badgeIcon ? 'pl-7' : ''}>{badge}</span>
    </div>
  )}
  <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6">
    {title}
    {highlight && <span class="brand-gradient-text"> {highlight}</span>}
  </h2>
  {description && (
    <p class="text-xl text-slate-600 max-w-3xl mx-auto leading-relaxed">
      {description}
    </p>
  )}
  <slot />
</div>
