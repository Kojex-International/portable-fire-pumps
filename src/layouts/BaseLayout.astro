---
import '../styles/global.css';
import Header from '@components/navigation/Header.astro';
import Footer from '@components/navigation/Footer.astro';
import JsonLd from '@components/seo/JsonLd.astro';
import { SITE, getLocaleFromPathname, localizePath, type Locale } from '@config/site';
import { buildOrganizationSchema, buildWebSiteSchema } from '@utils/seo/schema';

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  locale?: Locale;
  robots?: string;
  alternates?: {
    en?: string;
    fr?: string;
    xDefault?: string;
  };
  structuredData?: unknown | unknown[];
}

const currentPathname = Astro.url.pathname;

const { 
  title = SITE.title, 
  description = SITE.description,
  canonicalUrl,
  ogImage,
  locale: explicitLocale,
  robots,
  alternates,
  structuredData,
} = Astro.props;

const locale = explicitLocale ?? getLocaleFromPathname(currentPathname);
const ogLocale = locale === 'fr' ? 'fr_CA' : 'en_US';
const ogLocaleAlternate = locale === 'fr' ? 'en_US' : 'fr_CA';

const toAbsolute = (path: string) => new URL(path, SITE.url).toString();
const derivedEnAlternate = toAbsolute(localizePath(currentPathname, 'en'));
const derivedFrAlternate = toAbsolute(localizePath(currentPathname, 'fr'));
const enAlternateUrl = alternates?.en ?? derivedEnAlternate;
const frAlternateUrl = alternates?.fr ?? derivedFrAlternate;
const xDefaultAlternateUrl = alternates?.xDefault ?? enAlternateUrl;
const isProductionEnvironment = import.meta.env.PUBLIC_SITE_ENV === 'production';
const robotsContent = isProductionEnvironment ? (robots ?? 'index, follow') : 'noindex, nofollow';

const globalSchemas = [buildOrganizationSchema(), buildWebSiteSchema(locale)];
const pageSchemas = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
const allSchemas = [...globalSchemas, ...pageSchemas];
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/favicon-192.png" sizes="192x192" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <link rel="alternate" hreflang="en" href={enAlternateUrl} />
    <link rel="alternate" hreflang="fr" href={frAlternateUrl} />
    <link rel="alternate" hreflang="x-default" href={xDefaultAlternateUrl} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlternate} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <JsonLd schemas={allSchemas} />
  </head>
  <body class="flex min-h-screen flex-col bg-white font-sans text-neutral-900 antialiased">
    <Header currentPathname={currentPathname} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
