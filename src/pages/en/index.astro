---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PremiumHero from '../../components/sections/PremiumHero.astro';
import ServiceHighlights from '../../components/sections/ServiceHighlights.astro';
import PremiumCTA from '../../components/sections/PremiumCTA.astro';
import SectionHeader from '../../components/layout/SectionHeading.astro';
import logoMark from '@assets/shibaura-logo-mark.svg';
import heroOgImage from '@assets/portable-fire-pumps-hero.jpg';
import { getNonProductMetadata } from '@utils/nonProductMetadata';
import { localizePath } from '@config/site';

const featuresHref = localizePath('/features', 'en');
const useCasesHref = localizePath('/use-cases', 'en');
const resourcesHref = localizePath('/resources', 'en');
const distributorsHref = localizePath('/distributors', 'en');
const aboutHref = localizePath('/about-us', 'en');
const metadata = getNonProductMetadata({
  pageKey: 'home',
  locale: 'en',
  pathname: Astro.url.pathname,
  ogImageSrc: heroOgImage.src,
});
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  canonicalUrl={metadata.canonicalUrl}
  ogImage={metadata.ogImageUrl}
>
  <PremiumHero />
  <section class="bg-white">
    <div class="container mx-auto mobile-container-gutter py-12">
      <SectionHeader
        badge="About Shibaura Rabbit"
        badgeIcon={logoMark.src}
        title="Trusted"
        highlight="Portable Fire Pumps"
        class="mb-4"
      >
        <p class="text-lg md:text-xl text-slate-700 mb-4">
          for North America
        </p>
        <p class="text-lg md:text-xl text-slate-700">
          Welcome to Shibaura Rabbit Portable Fire Pumps Portal, brought to you by Kojex International. We are the only exclusive distributor of Rabbit Portable Firefighting Pumps in Canada and the United States.
        </p>
        <p class="text-lg md:text-xl text-slate-700 mt-4">
          Shibaura Rabbit’s originality, and a completely new design enables quick and easy inspection and maintenance.
        </p>
        <p class="text-lg md:text-xl text-slate-700 mt-4">
          Shibaura Rabbit portable firefighting equipment is ideal for use in the rural areas or any other areas where the infrastructure is not suitable for proper temporary fire fighting equipment.
        </p>
      </SectionHeader>
    </div>
  </section>
  <ServiceHighlights />
  <PremiumCTA
    description="Need more context before selecting a pump? Compare engineering features, browse manuals and parts documents, review distributor coverage, or learn more about Kojex support."
    supportLinks={[
      { href: featuresHref, label: 'Fire Pump Features' },
      { href: useCasesHref, label: 'Use Cases' },
      { href: resourcesHref, label: 'Resources' },
      { href: distributorsHref, label: 'Distributors' },
      { href: aboutHref, label: 'About Kojex' },
    ]}
  />
</BaseLayout>
