---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PremiumHero from '../../components/home/PremiumHero.astro';
import ServiceHighlights from '../../components/home/ServiceHighlights.astro';
import ImageGrid from '../../components/home/ImageGrid.astro';
import StatsShowcase from '../../components/home/StatsShowcase.astro';
import IndustriesServed from '../../components/home/IndustriesServed.astro';
import TechnologyInnovation from '../../components/home/TechnologyInnovation.astro';
import ProcessWorkflow from '../../components/home/ProcessWorkflow.astro';
import Testimonials from '../../components/home/Testimonials.astro';
import PremiumCTA from '../../components/home/PremiumCTA.astro';
---

<BaseLayout>
  <PremiumHero />
  <section class="bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="max-w-5xl mx-auto text-center space-y-5">
        <div class="inline-block px-4 py-2 mb-4 bg-blue-100 text-blue-800 text-sm font-semibold rounded-full">
          About Shibaura Rabbit
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
          Trusted <span class="brand-gradient-text">Portable Fire Pumps</span> for North America
        </h2>
        <p class="text-lg md:text-xl text-gray-700">
          Welcome to Shibaura Rabbit Portable Fire Pumps Portal, brought to you by Kojex International. We are the only exclusive distributor of Rabbit Portable Firefighting Pumps in Canada and the United States.
        </p>
        <p class="text-lg md:text-xl text-gray-700">
          Shibaura Rabbit’s originality, and a completely new design enables quick and easy inspection and maintenance.
        </p>
        <p class="text-lg md:text-xl text-gray-700">
          Shibaura Rabbit portable firefighting equipment is ideal for use in the rural areas or any other areas where the infrastructure is not suitable for proper temporary fire fighting equipment.
        </p>
      </div>
    </div>
  </section>
  <ServiceHighlights />
  <!-- <ImageGrid />
  <IndustriesServed />
  <TechnologyInnovation />
  <ProcessWorkflow />
  <StatsShowcase />
  <Testimonials /> -->
  <PremiumCTA />
</BaseLayout>
