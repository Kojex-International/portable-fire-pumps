---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/layout/Section.astro';
import SectionHeader from '../../components/layout/SectionHeading.astro';
import PageHero from '../../components/layout/PageHero.astro';
import { Building2 } from 'lucide-react';

import heroBgImg from '@assets/about-us-hero.webp';
import { getNonProductMetadata } from '@utils/nonProductMetadata';
import { buildAboutPageSchema } from '@utils/seo/schema';
const metadata = getNonProductMetadata({
  pageKey: 'about',
  locale: 'en',
  pathname: Astro.url.pathname,
  ogImageSrc: heroBgImg.src,
});
const structuredData = buildAboutPageSchema(metadata.canonicalUrl, 'en');
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  canonicalUrl={metadata.canonicalUrl}
  ogImage={metadata.ogImageUrl}
  locale="en"
  structuredData={structuredData}
>
  <PageHero
    backgroundImage={heroBgImg}
    backgroundAlt="About Kojex International"
    badge="About Us"
    badgeIconComponent={Building2}
    titleClass="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight animate-fadeInUp"
    descriptionClass="text-xl md:text-2xl text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed animate-fadeInUp"
    descriptionStyle="animation-delay: 0.1s"
  >
    <Fragment slot="title">
      <span class="brand-gradient-text-fill">Kojex International</span>
    </Fragment>
    <Fragment slot="description">
      Dedicated to delivering reliable fire-fighting equipment and trusted service worldwide.
    </Fragment>
  </PageHero>

  <Section background="white" class="!py-12 lg:!py-16">
    <SectionHeader
      title="About"
      highlight="Kojex International"
      class="mb-8 px-2"
    />
    <div class="max-w-4xl mx-auto text-lg text-gray-700 leading-relaxed space-y-6 px-4">
      <p>
        Since 1990, Kojex International has provided and supported the products and services that our clients need to meet today’s modern market. Located in Montreal, Canada, we provide many technologies and products such as pre-fabricated housing, road maintenance materials and fire-fighting equipment, globally across Asia, Europe, North and South America.
      </p>
      <p>
        With the objective to provide high quality products and excellent service, Kojex International’s philosophy is without compromise and is reflected in the quality of our products and services.
      </p>
      <p>
        Actively listening to our clients and ensuring their satisfaction has been essential to our success with our clients. We hope to be able to better serve you in the near future and provide you with the products and service that will insure your satisfaction.
      </p>
    </div>
  </Section>

  <Section background="gray" class="!py-12 lg:!py-16">
    <SectionHeader
      title="About"
      highlight="Shibaura Rabbit Fire Pump"
      class="mb-8 px-2"
    >
      <p class="text-xl text-slate-600 max-w-3xl mx-auto leading-relaxed">
        and Kojex Industries
      </p>
    </SectionHeader>
    <div class="max-w-4xl mx-auto text-lg text-gray-700 leading-relaxed space-y-6 px-4">
      <p>
        For over 25 years, Kojex International Inc. has served North America as the exclusive distributor of Shibaura Rabbit Portable Fire Pumps. We pride ourselves in personalized customer service and offer unmatched value in portable fire pump market.
      </p>
      <p>
        We offer a complete line of reliable high performance portable fire pumps with over 8 models, including water-cooled and air-cooled fire pump systems.
      </p>
      <p>
        To insure quality, Shibaura Rabbit Portable Fire Pumps undergo extensive testing before leaving the production facilities. They offer a reliable method of fire fighting when the need arises, especially in remote areas where appropriate infrastructures are non existent.
      </p>
      <p>
        Our search for new potential dealers of our products is ongoing. If you are interested in providing Shibaura Rabbit High Performance Portable Fire Pumps to your area; please contact us for more information.
      </p>
    </div>
  </Section>
</BaseLayout>
