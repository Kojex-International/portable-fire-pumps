  parts:
    '<path d="M11 10.27 7 3.34"/><path d="m11 13.73-4 6.93"/><path d="M12 22v-2"/><path d="M12 2v2"/><path d="M14 12h8"/><path d="m17 20.66-1-1.73"/><path d="m17 3.34-1 1.73"/><path d="M2 12h2"/><path d="m20.66 17-1.73-1"/><path d="m20.66 7-1.73 1"/><path d="m3.34 17 1.73-1"/><path d="m3.34 7 1.73 1"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="12" r="8"/>',
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  lightbulb:
    '<path d="M9.663 17h4.673"/><path d="M12 3v1"/><path d="m18.364 4.636-.707.707"/><path d="M21 12h-1"/><path d="M4 12H3"/><path d="m6.343 6.343-.707-.707"/><path d="m8.172 16.243-.548.547A3.374 3.374 0 0 0 10 18.469V19a2 2 0 1 0 4 0v-.531c0-.895.356-1.754.988-2.386l-.548-.547a5 5 0 1 0-7.072 0z"/>',
  fileText:
    '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/>'
};

const docCategories = [
  {
    title: 'Product Catalogs',
    iconPath: iconPaths.catalog,
    image: pumpCatalogImg,
    color: 'from-[#E11D48] to-[#F59E7E]',
    gradient: 'linear-gradient(135deg, var(--brand-1), var(--brand-2))',
    bgColor: 'bg-rose-50',
    iconColor: 'text-rose-600',
    docs: [
      { title: '2024 Shibaura Product Catalog', description: 'Browse the full Shibaura portable fire pump lineup', type: 'PDF', size: '19 MB', href: catalogPdf }
    ]
  },
  {
    title: 'Pump Instruction Manuals',
    iconPath: iconPaths.manual,
    image: firepumpManualsImg,
    color: 'from-purple-500 to-pink-500',
    gradient: 'linear-gradient(135deg, #a855f7, #ec4899)',
    bgColor: 'bg-purple-50',
    iconColor: 'text-purple-600',
    docs: [
      { title: 'FT300-A / FT400-A1 Manual', description: 'Air-cooled pump manual', type: 'PDF', size: '1.8 MB', href: ft300400ManualPdf },
      { title: 'FT450/FT500 Manual', description: 'Air-cooled pump manual', type: 'PDF', size: '2.1 MB', href: ft450500ManualPdf },
      { title: 'TF516MH Manual', description: 'Air-cooled pump manual', type: 'PDF', size: '44.6 KB', href: tf516mhManualPdf },
      { title: 'TF745MH Manual', description: 'Air-cooled pump manual', type: 'PDF', size: '3.9 MB', href: tf745mhManualPdf },
      { title: 'P572S Manual', description: 'Water-cooled pump manual', type: 'PDF', size: '0.7 MB', href: p572sManualPdf },
      { title: 'FK500 Manual', description: 'Water-cooled pump manual', type: 'PDF', size: '2.5 MB', href: fk500ManualPdf },
      { title: 'FF500 Manual', description: 'Water-cooled pump manual', type: 'PDF', size: '2.8 MB', href: ff500ManualPdf }
    ]
  },
  {
    title: 'Parts Lists',
    iconPath: iconPaths.parts,
    image: partsListImg,
    color: 'from-green-500 to-emerald-500',
    gradient: 'linear-gradient(135deg, #22c55e, #10b981)',
    bgColor: 'bg-green-50',
    iconColor: 'text-green-600',
    docs: [
      { title: 'FI6000/FI7000/FI8000 Parts List', description: 'Parts list', type: 'PDF', size: '1.1 MB', href: fi6000fi7000fi8000PartsPdf },
      { title: 'FT300/FT400 Parts List', description: 'Parts list', type: 'PDF', size: '2.5 MB', href: ft300ft400PartsPdf },
      { title: 'FT450/FT500 Parts List', description: 'Parts list', type: 'PDF', size: '4.2 MB', href: ft450ft500PartsPdf },
      { title: 'P509R Parts List', description: 'Parts list', type: 'PDF', size: '0.7 MB', href: p509rPartsPdf },
      { title: 'P555 Parts List', description: 'Parts list', type: 'PDF', size: '0.5 MB', href: p555PartsPdf },
      { title: 'P572 Parts List', description: 'Parts list', type: 'PDF', size: '1.0 MB', href: p572PartsPdf }
    ]
  },
  // {
  //   title: 'Compliance & Certifications',
  //   iconPath: iconPaths.shield,
  //   image: technicalDocumentationImg,
  //   color: 'from-amber-500 to-orange-500',
  //   gradient: 'linear-gradient(135deg, #f59e0b, #f97316)',
  //   bgColor: 'bg-amber-50',
  //   iconColor: 'text-amber-600',
  //   docs: [
  //     { title: 'ISO 9001 Certificate', description: 'Quality management system certification documentation', type: 'PDF', size: '1.2 MB' },
  //     { title: 'FDA Registration', description: 'Food and drug administration compliance records', type: 'PDF', size: '2.3 MB' },
  //     { title: 'C-TPAT Certification', description: 'Customs trade partnership against terrorism', type: 'PDF', size: '1.8 MB' },
  //     { title: 'Safety Data Sheets', description: 'Comprehensive material safety information database', type: 'PDF', size: '5.4 MB' }
  //   ]
  // },
  // {
  //   title: 'Best Practices',
  //   iconPath: iconPaths.lightbulb,
  //   image: operationsManualImg,
  //   color: 'from-indigo-500 to-blue-500',
  //   gradient: 'linear-gradient(135deg, #6366f1, #3b82f6)',
  //   bgColor: 'bg-indigo-50',
  //   iconColor: 'text-indigo-600',
  //   docs: [
  //     { title: 'Inventory Optimization', description: 'Strategies to maximize efficiency and reduce costs', type: 'PDF', size: '3.6 MB' },
  //     { title: 'Packaging Guidelines', description: 'Best practices for product protection and presentation', type: 'PDF', size: '2.8 MB' },
  //     { title: 'Supply Chain Tips', description: 'Proven methods to streamline your operations', type: 'PDF', size: '4.2 MB' },
  //     { title: 'Sustainability Guide', description: 'Eco-friendly logistics solutions and practices', type: 'PDF', size: '3.9 MB' }
  //   ]
  // },
  // {
  //   title: 'Forms & Templates',
  //   iconPath: iconPaths.fileText,
  //   image: formsTemplatesImg,
  //   color: 'from-teal-500 to-cyan-500',
  //   gradient: 'linear-gradient(135deg, #14b8a6, #06b6d4)',
  //   bgColor: 'bg-teal-50',
  //   iconColor: 'text-teal-600',
  //   docs: [
  //     { title: 'Bill of Lading Template', description: 'Standard shipping documentation template', type: 'DOC', size: '0.5 MB' },
  //     { title: 'Packing List Form', description: 'Itemized shipment details and inventory form', type: 'XLS', size: '0.3 MB' },
  //     { title: 'Inspection Checklist', description: 'Quality control and verification template', type: 'DOC', size: '0.4 MB' },
  //     { title: 'Incident Report Form', description: 'Standardized issue reporting and tracking form', type: 'PDF', size: '0.6 MB' }
  //   ]
  // }
];

const faqs = [
  {
    question: 'How do I access the customer portal?',
    answer: 'Contact your account manager to receive login credentials for our secure customer portal. Once registered, you can track shipments, view inventory, generate reports, and manage your account 24/7 from anywhere in the world.'
  },
  {
    question: 'What file formats are supported for EDI?',
    answer: 'We support all standard EDI formats including X12 (850, 856, 810, 997, etc.), EDIFACT, and custom XML formats. Our integration team can work with your existing systems to ensure seamless data exchange and compatibility.'
  },
  {
    question: 'Where can I find safety data sheets (SDS)?',
    answer: 'All safety data sheets are available in the Compliance & Certifications section of this documentation center. You can also request specific SDS documents directly from your account manager or through our support portal.'
  },
  {
    question: 'How often is documentation updated?',
    answer: 'Documentation is reviewed and updated quarterly, or more frequently as needed for regulatory changes, system updates, or process improvements. You will be notified of any critical updates via email and through the customer portal.'
  },
  {
    question: 'Can I download multiple documents at once?',
    answer: 'Yes, you can select multiple documents and download them as a ZIP archive. Simply use the bulk selection feature available in each category section to download multiple files simultaneously.'
  },
  {
    question: 'Is there a mobile app for accessing documentation?',
    answer: 'Yes, our mobile application is available for both iOS and Android devices. You can download it from the App Store or Google Play Store. The app provides full access to all documentation and features offline reading capabilities.'
  }
];
---

<BaseLayout title="Resources - Portable Fire Pumps">
  <!-- Hero Section with Professional Background -->
  <section class="relative h-[70vh] min-h-[500px] flex items-center overflow-hidden">
    <div class="absolute inset-0">
      <Image 
        src={heroBgImg}
        alt="Professional documentation and resources"
        class="w-full h-full object-cover"
        width={2070}
        height={1380}
      />
      <div class="absolute inset-0 bg-linear-to-r from-slate-900/95 via-slate-900/80 to-slate-900/50"></div>
    </div>

    <div class="container mx-auto relative z-10 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center px-4 py-2 mb-6 brand-gradient-bg text-white text-sm font-semibold rounded-full shadow-lg backdrop-blur-sm">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Comprehensive Resource Center
        </div>
        
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight animate-fadeInUp">
          <span class="brand-gradient-text">
            Documents and Parts Lists
          </span>
        </h1>
        
        <p class="text-xl md:text-2xl text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed animate-fadeInUp" style="animation-delay: 0.1s">
          Download catalogs, pump technical documentation and parts lists. 
        </p>

        <div class="flex flex-wrap justify-center gap-4 text-sm text-slate-300 animate-fadeInUp" style="animation-delay: 0.2s">
          <div class="flex items-center">
            <svg class="w-4 h-4 mr-2 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>All pump documentation</span>
          </div>
          <div class="flex items-center">
            <svg class="w-4 h-4 mr-2 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>Regular Updates</span>
          </div>
          <div class="flex items-center">
            <svg class="w-4 h-4 mr-2 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>24/7 Access</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </section>

  <!-- Search Bar -->
  <Section background="gray">
    <div class="max-w-4xl mx-auto mb-16">
      <Card class="p-6 shadow-xl border-2 border-gray-100">
        <div class="flex flex-col md:flex-row gap-4">
          <div class="flex-1 relative">
            <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input
              type="text"
              placeholder="Search documentation, guides, and resources..."
              class="w-full pl-12 pr-4 py-4 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all text-lg"
              id="doc-search"
            />
          </div>
          <button class="brand-cta !px-8 !py-4 !rounded-xl text-base flex items-center justify-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            Search
          </button>
        </div>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="text-sm text-gray-500">Quick links:</span>
          <a href="#product-catalogs" class="text-sm text-blue-600 hover:text-blue-800 font-medium">Product Catalogs</a>
          <span class="text-gray-300">•</span>
          <a href="#pump-instruction-manuals" class="text-sm text-blue-600 hover:text-blue-800 font-medium">Pump Manuals</a>
          <span class="text-gray-300">•</span>
          <a href="#parts-lists" class="text-sm text-blue-600 hover:text-blue-800 font-medium">Parts Lists</a>
          <span class="text-gray-300">•</span>
          <a href="#compliance-&-certifications" class="text-sm text-blue-600 hover:text-blue-800 font-medium">Compliance</a>
          <span class="text-gray-300">•</span>
          <a href="#faq" class="text-sm text-blue-600 hover:text-blue-800 font-medium">FAQ</a>
        </div>
      </Card>
    </div>

    <!-- Documentation Categories -->
    <div class="space-y-20">
      {docCategories.map((category, index) => {
        const categoryId = category.title.toLowerCase().replace(/\s+/g, '-');
        return (
        <div class="animate-fadeInUp" style={`animation-delay: ${index * 0.1}s`} id={categoryId}>
          <!-- Category Header with Image -->
          <div class="mb-8">
            <ImageReveal client:load delay={index * 0.1}>
              <div class="relative h-64 rounded-2xl overflow-hidden shadow-2xl group">
                <Image 
                  src={category.image}
                  alt={category.title}
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                  width={2070}
                  height={1380}
                />
                <div class={`absolute inset-0 bg-linear-to-r ${category.color} opacity-80`}></div>
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="text-center text-white">
                    <div class={`w-20 h-20 ${category.bgColor} rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-xl backdrop-blur-sm bg-white/20 border-2 border-white/30`}>
                      <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <g stroke-linecap="round" stroke-linejoin="round" stroke-width="2" set:html={category.iconPath} />
                      </svg>
                    </div>
                    <h2 class="text-4xl md:text-5xl font-bold mb-2">{category.title}</h2>
                    <p class="text-lg text-white/90">{category.docs.length} Documents Available</p>
                  </div>
                </div>
              </div>
            </ImageReveal>
          </div>
            
            <!-- Documents Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {category.docs.map((doc, docIndex) => (
                <ImageReveal client:load delay={index * 0.1 + docIndex * 0.05}>
                  <div
                    class="doc-card"
                    data-doc-card
                    data-doc-text={`${doc.title} ${doc.description}`.toLowerCase()}
                  >
                    <Card
                      hover
                      class="cursor-pointer group h-full flex flex-col"
                      style={`--doc-hover-color: ${category.title === 'Getting Started' ? 'var(--brand-1)' : '#2563eb'};`}
                    >
                      <div class="flex-1">
                        <div class="flex items-start justify-between mb-4">
                          <div class={`w-12 h-12 ${category.bgColor} rounded-xl flex items-center justify-center ${category.iconColor} shadow-md group-hover:scale-110 transition-transform`}>
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                            </svg>
                          </div>
                          <span class={`inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold ${category.bgColor} ${category.iconColor} border border-current/20`}>
                            {doc.type}
                          </span>
                        </div>

                        <h3 class="text-xl font-bold text-gray-900 mb-3 doc-card-title">
                          {doc.title}
                        </h3>
                        <p class="text-sm text-gray-600 mb-4 leading-relaxed">{doc.description}</p>

                        <div class="flex items-center text-xs text-gray-500 mb-4">
                          <span>Size: {doc.size}</span>
                        </div>
                      </div>

                      {doc.href ? (
                        <a
                          href={doc.href}
                          class={`w-full mt-auto inline-flex items-center justify-center gap-2 rounded-lg px-4 py-3 font-semibold text-white shadow-2xl transition focus-visible:ring-2 focus-visible:ring-offset-2 hover:brightness-95`}
                          style={`background: ${category.gradient};`}
                          download
                        >
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                          </svg>
                          <span>Download</span>
                        </a>
                      ) : (
                        <button
                          class={`w-full mt-auto inline-flex items-center justify-center gap-2 rounded-lg px-4 py-3 font-semibold text-white shadow-2xl transition focus-visible:ring-2 focus-visible:ring-offset-2 hover:brightness-95`}
                          style={`background: ${category.gradient};`}
                        >
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                          </svg>
                          <span>Download</span>
                        </button>
                      )}
                    </Card>
                  </div>
                </ImageReveal>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </Section>

  <script>
    const searchInput = document.querySelector('#doc-search');
    const docCards = Array.from(document.querySelectorAll('[data-doc-card]'));

    if (searchInput) {
      searchInput.addEventListener('input', (event) => {
        const term = event.target.value.toLowerCase().trim();
        docCards.forEach((card) => {
          const text = card.dataset.docText || '';
          card.classList.toggle('hidden', term.length > 0 && !text.includes(term));
        });
      });
    }
  </script>

  <!-- FAQ Section -->
  <!-- <Section background="white" id="faq">
    <div class="text-center mb-16">
      <div class="inline-block px-4 py-2 mb-4 bg-blue-100 text-blue-800 text-sm font-semibold rounded-full">
        Support
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        Frequently Asked <span class="gradient-text">Questions</span>
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Quick answers to common questions about our documentation and resources.
      </p>
    </div>

    <div class="max-w-4xl mx-auto space-y-4">
      {faqs.map((faq, index) => (
        <ImageReveal client:load delay={index * 0.05}>
          <Card hover class="animate-fadeInUp border-2 border-gray-100 hover:border-blue-200 transition-colors" style={`animation-delay: ${index * 0.05}s`}>
            <details class="group">
              <summary class="flex items-center justify-between cursor-pointer list-none py-2">
                <h3 class="text-lg font-semibold text-gray-900 pr-4 group-hover:text-blue-600 transition-colors">
                  {faq.question}
                </h3>
                <div class="shrink-0">
                  <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
