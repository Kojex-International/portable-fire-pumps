---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/layout/Section.astro';
import MobilePumpCards from '../../components/products/MobilePumpCards.astro';
import DesktopPumpCards from '../../components/products/DesktopPumpCards.astro';
import ProductsCTA from '../../components/products/ProductsCTA.astro';
import PageHero from '../../components/layout/PageHero.astro';
import { Gauge } from 'lucide-react';

import { getFirepumps } from '../../data/firepumps';
import heroBgImg from '@assets/portable-fire-pumps-hero.jpg';
import { getLocaleFromPathname, localizePath } from '@config/site';
import { getNonProductMetadata } from '@utils/nonProductMetadata';
import { buildItemListSchema } from '@utils/seo/schema';
import { SITE } from '@config/site';

const locale = getLocaleFromPathname(Astro.url.pathname);
const productsBaseHref = localizePath('/products', locale);
const airCooledHref = localizePath('/products/air-cooled', locale);
const waterCooledHref = localizePath('/products/water-cooled', locale);
const requestQuoteHref = localizePath('/contact-us', locale);
const distributorsHref = localizePath('/distributors', locale);
const firepumps = getFirepumps('en');
const metadata = getNonProductMetadata({
  pageKey: 'products',
  locale: 'en',
  pathname: Astro.url.pathname,
  ogImageSrc: heroBgImg.src,
});
const structuredData = buildItemListSchema({
  listName: 'Portable Fire Pumps',
  canonicalUrl: metadata.canonicalUrl,
  items: firepumps.map((pump) => ({
    name: pump.title,
    url: new URL(localizePath(`/products/${pump.slug}`, 'en'), SITE.url).toString(),
    image: new URL(pump.image.src, SITE.url).toString(),
  })),
});
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  canonicalUrl={metadata.canonicalUrl}
  ogImage={metadata.ogImageUrl}
  locale="en"
  structuredData={structuredData}
>
  <PageHero
    backgroundImage={heroBgImg}
    backgroundAlt="Shibaura portable fire pumps staged for rapid deployment"
    badge="Products"
    badgeIconComponent={Gauge}
    contentClass="max-w-4xl mx-auto text-center min-h-[360px] flex flex-col items-center"
    titleClass="text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight animate-fadeInUp"
    descriptionClass="text-xl md:text-2xl text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed animate-fadeInUp"
    descriptionStyle="animation-delay: 0.1s"
  >
    <Fragment slot="title">
      <span class="brand-gradient-text-fill">Portable Fire Pumps</span>
    </Fragment>
    <Fragment slot="description">
      Choose the right pump based on water conditions and duty cycle.
    </Fragment>
    <div class="mt-auto mb-14 flex w-full max-w-full flex-col items-center gap-3 text-left sm:flex-row sm:justify-center sm:gap-6 md:translate-x-8 lg:translate-x-10">
      <a href={airCooledHref} class="group w-full max-w-[18rem] rounded-2xl bg-transparent px-0 py-3 text-white transition-all duration-300 hover:-translate-y-0.5 sm:w-[18rem]">
        <div class="text-[0.65rem] font-semibold uppercase tracking-[0.14em] text-white/70 sm:text-xs">Category</div>
        <div class="mt-2 text-base font-bold leading-tight text-white transition-colors duration-300 group-hover:text-red-300 sm:text-xl">Air-Cooled Pumps</div>
        <div class="mt-2 text-sm leading-relaxed text-slate-200">Best for variable water sources and simpler field deployment.</div>
      </a>
      <a href={waterCooledHref} class="group w-full max-w-[18rem] rounded-2xl bg-transparent px-0 py-3 text-white transition-all duration-300 hover:-translate-y-0.5 sm:w-[18rem]">
        <div class="text-[0.65rem] font-semibold uppercase tracking-[0.14em] text-white/70 sm:text-xs">Category</div>
        <div class="mt-2 text-base font-bold leading-tight text-white transition-colors duration-300 group-hover:text-red-300 sm:text-xl">Water-Cooled Pumps</div>
        <div class="mt-2 text-sm leading-relaxed text-slate-200">Best for sustained relay pumping and longer-duty water transfer.</div>
      </a>
    </div>
  </PageHero>

  <Section background="white">
    <div class="lg:hidden mb-12">
      <MobilePumpCards capabilities={firepumps} detailsBaseHref={productsBaseHref} locale="en" />
    </div>

    <DesktopPumpCards capabilities={firepumps} detailsBaseHref={productsBaseHref} locale="en" />
  </Section>

  <ProductsCTA
    locale="en"
    backgroundImage={heroBgImg}
    contactHref={requestQuoteHref}
    distributorsHref={distributorsHref}
  />
</BaseLayout>
