---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Section from '../../../components/ui/Section.astro';
import Card from '../../../components/ui/Card.astro';
import Button from '../../../components/ui/Button.astro';
import { Image } from 'astro:assets';
import ImageReveal from '../../../components/react/ImageReveal';
import { getLocaleFromPathname, localizePath } from '@config/site';
import { firepumps, type Firepump } from '../../../data/firepumps';
import checkIcon from '@assets/icons/check.svg?url';
import catalogPdf from '../../../data/Shibaura_Catalog2024_9 (1).pdf';
import p510GraphImg from '@assets/p510-aGraphImg.png';

export async function getStaticPaths() {
  return firepumps.map((pump) => ({
    params: { slug: pump.slug },
    props: { pump }
  }));
}

const { pump } = Astro.props as { pump: Firepump };
const locale = getLocaleFromPathname(Astro.url.pathname);
const requestQuoteHref = localizePath('/request-a-quote', locale);
const productsHref = localizePath('/products', locale);

const relatedPumps = firepumps.filter((item) => item.slug !== pump.slug).slice(0, 3);
const keySpecByLabel = new Map(pump.keySpecs.map((spec) => [spec.label, spec]));
const leftSpecLabels = ['Cooling system', 'Pump model', 'Engine type', 'Max pressure', 'Priming performance'];
const rightSpecLabels = ['Discharge performance'];
const leftSpecs = leftSpecLabels.map((label) => keySpecByLabel.get(label)).filter(Boolean);
const rightSpecs = rightSpecLabels.map((label) => keySpecByLabel.get(label)).filter(Boolean);
---

<BaseLayout title={`${pump.title} - Portable Fire Pumps`}>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-slate-950">
    <div class="absolute inset-0 bg-linear-to-r from-slate-900/95 via-slate-900/75 to-slate-900/40"></div>
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10 py-16 lg:py-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1 hidden lg:block">
          <ImageReveal client:load>
            <div class="relative bg-white/5 border border-white/10 rounded-3xl shadow-2xl overflow-hidden group">
              <Image
                src={pump.image}
                alt={pump.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                width={1200}
                height={800}
              />
              <div class="absolute inset-0 bg-black/2"></div>
              <div class="absolute inset-0 bg-linear-to-t from-slate-900/40 via-slate-900/10 to-transparent"></div>
            </div>
          </ImageReveal>
        </div>

        <div class="order-1 lg:order-2">
          <h1 class="text-4xl md:text-6xl font-bold text-white mb-3 leading-tight animate-fadeInUp">
            <span class="brand-gradient-text">{pump.title}</span>
          </h1>
          <p class="text-xl text-slate-200 mb-2 animate-fadeInUp" style="animation-delay: 0.1s">
            {pump.subtitle}
          </p>
          <p class="text-lg text-slate-300 mb-8 leading-relaxed animate-fadeInUp" style="animation-delay: 0.2s">
            {pump.valueProp}
          </p>

          <div class="lg:hidden mb-8 animate-fadeInUp" style="animation-delay: 0.25s">
            <div class="relative bg-white/5 border border-white/10 rounded-3xl shadow-2xl overflow-hidden group">
              <Image
                src={pump.image}
                alt={pump.title}
                class="w-full h-full object-cover"
                width={1200}
                height={800}
              />
              <div class="absolute inset-0 bg-black/2"></div>
              <div class="absolute inset-0 bg-linear-to-t from-slate-900/40 via-slate-900/10 to-transparent"></div>
            </div>
          </div>

          <div class="relative animate-fadeInUp" style="animation-delay: 0.3s">
            <div class="grid grid-cols-1 sm:grid-cols-[auto_1fr] gap-6 mb-8">
              <div class="space-y-4">
                {leftSpecs.map((spec) => (
                  <div class="flex items-start gap-3">
                    <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-white text-slate-900 shrink-0">
                      <img src={spec.icon} alt="" class="w-5 h-5" aria-hidden="true" />
                    </div>
                    <div>
                      <p class="text-xs uppercase tracking-wide text-slate-300">{spec.label}</p>
                      <p class="text-white font-semibold whitespace-pre-line">{spec.value}</p>
                    </div>
                  </div>
                ))}
              </div>
              <div class="space-y-4">
                {rightSpecs.map((spec) => (
                  <>
                    <div class="flex items-start gap-3">
                      <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-white text-slate-900 shrink-0">
                        <img src={spec.icon} alt="" class="w-5 h-5" aria-hidden="true" />
                      </div>
                      <div>
                        <p class="text-xs uppercase tracking-wide text-slate-300">{spec.label}</p>
                        <p class="text-white font-semibold whitespace-pre-line">{spec.value}</p>
                      </div>
                    </div>
                    {spec.label === 'Discharge performance' && (
                      <div class="pl-0">
                        <p class="text-xs uppercase tracking-wide text-white/80 mb-2 ml-9">Performance Curve</p>
                        <div class="w-full rounded-xl">
                          <Image
                            src={p510GraphImg}
                            alt="Pump performance graph"
                            class="w-full h-auto brightness-0 invert"
                            width={640}
                            height={456}
                          />
                        </div>
                      </div>
                    )}
                  </>
                ))}
              </div>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row gap-4 animate-fadeInUp" style="animation-delay: 0.4s">
            <a
              href={catalogPdf}
              class="brand-cta px-6 py-3 text-base"
              download
            >
              Download Specifications (PDF)
            </a>
            <Button href={requestQuoteHref} size="lg" variant="outline" class="border-2! border-white! text-white! hover:bg-white/10! shadow-2xl!">
              Request a Quote
            </Button>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </section>

  <!-- Key Benefits -->
  <Section background="white" class="!py-12 lg:!py-16">
    <div class="text-center mb-8 px-2">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
        Key <span class="brand-gradient-text">Benefits</span>
      </h2>
      <p class="text-lg text-gray-600 max-w-3xl mx-auto">
        Why the {pump.title} is a reliable choice for rapid response teams.
      </p>
    </div>
    <ul class="space-y-4 max-w-3xl mx-auto mt-4 px-4">
      {pump.benefits.map((benefit) => (
        <li class="flex items-center justify-center gap-4">
          <div class="flex items-center justify-center w-8 h-8 rounded-md brand-gradient-bg text-white shrink-0">
            <img src={checkIcon} alt="" class="w-4 h-4 invert" aria-hidden="true" />
          </div>
          <div class="w-[28rem] max-w-full text-left">
            <div class="flex flex-wrap items-baseline gap-x-2">
              <h3 class="text-lg font-bold text-gray-900">{benefit.title}</h3>
              <p class="text-gray-600">{benefit.description}</p>
            </div>
          </div>
        </li>
      ))}
    </ul>
  </Section>

  <!-- Technical Specifications -->
  <Section background="gray" class="!py-12 lg:!py-16">
    <div class="text-center mb-8">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
        Technical <span class="brand-gradient-text">Specifications</span>
      </h2>
      <p class="text-lg text-gray-600 max-w-3xl mx-auto">
        The specifications procurement teams need to evaluate the {pump.title}.
      </p>
    </div>
    <div class="overflow-x-auto bg-white rounded-2xl shadow-xl border border-gray-200">
      <table class="w-full text-left">
        <tbody>
          {pump.specs.map((spec, index) => (
            <tr class={`border-b last:border-b-0 ${index % 2 === 0 ? 'bg-gray-50' : 'bg-white'}`}>
              <th class="px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide w-1/2">
                {spec.label}
              </th>
              <td class="px-5 py-3 text-gray-900 font-semibold whitespace-pre-line">
                {spec.value}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </Section>

  <!-- Related Products -->
  <Section background="white">
    <div class="mb-10 px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
        Related <span class="brand-gradient-text">Pumps</span>
      </h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {relatedPumps.map((item) => (
        <a
          href={`${productsHref}/${item.slug}`}
          class="group block"
        >
          <Card class="p-6 flex flex-col h-full transition-transform duration-300 group-hover:-translate-y-1">
            <div class="relative h-40 mb-4 flex items-center justify-center rounded-xl bg-white shadow-sm overflow-hidden border border-gray-100">
              <div class="absolute inset-0 bg-radial-[circle_at_50%_60%] from-slate-100/80 via-white to-white"></div>
              <Image src={item.image} alt={item.title} class="relative w-full h-full object-contain p-2" width={600} height={400} />
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-1">{item.title}</h3>
            <p class="text-sm text-gray-600">{item.subtitle}</p>
            <div class="mt-auto pt-4 text-sm font-semibold text-gray-700 group-hover:text-[var(--brand-1)] transition-colors">
              View Details →
            </div>
          </Card>
        </a>
      ))}
    </div>
  </Section>
</BaseLayout>
