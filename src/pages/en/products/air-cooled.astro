---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Section from '../../../components/layout/Section.astro';
import MobilePumpCards from '../../../components/products/MobilePumpCards';
import DesktopPumpCards from '../../../components/products/DesktopPumpCards.astro';
import CategoryIntro from '../../../components/products/CategoryIntro.astro';
import ProductsCTA from '../../../components/products/ProductsCTA.astro';
import PageHero from '../../../components/layout/PageHero.astro';
import { Gauge } from 'lucide-react';

import { getFirepumps } from '../../../data/firepumps';
import heroBgImg from '@assets/portable-fire-pumps-hero.jpg';
import { getLocaleFromPathname, localizePath } from '@config/site';
import { getNonProductMetadata } from '@utils/nonProductMetadata';
import { buildItemListSchema } from '@utils/seo/schema';
import { SITE } from '@config/site';

const locale = getLocaleFromPathname(Astro.url.pathname);
const productsBaseHref = localizePath('/products', locale);
const requestQuoteHref = localizePath('/contact-us', locale);
const distributorsHref = localizePath('/distributors', locale);

const firepumps = getFirepumps('en');
const airCooledPumps = firepumps.filter((pump) =>
  pump.keySpecs.some(
    (spec) => spec.key === 'coolingSystem' && spec.value.toLowerCase().includes('air')
  )
);
const categoryIntro = {
  badge: 'Air-Cooled Category',
  title: 'Built for Variable Water Conditions',
  subtitle: 'Independent engine cooling for variable water conditions.',
  description:
    'Air-cooled portable fire pumps are a practical choice when suction water quality is uncertain or debris levels are higher than ideal. Because engine cooling does not depend on the pumped water circuit, these units are easier to deploy in field conditions where setup simplicity and operating reliability matter. They are commonly selected for rapid response, remote access, and applications where a straightforward pump package is preferred.',
  advantages: [
    'No reliance on pumped water for engine cooling',
    'Well suited to debris-heavy or inconsistent water sources',
    'Simple, field-friendly setup and operation',
  ],
};
const metadata = getNonProductMetadata({
  pageKey: 'productsAirCooled',
  locale: 'en',
  pathname: Astro.url.pathname,
  ogImageSrc: heroBgImg.src,
});
const structuredData = buildItemListSchema({
  listName: 'Air-Cooled Portable Fire Pumps',
  canonicalUrl: metadata.canonicalUrl,
  items: airCooledPumps.map((pump) => ({
    name: pump.title,
    url: new URL(localizePath(`/products/${pump.slug}`, 'en'), SITE.url).toString(),
    image: new URL(pump.image.src, SITE.url).toString(),
  })),
});
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  canonicalUrl={metadata.canonicalUrl}
  ogImage={metadata.ogImageUrl}
  locale="en"
  structuredData={structuredData}
>
  <PageHero
    backgroundImage={heroBgImg}
    backgroundAlt="Air-cooled portable fire pumps"
    badge="Products"
    badgeIconComponent={Gauge}
    titleClass="text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight animate-fadeInUp"
    descriptionClass="text-xl md:text-2xl text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed animate-fadeInUp"
    descriptionStyle="animation-delay: 0.1s"
  >
    <Fragment slot="title">
      <span class="brand-gradient-text-fill">
        Air-Cooled<br />
        Portable Fire Pumps
      </span>
    </Fragment>
    <Fragment slot="description">
      Independent cooling for dependable operation where water quality is less predictable.
    </Fragment>
  </PageHero>

  <!-- Main Capabilities -->
  <Section background="white">
    <CategoryIntro {...categoryIntro} />

    <!-- Accordion View for Mobile/Compact -->
    <div class="lg:hidden mb-12">
      <MobilePumpCards capabilities={airCooledPumps} detailsBaseHref={productsBaseHref} locale="en" />
    </div>

    <!-- Grid View for Desktop -->
    <DesktopPumpCards capabilities={airCooledPumps} detailsBaseHref={productsBaseHref} locale="en" />
  </Section>

  <ProductsCTA
    locale="en"
    backgroundImage={heroBgImg}
    contactHref={requestQuoteHref}
    distributorsHref={distributorsHref}
  />
</BaseLayout>
