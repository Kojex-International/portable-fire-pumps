---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Section from '../../../components/ui/Section.astro';
import MobilePumpCards from '../../../components/react/MobilePumpCards';
import DesktopPumpCards from '../../../components/products/DesktopPumpCards.astro';
import ProductsCTA from '../../../components/products/ProductsCTA.astro';
import { Image } from 'astro:assets';
import { Gauge } from 'lucide-react';

import { firepumps } from '../../../data/firepumps';
import heroBgImg from '@assets/portable-fire-pumps-hero.jpg';
import { getLocaleFromPathname, localizePath } from '@config/site';

const locale = getLocaleFromPathname(Astro.url.pathname);
const productsBaseHref = localizePath('/products', locale);
const requestQuoteHref = localizePath('/contact-us', locale);
const distributorsHref = localizePath('/distributors', locale);

const airCooledPumps = firepumps.filter((pump) =>
  pump.keySpecs.some(
    (spec) => spec.label === 'Cooling system' && spec.value.toLowerCase().includes('air')
  )
);
---

<BaseLayout title="Air-Cooled Portable Fire Pumps - Portable Fire Pumps">
  <!-- Hero Section -->
  <section class="relative h-[70vh] min-h-[500px] flex items-center overflow-hidden">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0 bg-slate-900">
      <Image
        src={heroBgImg}
        alt="Air-cooled portable fire pumps"
        class="w-full h-full object-cover"
        loading="eager"
        decoding="async"
        fetchpriority="high"
        width={2070}
        height={1380}
      />
      <div class="absolute inset-0 bg-linear-to-r from-slate-900/95 via-slate-900/80 to-slate-900/50"></div>
    </div>

    <!-- Content -->
    <div class="container mx-auto relative z-10 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center px-4 py-2 mb-6 bg-white/10 backdrop-blur-[6px] text-white text-sm leading-none font-semibold rounded-full shadow-lg border border-white/15">
          <Gauge className="w-4 h-4 mr-2" />
          Products
        </div>

        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight animate-fadeInUp">
          <span class="text-[var(--brand-400)]">
            Air-Cooled<br />
            Portable Fire Pumps
          </span>
        </h1>

        <p class="text-xl md:text-2xl text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed animate-fadeInUp" style="animation-delay: 0.1s">
          Lightweight, rapid-response pumps built for fast deployment and dependable output.
        </p>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </section>

  <!-- Main Capabilities -->
  <Section background="white">
    <!-- Accordion View for Mobile/Compact -->
    <div class="lg:hidden mb-12">
      <MobilePumpCards capabilities={airCooledPumps} detailsBaseHref={productsBaseHref} locale="en" />
    </div>

    <!-- Grid View for Desktop -->
    <DesktopPumpCards capabilities={airCooledPumps} detailsBaseHref={productsBaseHref} locale="en" />
  </Section>

  <ProductsCTA
    locale="en"
    backgroundImage={heroBgImg}
    contactHref={requestQuoteHref}
    distributorsHref={distributorsHref}
  />
</BaseLayout>
