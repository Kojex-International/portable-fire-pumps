---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/layout/PageHero.astro';
import Section from '../../components/layout/Section.astro';
import SectionHeader from '../../components/layout/SectionHeading.astro';
import ProductsCTA from '../../components/products/ProductsCTA.astro';
import ProductRelatedPumps from '../../components/products/ProductRelatedPumps.astro';
import { Check, Gauge, Workflow } from 'lucide-react';

import heroBgImg from '@assets/product-features-hero.webp';
import relayDiagramImg from '@assets/portable-fire-pump-relay-pumping-diagram.webp';
import shibauraLogoMark from '@assets/shibaura-logo-mark.svg?url';
import { getNonProductMetadata } from '@utils/nonProductMetadata';
import { localizePath } from '@config/site';
import { getFirepumps } from '../../data/firepumps';

const metadata = getNonProductMetadata({
  pageKey: 'relayPumping',
  locale: 'en',
  pathname: Astro.url.pathname,
  ogImageSrc: heroBgImg.src,
});

const waterCooledHref = localizePath('/products/water-cooled', 'en');
const productsBaseHref = localizePath('/products', 'en');
const ff500Href = localizePath('/products/ff500ar-a', 'en');
const p572Href = localizePath('/products/p572s-a', 'en');
const fk500Href = localizePath('/products/fk500-a', 'en');
const contactHref = localizePath('/contact-us', 'en');
const distributorsHref = localizePath('/distributors', 'en');
const recommendedPumps = getFirepumps('en').filter((pump) =>
  ['ff500ar-a', 'p572s-a', 'fk500-a'].includes(pump.slug)
);
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  canonicalUrl={metadata.canonicalUrl}
  ogImage={metadata.ogImageUrl}
  locale="en"
  alternates={{
    en: 'https://www.portable-fire-pumps.com/en/long-distance-relay-pumping/',
    fr: 'https://www.portable-fire-pumps.com/fr/long-distance-relay-pumping/',
    xDefault: 'https://www.portable-fire-pumps.com/en/long-distance-relay-pumping/',
  }}
>
  <PageHero
    backgroundImage={heroBgImg}
    backgroundAlt="Long-distance relay pumping with portable fire pumps"
    badge="Use Case"
    badgeIconComponent={Workflow}
    titleClass="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight animate-fadeInUp"
    descriptionClass="text-xl md:text-2xl text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed animate-fadeInUp"
    descriptionStyle="animation-delay: 0.1s"
  >
    <Fragment slot="title">
      <span class="brand-gradient-text-fill">Long-Distance Relay Pumping</span>
    </Fragment>
    <Fragment slot="description">
      Portable fire pumps configured for relay pumping help move water over extended hose lays when the source is remote from the incident.
    </Fragment>
  </PageHero>

  <Section background="white">
    <SectionHeader
      badge="Operational Fit"
      badgeIconComponent={Gauge}
      title="When relay pumping"
      highlight="matters"
      description="Relay pumping is used when water must be moved farther than a single pump can efficiently support. Each stage maintains pressure and flow so water can continue moving toward the fireground or target site."
      class="mb-12"
    />

    <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
      <div class="space-y-6 mobile-body-gutter text-lg leading-relaxed text-slate-700">
        <p>
          This setup is commonly used for wildfire response, rural water supply, and long transfer operations where a pond, river, or tank source is well removed from the working area. The relay layout reduces pressure loss across long hose lines and helps sustain usable discharge at the final pump.
        </p>
        <ul class="space-y-3 text-base">
          <li class="flex items-start gap-3">
            <Check className="mt-1 h-5 w-5 shrink-0 text-green-600" />
            <span>Maintains water delivery over long hose distances.</span>
          </li>
          <li class="flex items-start gap-3">
            <Check className="mt-1 h-5 w-5 shrink-0 text-green-600" />
            <span>Supports remote water sources where direct attack supply is not practical.</span>
          </li>
          <li class="flex items-start gap-3">
            <Check className="mt-1 h-5 w-5 shrink-0 text-green-600" />
            <span>Rewards stable cooling, reliable priming, and sustained-duty pump performance.</span>
          </li>
        </ul>
      </div>

      <figure class="lg:pt-1">
        <div class="overflow-hidden rounded-xl border border-slate-200 bg-white">
          <img src={relayDiagramImg.src} alt="Relay pumping diagram showing multiple pump stages" class="w-full block" />
        </div>
        <figcaption class="mt-4 text-sm leading-relaxed text-slate-600">
          Relay layouts often favor water-cooled pumps for sustained transfer when relatively clean water is available.
        </figcaption>
      </figure>
    </div>
  </Section>

  <Section background="gray">
    <SectionHeader
      badge="Recommended Pumps"
      badgeIconComponent={Gauge}
      title="Models worth reviewing"
      highlight="for relay pumping"
      description="These water-cooled models are a strong starting point for sustained relay layouts, long-distance water delivery, and stable transfer performance."
      class="mb-10"
    />

    <ProductRelatedPumps
      relatedPumps={recommendedPumps}
      productsHref={productsBaseHref}
      titleLeading="Recommended"
      titleHighlight="Pumps"
      shibauraLogoMark={shibauraLogoMark}
      locale="en"
      showHeading={false}
      embedded={true}
    />
  </Section>

  <ProductsCTA
    locale="en"
    backgroundImage={heroBgImg}
    contactHref={contactHref}
    distributorsHref={distributorsHref}
    badge="Category Fit"
    titleLine1="Start with"
    titleLine2="Water-Cooled Pumps"
    description="Water-cooled portable fire pumps are typically the better fit for extended relay layouts and sustained long-distance water transfer when relatively clean water is available."
    primaryCta="View Water-Cooled Pumps"
    primaryHref={waterCooledHref}
    secondaryCta="Find a Distributor"
    secondaryHref={distributorsHref}
  />
</BaseLayout>
