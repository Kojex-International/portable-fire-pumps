---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/ui/Section.astro';
import Card from '@components/ui/Card.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import PageHero from '@components/heroes/PageHero.astro';
import RFQForm from '@components/react/RFQForm';
import { getLocaleFromPathname, localizePath } from '@config/site';
import { Image } from 'astro:assets';
import { MessageSquare, Clock, Shield, CheckCircle2, Phone, Mail, MessageCircle, Award, TrendingUp, Users } from 'lucide-react';
import rfqBgImg from '@assets/contactus.png';
import warehouseImg from '@assets/photo-1563013544-824ae1b704d3.jpg';

const locale = getLocaleFromPathname(Astro.url.pathname);
const thanksHref = '/contact-us/thanks?lang=en';
---
<style>
  .sidebar-icon-sub {
    color: #64748b;
  }
</style>



<BaseLayout title="Contact Us - Portable Fire Pumps">
  <PageHero
    backgroundImage={rfqBgImg}
    backgroundAlt="Professional logistics and supply chain management"
    badge="Contact Sales & Support"
    badgeIconComponent={MessageSquare}
    sectionClass="relative h-[500px] md:h-[600px] flex items-center overflow-hidden"
    badgeClass="inline-flex items-center px-4 py-2 mb-6 bg-white/10 backdrop-blur-[6px] text-white text-sm leading-none font-semibold rounded-full shadow-lg border border-white/15 animate-fadeInUp"
    titleClass="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight animate-fadeInUp"
    descriptionClass="text-xl md:text-2xl text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed animate-fadeInUp"
    descriptionStyle="animation-delay: 0.2s"
  >
    <Fragment slot="title">
      <span class="brand-gradient-text-fill">Contact Us</span>
    </Fragment>
    <Fragment slot="description">
      Contact us for quotes, pump guidance, and parts or service support.
      We typically respond within 24 hours.
    </Fragment>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 pt-8 border-t border-white/20 animate-fadeInUp" style="animation-delay: 0.3s">
      <div class="group">
        <div class="text-lg md:text-xl font-semibold text-slate-100 mb-1">24 hours</div>
        <div class="text-sm text-slate-300">Typical Response</div>
      </div>
      <div class="group">
        <div class="text-lg md:text-xl font-semibold text-slate-100 mb-1">70+ years</div>
        <div class="text-sm text-slate-300">Pump Expertise</div>
      </div>
      <div class="group">
        <div class="text-lg md:text-xl font-semibold text-slate-100 mb-1">Field</div>
        <div class="text-sm text-slate-300">Proven Reliability</div>
      </div>
      <div class="group">
        <div class="text-lg md:text-xl font-semibold text-slate-100 mb-1">Support</div>
        <div class="text-sm text-slate-300">Parts & Service</div>
      </div>
    </div>
  </PageHero>

  <!-- Main Form Section -->
  <Section background="gray">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <!-- Form -->
      <div class="lg:col-span-2">
        <Card>
          <RFQForm action={thanksHref} locale="en" />
        </Card>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <!-- Contact Info Card -->
        <Card class="bg-slate-50 border-slate-200">
          <div class="flex items-center mb-4">
            <div class="w-10 h-10 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center mr-3">
              <Phone className="w-5 h-5 sidebar-icon-sub" />
            </div>
            <h3 class="text-xl font-bold text-gray-900">Need Help?</h3>
          </div>
          <div class="space-y-4 text-sm">
            <div class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-sm transition-shadow">
              <div class="w-10 h-10 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center shrink-0">
                <Phone className="w-5 h-5 sidebar-icon-sub" />
              </div>
              <div>
                <div class="font-semibold text-gray-900">Phone</div>
                <div class="text-gray-600 font-medium">438 377 6729</div>
                <div class="text-gray-500 text-xs">Mon-Fri, 8am-6pm EST</div>
              </div>
            </div>

            <div class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-sm transition-shadow">
              <div class="w-10 h-10 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center shrink-0">
                <Mail className="w-5 h-5 sidebar-icon-sub" />
              </div>
              <div>
                <div class="font-semibold text-gray-900">Email</div>
                <div class="text-gray-600 font-medium">info@kojex.com</div>
                <div class="text-gray-500 text-xs">24-hour response time</div>
              </div>
            </div>

            <!-- Live Chat hidden for now -->
          </div>
        </Card>

        <!-- What to Expect Card -->
        <Card class="bg-slate-50 border-slate-200">
          <div class="flex items-center mb-4">
            <div class="w-10 h-10 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center mr-3">
              <Clock className="w-5 h-5 sidebar-icon-sub" />
            </div>
            <h3 class="text-xl font-bold text-gray-900">What to Expect</h3>
          </div>
          <ol class="space-y-4 text-sm">
            <li class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-sm transition-shadow">
              <span class="shrink-0 w-8 h-8 rounded-full bg-slate-100 border border-slate-200 sidebar-icon-sub flex items-center justify-center font-bold text-sm">1</span>
              <div>
                <span class="text-gray-900 font-semibold block">Request Received</span>
                <span class="text-gray-600">We confirm your inquiry immediately.</span>
              </div>
            </li>
            <li class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-sm transition-shadow">
              <span class="shrink-0 w-8 h-8 rounded-full bg-slate-100 border border-slate-200 sidebar-icon-sub flex items-center justify-center font-bold text-sm">2</span>
              <div>
                <span class="text-gray-900 font-semibold block">Response Within 24 Hours</span>
                <span class="text-gray-600">Our team reviews your request and replies within one business day.</span>
              </div>
            </li>
            <li class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-sm transition-shadow">
              <span class="shrink-0 w-8 h-8 rounded-full bg-slate-100 border border-slate-200 sidebar-icon-sub flex items-center justify-center font-bold text-sm">3</span>
              <div>
                <span class="text-gray-900 font-semibold block">Quote or Support Follow-Up</span>
                <span class="text-gray-600">We provide the relevant quote, product guidance, or parts/service support.</span>
              </div>
            </li>
          </ol>
        </Card>

        <!-- Trust Indicators -->
        <Card class="bg-slate-50 border-slate-200">
          <div class="flex items-center mb-4">
            <div class="w-10 h-10 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center mr-3">
              <Award className="w-5 h-5 sidebar-icon-sub" />
            </div>
            <h3 class="text-xl font-bold text-gray-900">Why Choose Us?</h3>
          </div>
          <ul class="space-y-3 text-sm">
            <li class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-sm transition-shadow">
              <div class="w-8 h-8 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center shrink-0">
                <TrendingUp className="w-4 h-4 sidebar-icon-sub" />
              </div>
              <span class="text-gray-700 pt-1">70+ years in portable fire pumps</span>
            </li>
            <li class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-sm transition-shadow">
              <div class="w-8 h-8 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center shrink-0">
                <CheckCircle2 className="w-4 h-4 sidebar-icon-sub" />
              </div>
              <span class="text-gray-700 pt-1">Field-tested reliability and rugged design</span>
            </li>
            <li class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-sm transition-shadow">
              <div class="w-8 h-8 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center shrink-0">
                <Shield className="w-4 h-4 sidebar-icon-sub" />
              </div>
              <span class="text-gray-700 pt-1">Serviceable parts and dealer support</span>
            </li>
            <li class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-sm transition-shadow">
              <div class="w-8 h-8 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center shrink-0">
                <Users className="w-4 h-4 sidebar-icon-sub" />
              </div>
              <span class="text-gray-700 pt-1">Support for municipal, industrial, and wildfire use</span>
            </li>
          </ul>
        </Card>
      </div>
    </div>
  </Section>

  <!-- Trust & Success Section hidden for now -->
