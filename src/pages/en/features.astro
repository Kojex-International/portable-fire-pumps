---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/layout/PageHero.astro';
import Section from '../../components/layout/Section.astro';
import AutoRelaySection from '../../components/products/AutoRelaySection.astro';
import PumpFeaturesSection from '../../components/products/PumpFeaturesSection.astro';
import ProductsCTA from '../../components/products/ProductsCTA.astro';
import { Gauge } from 'lucide-react';
import heroBgImg from '@assets/portable-fire-pumps-hero.jpg';
import productFeatureHeroImg from '@assets/product-features-hero.webp';
import { getLocaleFromPathname, localizePath } from '@config/site';
import { getNonProductMetadata } from '@utils/nonProductMetadata';

const locale = getLocaleFromPathname(Astro.url.pathname);
const requestQuoteHref = localizePath('/contact-us', locale);
const distributorsHref = localizePath('/distributors', locale);
const relayHref = localizePath('/long-distance-relay-pumping', locale);
const waterCooledHref = localizePath('/products/water-cooled', locale);
const metadata = getNonProductMetadata({
  pageKey: 'features',
  locale: 'en',
  pathname: Astro.url.pathname,
  ogImageSrc: productFeatureHeroImg.src,
});
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  canonicalUrl={metadata.canonicalUrl}
  ogImage={metadata.ogImageUrl}
>
  <PageHero
    backgroundImage={productFeatureHeroImg}
    backgroundAlt="Portable fire pump engineering features"
    badge="Features"
    badgeIconComponent={Gauge}
    titleClass="text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight animate-fadeInUp"
    descriptionClass="text-xl md:text-2xl text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed animate-fadeInUp"
    descriptionStyle="animation-delay: 0.1s"
  >
    <Fragment slot="title">
      <span class="brand-gradient-text-fill">Fire Pump Features</span>
    </Fragment>
    <Fragment slot="description">
      Pump technologies and operational systems designed for reliable firefighting performance.
    </Fragment>
  </PageHero>

  <Section background="white">
    <div class="mx-auto max-w-4xl px-4 pb-8 text-center text-base leading-relaxed text-slate-600">
      These engineering features are most relevant when comparing <a href={relayHref} class="font-semibold text-[var(--brand-1)] hover:underline">long-distance relay pumping layouts</a> and the <a href={waterCooledHref} class="font-semibold text-[var(--brand-1)] hover:underline">water-cooled pumps</a> built for sustained-duty operation.
    </div>
    <div id="long-distance-water-delivery">
      <AutoRelaySection locale="en" variant="longDistance" showVideo={true} badgeIconComponent={Gauge} />
    </div>
    <div id="water-relay-system" class="mt-16 lg:mt-24">
      <AutoRelaySection locale="en" variant="waterRelay" showVideo={false} badgeIconComponent={Gauge} />
    </div>
    <div id="pump-features" class="mt-16 lg:mt-24">
      <PumpFeaturesSection locale="en" />
    </div>
  </Section>

  <ProductsCTA
    locale="en"
    backgroundImage={heroBgImg}
    contactHref={requestQuoteHref}
    distributorsHref={distributorsHref}
    badge="Related Use Case"
    titleLine1="Need more context on"
    titleLine2="Relay Pumping?"
    description="See how relay pumping supports long-distance water delivery, then compare the water-cooled models that best fit sustained relay layouts."
    primaryCta="View Relay Pumping"
    primaryHref={localizePath('/long-distance-relay-pumping', locale)}
    secondaryCta="View Water-Cooled Pumps"
    secondaryHref={localizePath('/products/water-cooled', locale)}
  />
</BaseLayout>
