---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/layout/Section.astro';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';
import SectionHeader from '../../components/layout/SectionHeading.astro';
import PageHero from '../../components/layout/PageHero.astro';
import { Image } from 'astro:assets';
import ImageReveal from '../../components/react/ImageReveal';
import { getLocaleFromPathname, localizePath } from '@config/site';
import { Handshake, UserPlus } from 'lucide-react';
import { getNonProductMetadata } from '@utils/nonProductMetadata';

import easternCanadaDistributorImg from '@assets/distributors/larsenal-distributor-logo.svg';
import westernCanadaDistributorImg from '@assets/distributors/flash-wildfire-services-logo.avif';

import distributorsHeroImg from '@assets/distributors-network-hero.webp';
import distributorsCtaImg from '@assets/distributors-support-cta.webp';

const distributors = [
  {
    name: "L'Arsenal",
    location: 'Drummondville, Quebec',
    address: '2250, rue Andre-C.-Hamel, Drummondville, QC J2C 8B1',
    type: 'Fire apparatus and emergency equipment',
    region: 'Quebec',
    image: easternCanadaDistributorImg,
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
    </svg>`,
    phone: '819 474-2111',
    phoneAlt: '1 800 266-7610',
    email: 'info@larsenal.ca',
    website: 'https://larsenal.ca/',
    description:
      "Founded in 1998, L'Arsenal offers emergency-response products and services, including fire truck and equipment sales, maintenance, repairs, and parts service.",
    focus:
      'Based in Drummondville, serving Quebec fire services plus industrial, government, and institutional organizations.',
    services: [
      'Fire trucks and emergency equipment',
      'Maintenance and repair services',
      'Parts support and service'
    ]
  },
  {
    name: 'Flash Wildfire Services',
    location: 'Sherwood Park, Alberta',
    address: '2899 Broadmoor Boulevard, 150, Sherwood Park, AB T8H 1B5',
    type: 'Wildfire protection equipment',
    region: 'BC, Alberta, Saskatchewan',
    image: westernCanadaDistributorImg,
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
    </svg>`,
    phone: '780 467 7234',
    email: 'info@flashwildfireservices.ca',
    website: 'https://www.flashwildfireservices.ca/',
    description:
      'Supplier of wildfire pumps, sprinkler systems, WATERAX components, fire hose, and hardware for wildfire defense.',
    focus:
      'Supports WUI properties, homeowners, utilities, municipalities, and commercial fire-protection applications.',
    services: [
      'Wildfire pumps and WATERAX components',
      'Sprinkler systems and protection kits',
      'Fire hose, fittings, and hardware'
    ]
  }
];

const locale = getLocaleFromPathname(Astro.url.pathname);
const requestQuoteHref = localizePath('/contact-us', locale);
const distributorsHref = localizePath('/distributors', locale);
const productsHref = localizePath('/products', locale);
const metadata = getNonProductMetadata({
  pageKey: 'distributors',
  locale: 'en',
  pathname: Astro.url.pathname,
  ogImageSrc: distributorsHeroImg.src,
});
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  canonicalUrl={metadata.canonicalUrl}
  ogImage={metadata.ogImageUrl}
>
  <PageHero
    backgroundImage={distributorsHeroImg}
    backgroundAlt="Portable fire pump distributor network across Canada"
    badge="Our Distributor Network"
    badgeIconComponent={Handshake}
    titleClass="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight animate-fadeInUp"
    descriptionClass="text-xl md:text-2xl text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed animate-fadeInUp"
    descriptionStyle="animation-delay: 0.1s"
  >
    <Fragment slot="title">
      <span class="brand-gradient-text-fill">
        Distributors
      </span>
    </Fragment>
    <Fragment slot="description">
      Trusted partners across North America delivering portable fire pump expertise, parts, and service.
    </Fragment>
  </PageHero>

  <!-- Facilities Grid -->
  <Section background="gray">
    <SectionHeader
      badge="Our Distributors"
      badgeIconComponent={Handshake}
      title="Trusted"
      highlight="Distributor Network"
      description="Verified partners with proven expertise in emergency response and wildfire protection equipment."
      class="mb-16"
    />
    <div class="mx-auto mb-10 max-w-4xl mobile-body-gutter text-center text-base leading-relaxed text-slate-600">
      Teams comparing regional support can review the full <a href={productsHref} class="font-semibold text-[var(--brand-1)] hover:underline">portable fire pump range</a> first, then contact the distributor best aligned with their operational territory.
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 auto-rows-fr">
      {distributors.map((distributor, index) => (
        <ImageReveal client:load delay={index * 0.1} className="h-full">
          <Card hover class="overflow-hidden animate-fadeInUp group h-full flex flex-col" style={`animation-delay: ${index * 0.1}s`}>
            <!-- Distributor Image -->
            <div class="relative h-64 overflow-hidden bg-black">
              <Image 
                src={distributor.image}
                alt={distributor.name}
                class="w-full h-full object-contain p-6"
              />
              <div class="absolute inset-0 bg-linear-to-t from-gray-900/80 via-gray-900/40 to-transparent"></div>
            </div>

            <div class="p-6 space-y-5 flex-1 flex flex-col">
              <div>
                <h3 class="text-2xl font-bold text-gray-900 mb-1">{distributor.name}</h3>
                <p class="text-sm text-gray-500">{distributor.type}</p>
                <p class="text-sm font-semibold text-primary-700">{distributor.region}</p>
              </div>
              <p class="text-sm text-gray-600 leading-relaxed">
                {distributor.description}
              </p>

              <!-- Contact -->
              <div>
                <h4 class="text-sm font-semibold text-gray-700 uppercase mb-3 tracking-wide flex items-center gap-2">
                  <svg class="w-4 h-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16h6M12 14a4 4 0 100-8 4 4 0 000 8z" />
                  </svg>
                  Contact
                </h4>
                <div class="space-y-2 text-sm text-gray-600">
                  <p class="flex items-start gap-2">
                    <svg class="w-4 h-4 text-primary-600 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    <span>{distributor.address}</span>
                  </p>
                  <p class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                    </svg>
                    <span>{distributor.phone}{distributor.phoneAlt ? ` | ${distributor.phoneAlt}` : ''}</span>
                  </p>
                  <p class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12H8m8 0l-8-5m8 5l-8 5" />
                    </svg>
                    <a href={`mailto:${distributor.email}`} class="text-primary-700 hover:text-primary-900 underline-offset-4 hover:underline">
                      {distributor.email}
                    </a>
                  </p>
                  <p class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 010 5.656M15 7a7 7 0 010 10M9 13a3 3 0 010-2m3-6a9 9 0 010 14" />
                    </svg>
                    <a href={distributor.website} class="text-primary-700 hover:text-primary-900 underline-offset-4 hover:underline" target="_blank" rel="noreferrer">
                      {distributor.website.replace('https://', '').replace('http://', '')}
                    </a>
                  </p>
                </div>
              </div>

              <!-- Focus -->
              <div class="border-t border-gray-200 pt-4">
                <h4 class="text-sm font-semibold text-gray-700 uppercase mb-3 tracking-wide flex items-center gap-2">
                  <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  Coverage & Offerings
                </h4>
                <p class="text-sm text-gray-600 mb-3">
                  {distributor.focus}
                </p>
                <ul class="grid grid-cols-1 gap-2.5">
                  {distributor.services.map((service) => (
                    <li class="flex items-start space-x-2.5 text-sm">
                      <svg class="w-4 h-4 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      <span class="text-gray-600">{service}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </Card>
        </ImageReveal>
      ))}
    </div>
  </Section>

  <!-- CTA Section -->
  <section class="relative py-24 md:py-28 overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <Image 
        src={distributorsCtaImg}
        alt="Portable fire pump distributor partnership team discussion"
        class="w-full h-full object-cover"
        width={2070}
        height={1380}
      />
      <div class="absolute inset-0 cta-overlay-gradient"></div>
    </div>

    <!-- Content -->
    <div class="container mx-auto mobile-container-gutter relative z-10">
      <div class="max-w-4xl mx-auto text-center text-white">
        <div class="inline-flex items-center px-4 py-2 mb-6 bg-white/10 backdrop-blur-sm text-white text-sm font-semibold rounded-full">
          <UserPlus className="w-4 h-4 mr-2" />
          Distributors Wanted
        </div>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
          Seeking <span class="text-[var(--brand-400)]">new distributors</span>
        </h2>
        <p class="text-xl md:text-2xl text-slate-200 mb-8 max-w-2xl mx-auto leading-relaxed">
          We are actively expanding our distributor network for portable fire pumps. Please contact us if you are interested in partnership opportunities.
        </p>
        <div class="flex flex-col sm:flex-row gap-6 justify-center">
          <Button href={requestQuoteHref} size="lg" class="brand-cta">
            Contact Us
          </Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
