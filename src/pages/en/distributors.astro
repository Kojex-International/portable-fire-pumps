---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/ui/Section.astro';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import { Image } from 'astro:assets';
import ImageReveal from '../../components/react/ImageReveal';
import FacilityStats from '../../components/react/FacilityStats';
import { getLocaleFromPathname, localizePath } from '@config/site';

import easternCanadaDistributorImg from '@assets/distributors/logo-larsenal.svg';
import westernCanadaDistributorImg from '@assets/distributors/Flash_Wildfire_Services_Logo_Transparent_Background.avif';

import distributorsHeroImg from '@assets/distributorsHeroImg.png';
import distributorsCtaImg from '@assets/distributorsCtaImg.png';

const distributors = [
  {
    name: "L'Arsenal",
    location: 'Drummondville, Quebec',
    address: '2250, rue Andre-C.-Hamel, Drummondville, QC J2C 8B1',
    type: 'Fire apparatus and emergency equipment',
    region: 'Quebec',
    image: easternCanadaDistributorImg,
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
    </svg>`,
    phone: '819 474-2111',
    phoneAlt: '1 800 266-7610',
    email: 'info@larsenal.ca',
    website: 'https://larsenal.ca/',
    description:
      "Founded in 1998, L'Arsenal offers emergency-response products and services, including fire truck and equipment sales, maintenance, repairs, and parts service.",
    focus:
      'Based in Drummondville, serving Quebec fire services plus industrial, government, and institutional organizations.',
    services: [
      'Fire trucks and emergency equipment',
      'Maintenance and repair services',
      'Parts support and service'
    ]
  },
  {
    name: 'Flash Wildfire Services',
    location: 'Sherwood Park, Alberta',
    address: '2899 Broadmoor Boulevard, 150, Sherwood Park, AB T8H 1B5',
    type: 'Wildfire protection equipment',
    region: 'BC, Alberta, Saskatchewan',
    image: westernCanadaDistributorImg,
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
    </svg>`,
    phone: '780 467 7234',
    email: 'info@flashwildfireservices.ca',
    website: 'https://www.flashwildfireservices.ca/',
    description:
      'Supplier of wildfire pumps, sprinkler systems, WATERAX components, fire hose, and hardware for wildfire defense.',
    focus:
      'Supports WUI properties, homeowners, utilities, municipalities, and commercial fire-protection applications.',
    services: [
      'Wildfire pumps and WATERAX components',
      'Sprinkler systems and protection kits',
      'Fire hose, fittings, and hardware'
    ]
  }
];

const facilityStandards = [
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
    </svg>`,
    title: 'Security',
    description: '24/7 surveillance, access control, and security personnel at all locations',
    color: 'from-blue-500 to-blue-600'
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
    </svg>`,
    title: 'Quality Control',
    description: 'Rigorous inspection processes and quality management systems',
    color: 'from-teal-500 to-teal-600'
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
    </svg>`,
    title: 'Efficiency',
    description: 'Optimized layouts and automated systems for maximum throughput',
    color: 'from-amber-500 to-amber-600'
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>`,
    title: 'Sustainability',
    description: 'Energy-efficient operations and environmental management programs',
    color: 'from-green-500 to-green-600'
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
    </svg>`,
    title: 'Technology',
    description: 'Real-time tracking, WMS, and automated reporting systems',
    color: 'from-purple-500 to-purple-600'
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
    </svg>`,
    title: 'Expert Team',
    description: 'Trained professionals dedicated to operational excellence',
    color: 'from-pink-500 to-pink-600'
  }
];

const locale = getLocaleFromPathname(Astro.url.pathname);
const requestQuoteHref = localizePath('/contact-us', locale);
const distributorsHref = localizePath('/distributors', locale);
---

<BaseLayout title="Distributors - Portable Fire Pumps">
  <!-- Hero Section -->
  <section class="relative h-[70vh] min-h-[500px] flex items-center overflow-hidden">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0">
      <Image 
        src= {distributorsHeroImg}
        alt="Modern facilities and infrastructure"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-linear-to-r from-slate-900/95 via-slate-900/80 to-slate-900/50"></div>
    </div>

    <!-- Content -->
    <div class="container mx-auto relative z-10 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center px-4 py-2 mb-6 brand-gradient-bg text-white text-sm font-semibold rounded-full shadow-lg">
          <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z" />
          </svg>
          Our Distributor Network
        </div>
        
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight animate-fadeInUp">
          <span class="brand-gradient-text">
            Distributors
          </span>
        </h1>
        
        <p class="text-xl md:text-2xl text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed animate-fadeInUp" style="animation-delay: 0.1s">
          Trusted partners across North America delivering portable fire pump expertise, parts, and service.
        </p>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </section>

  <!-- Quick Stats -->
  <!-- <Section background="white" class="relative z-20 -mt-20 lg:-mt-28 pt-0!">
    <FacilityStats client:load />
  </Section> -->

  <!-- Facilities Grid -->
  <Section background="gray">
    <SectionHeader
      badge="Our Distributors"
      title="Trusted"
      highlight="Distributor Network"
      description="Verified partners with proven expertise in emergency response and wildfire protection equipment."
      class="mb-16"
    />

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      {distributors.map((distributor, index) => (
        <ImageReveal client:load delay={index * 0.1}>
          <Card hover class="overflow-hidden animate-fadeInUp group" style={`animation-delay: ${index * 0.1}s`}>
            <!-- Distributor Image -->
            <div class="relative h-64 overflow-hidden bg-black">
              <Image 
                src={distributor.image}
                alt={distributor.name}
                class="w-full h-full object-contain p-6"
              />
              <div class="absolute inset-0 bg-linear-to-t from-gray-900/80 via-gray-900/40 to-transparent"></div>
              <div class="absolute top-4 right-4">
                <div class="w-12 h-12 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center border border-white/30" set:html={distributor.icon}></div>
              </div>
            </div>

            <div class="p-6 space-y-5">
              <div>
                <h3 class="text-2xl font-bold text-gray-900 mb-1">{distributor.name}</h3>
                <p class="text-sm text-gray-500">{distributor.type}</p>
                <p class="text-sm font-semibold text-primary-700">{distributor.region}</p>
              </div>
              <p class="text-sm text-gray-600 leading-relaxed">
                {distributor.description}
              </p>

              <!-- Contact -->
              <div>
                <h4 class="text-sm font-semibold text-gray-700 uppercase mb-3 tracking-wide flex items-center gap-2">
                  <svg class="w-4 h-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16h6M12 14a4 4 0 100-8 4 4 0 000 8z" />
                  </svg>
                  Contact
                </h4>
                <div class="space-y-2 text-sm text-gray-600">
                  <p class="flex items-start gap-2">
                    <svg class="w-4 h-4 text-primary-600 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    <span>{distributor.address}</span>
                  </p>
                  <p class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                    </svg>
                    <span>{distributor.phone}{distributor.phoneAlt ? ` | ${distributor.phoneAlt}` : ''}</span>
                  </p>
                  <p class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12H8m8 0l-8-5m8 5l-8 5" />
                    </svg>
                    <a href={`mailto:${distributor.email}`} class="text-primary-700 hover:text-primary-900 underline-offset-4 hover:underline">
                      {distributor.email}
                    </a>
                  </p>
                  <p class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 010 5.656M15 7a7 7 0 010 10M9 13a3 3 0 010-2m3-6a9 9 0 010 14" />
                    </svg>
                    <a href={distributor.website} class="text-primary-700 hover:text-primary-900 underline-offset-4 hover:underline" target="_blank" rel="noreferrer">
                      {distributor.website.replace('https://', '').replace('http://', '')}
                    </a>
                  </p>
                </div>
              </div>

              <!-- Focus -->
              <div class="border-t border-gray-200 pt-4">
                <h4 class="text-sm font-semibold text-gray-700 uppercase mb-3 tracking-wide flex items-center gap-2">
                  <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  Coverage & Offerings
                </h4>
                <p class="text-sm text-gray-600 mb-3">
                  {distributor.focus}
                </p>
                <ul class="grid grid-cols-1 gap-2.5">
                  {distributor.services.map((service) => (
                    <li class="flex items-start space-x-2.5 text-sm">
                      <svg class="w-4 h-4 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      <span class="text-gray-600">{service}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </Card>
        </ImageReveal>
      ))}
    </div>
  </Section>

  <!-- Map Section -->
  <!-- <Section background="white">
    <Card class="overflow-hidden">
      <div class="text-center mb-8">
        <div class="inline-block px-4 py-2 mb-4 bg-primary-100 text-primary-800 text-sm font-semibold rounded-full">
          Network Coverage
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Strategic <span class="gradient-text">Coverage</span>
        </h2>
        <p class="text-gray-600 max-w-2xl mx-auto">
          Our facilities are strategically positioned to provide optimal coverage across North America
        </p>
      </div> -->
      
      <!-- Map Placeholder -->
      <!-- <div class="relative aspect-video bg-linear-to-br from-primary-50 via-white to-secondary-50 rounded-xl overflow-hidden border border-gray-200">
        <div class="absolute inset-0 flex items-center justify-center z-10">
          <div class="text-center">
            <svg class="w-24 h-24 mx-auto text-primary-300 mb-4 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p class="text-gray-600 font-semibold text-lg mb-2">Interactive Map</p>
            <p class="text-sm text-gray-400">Contact us for detailed facility information and tours</p>
          </div>
        </div> -->
        
        <!-- Decorative location markers -->
        <!-- <div class="absolute inset-0 opacity-40">
          <div class="absolute top-1/4 left-1/4 w-4 h-4 bg-primary-600 rounded-full animate-pulse shadow-lg"></div>
          <div class="absolute top-1/3 left-1/2 w-4 h-4 bg-primary-600 rounded-full animate-pulse shadow-lg" style="animation-delay: 0.2s"></div>
          <div class="absolute top-1/2 right-1/3 w-4 h-4 bg-primary-600 rounded-full animate-pulse shadow-lg" style="animation-delay: 0.4s"></div>
          <div class="absolute bottom-1/3 left-1/3 w-4 h-4 bg-primary-600 rounded-full animate-pulse shadow-lg" style="animation-delay: 0.6s"></div>
          <div class="absolute bottom-1/4 right-1/4 w-4 h-4 bg-primary-600 rounded-full animate-pulse shadow-lg" style="animation-delay: 0.8s"></div>
          <div class="absolute top-2/3 right-1/4 w-4 h-4 bg-primary-600 rounded-full animate-pulse shadow-lg" style="animation-delay: 1s"></div>
        </div>
      </div>
    </Card>
  </Section> -->

  <!-- Facility Standards -->
  <!-- <Section background="gradient">
    <div class="text-center mb-16">
      <div class="inline-block px-4 py-2 mb-4 bg-white/80 backdrop-blur-sm text-primary-800 text-sm font-semibold rounded-full border border-primary-200">
        Our Standards
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        Facility <span class="gradient-text">Standards</span>
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
        Every facility meets our rigorous standards for safety, security, and operational excellence.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {facilityStandards.map((feature, index) => (
        <Card hover class="text-center animate-fadeInUp group" style={`animation-delay: ${index * 0.1}s`}>
          <div class={`w-16 h-16 mx-auto mb-4 rounded-xl bg-linear-to-br ${feature.color} flex items-center justify-center group-hover:scale-110 transition-transform duration-300 shadow-lg`} set:html={feature.icon}></div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">{feature.title}</h3>
          <p class="text-gray-600 text-sm leading-relaxed">{feature.description}</p>
        </Card>
      ))}
    </div>
  </Section> -->

  <!-- CTA Section -->
  <section class="relative py-32 overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <Image 
        src={distributorsCtaImg}
        alt="Modern warehouse operations"
        class="w-full h-full object-cover"
        width={2070}
        height={1380}
      />
      <div class="absolute inset-0 cta-overlay-gradient"></div>
    </div>

    <!-- Content -->
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-4xl mx-auto text-center text-white">
        <div class="inline-block px-4 py-2 mb-6 bg-white/10 backdrop-blur-sm text-white text-sm font-semibold rounded-full">
          Dealers Wanted
        </div>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
          Seeking <span class="brand-gradient-text">new dealers</span>
        </h2>
        <p class="text-xl md:text-2xl text-slate-200 mb-8 max-w-2xl mx-auto leading-relaxed">
          We are actively seeking new dealer partners for our pumps. Please contact us if you’re interested in distribution opportunities. Priority regions include Ontario, the Maritimes, and Manitoba.
        </p>
        <div class="mb-12 space-y-2 text-base md:text-lg text-slate-200">
          <p>Tel: 438 377 6729</p>
          <p>Email: info@kojex.com</p>
        </div>

        <div class="flex flex-col sm:flex-row gap-6 justify-center">
          <Button href={requestQuoteHref} size="lg" class="brand-cta">
            Contact Us
          </Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
