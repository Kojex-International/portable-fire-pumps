---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Section from '../../../components/layout/Section.astro';
import MobilePumpCards from '../../../components/products/MobilePumpCards.astro';
import DesktopPumpCards from '../../../components/products/DesktopPumpCards.astro';
import ProductsCTA from '../../../components/products/ProductsCTA.astro';
import PageHero from '../../../components/layout/PageHero.astro';
import { Gauge } from 'lucide-react';

import { getFirepumps } from '../../../data/firepumps';
import heroBgImg from '@assets/portable-fire-pumps-hero.jpg';
import { getLocaleFromPathname, localizePath } from '@config/site';
import { getNonProductMetadata } from '@utils/nonProductMetadata';
import { buildItemListSchema } from '@utils/seo/schema';
import { SITE } from '@config/site';

const locale = getLocaleFromPathname(Astro.url.pathname);
const productsBaseHref = localizePath('/products', locale);
const requestQuoteHref = localizePath('/contact-us', locale);
const distributorsHref = localizePath('/distributors', locale);
const relayHref = localizePath('/long-distance-relay-pumping', locale);
const firepumps = getFirepumps('fr');

const WATER_COOLED_SLUGS = new Set(['p572s-a', 'p572sw-a', 'fk500-a', 'ff500ar-a']);
const waterCooledPumps = firepumps.filter((pump) => WATER_COOLED_SLUGS.has(pump.slug));
const metadata = getNonProductMetadata({
  pageKey: 'productsWaterCooled',
  locale: 'fr',
  pathname: Astro.url.pathname,
  ogImageSrc: heroBgImg.src,
});
const structuredData = buildItemListSchema({
  listName: 'Pompes incendie portatives refroidies à l’eau',
  canonicalUrl: metadata.canonicalUrl,
  items: waterCooledPumps.map((pump) => ({
    name: pump.title,
    url: new URL(localizePath(`/products/${pump.slug}`, 'fr'), SITE.url).toString(),
    image: new URL(pump.image.src, SITE.url).toString(),
  })),
});
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  canonicalUrl={metadata.canonicalUrl}
  ogImage={metadata.ogImageUrl}
  locale="fr"
  structuredData={structuredData}
>
  <PageHero
    backgroundImage={heroBgImg}
    backgroundAlt="Pompes incendie portatives refroidies à l’eau"
    badge="Refroidies à l’eau"
    badgeIconComponent={Gauge}
    contentClass="max-w-4xl mx-auto text-center min-h-[360px] flex flex-col items-center"
    titleClass="text-[1.9rem] sm:text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-5 leading-tight animate-fadeInUp"
    descriptionClass="text-lg md:text-xl text-slate-200 mb-6 max-w-2xl mx-auto leading-relaxed animate-fadeInUp"
    descriptionStyle="animation-delay: 0.1s"
  >
    <Fragment slot="title">
      <span class="brand-gradient-text-fill">Conçues pour les opérations soutenues</span>
    </Fragment>
    <Fragment slot="description">
      Mieux adaptées au pompage en relais et aux opérations soutenues avec une eau relativement propre.
    </Fragment>
    <ul class="mt-auto mb-14 inline-flex flex-col items-start space-y-2 text-left text-sm text-slate-200 sm:text-base">
      <li class="flex items-start gap-3">
        <span class="mt-2 inline-block h-2 w-2 shrink-0 rounded-full bg-[var(--brand-400)]"></span>
        <span>Refroidissement stable sous charge</span>
      </li>
      <li class="flex items-start gap-3">
        <span class="mt-2 inline-block h-2 w-2 shrink-0 rounded-full bg-[var(--brand-400)]"></span>
        <span>Bien adaptées au pompage en relais</span>
      </li>
      <li class="flex items-start gap-3">
        <span class="mt-2 inline-block h-2 w-2 shrink-0 rounded-full bg-[var(--brand-400)]"></span>
        <span>Meilleur rendement avec une eau plus propre</span>
      </li>
    </ul>
  </PageHero>

  <!-- Main Capabilities -->
  <Section background="white">
    <!-- Accordion View for Mobile/Compact -->
    <div class="lg:hidden mb-12">
      <MobilePumpCards capabilities={waterCooledPumps} detailsBaseHref={productsBaseHref} locale="fr" />
    </div>

    <!-- Grid View for Desktop -->
    <DesktopPumpCards capabilities={waterCooledPumps} detailsBaseHref={productsBaseHref} locale="fr" />

  </Section>

  <ProductsCTA
    locale="fr"
    backgroundImage={heroBgImg}
    contactHref={requestQuoteHref}
    distributorsHref={distributorsHref}
    badge="Cas d’usage lié"
    titleLine1="Vous travaillez sur un"
    titleLine2="relais d’eau?"
    description="Pour les longues lignes de tuyaux, les transferts soutenus et les configurations à plusieurs étages, consultez la page sur le relais d’eau longue distance et comparez les pompes refroidies à l’eau adaptées aux opérations soutenues."
    primaryCta="Voir le relais d’eau longue distance"
    primaryHref={relayHref}
    secondaryCta="Voir les pompes refroidies à l’eau"
    secondaryHref={Astro.url.pathname}
  />
</BaseLayout>
