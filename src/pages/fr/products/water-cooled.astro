---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Section from '../../../components/layout/Section.astro';
import MobilePumpCards from '../../../components/products/MobilePumpCards.astro';
import DesktopPumpCards from '../../../components/products/DesktopPumpCards.astro';
import CategoryIntro from '../../../components/products/CategoryIntro.astro';
import ProductsCTA from '../../../components/products/ProductsCTA.astro';
import PageHero from '../../../components/layout/PageHero.astro';
import { Gauge } from 'lucide-react';

import { getFirepumps } from '../../../data/firepumps';
import heroBgImg from '@assets/portable-fire-pumps-hero.jpg';
import { getLocaleFromPathname, localizePath } from '@config/site';
import { getNonProductMetadata } from '@utils/nonProductMetadata';
import { buildItemListSchema } from '@utils/seo/schema';
import { SITE } from '@config/site';

const locale = getLocaleFromPathname(Astro.url.pathname);
const productsBaseHref = localizePath('/products', locale);
const requestQuoteHref = localizePath('/contact-us', locale);
const distributorsHref = localizePath('/distributors', locale);
const firepumps = getFirepumps('fr');

const WATER_COOLED_SLUGS = new Set(['p572s-a', 'p572sw-a', 'fk500-a', 'ff500ar-a']);
const waterCooledPumps = firepumps.filter((pump) => WATER_COOLED_SLUGS.has(pump.slug));
const categoryIntro = {
  badge: 'Catégorie refroidie à l’eau',
  title: 'Conçues pour les opérations soutenues',
  subtitle: 'Refroidissement stable pour le relais et les usages prolongés.',
  description:
    'Les pompes incendie portatives refroidies à l’eau sont généralement choisies pour les opérations qui exigent un débit stable sur une durée prolongée. Leur système de refroidissement convient bien au pompage en relais, aux transferts longue distance et aux missions soutenues où l’endurance de fonctionnement est déterminante. Elles donnent leur meilleur rendement avec une eau relativement propre afin de préserver l’efficacité du circuit de refroidissement.',
  advantages: [
    'Bon maintien des performances sous charge continue',
    'Adaptées au pompage en relais et aux transferts prolongés',
    'Demandent une eau relativement propre pour le refroidissement',
  ],
};
const metadata = getNonProductMetadata({
  pageKey: 'productsWaterCooled',
  locale: 'fr',
  pathname: Astro.url.pathname,
  ogImageSrc: heroBgImg.src,
});
const structuredData = buildItemListSchema({
  listName: 'Pompes incendie portatives refroidies à l’eau',
  canonicalUrl: metadata.canonicalUrl,
  items: waterCooledPumps.map((pump) => ({
    name: pump.title,
    url: new URL(localizePath(`/products/${pump.slug}`, 'fr'), SITE.url).toString(),
    image: new URL(pump.image.src, SITE.url).toString(),
  })),
});
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  canonicalUrl={metadata.canonicalUrl}
  ogImage={metadata.ogImageUrl}
  locale="fr"
  structuredData={structuredData}
>
  <PageHero
    backgroundImage={heroBgImg}
    backgroundAlt="Pompes incendie portatives refroidies à l’eau"
    badge="Produits"
    badgeIconComponent={Gauge}
    titleClass="text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight animate-fadeInUp"
    descriptionClass="text-xl md:text-2xl text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed animate-fadeInUp"
    descriptionStyle="animation-delay: 0.1s"
  >
    <Fragment slot="title">
      <span class="brand-gradient-text-fill">
        <span class="sm:whitespace-nowrap">Pompes incendie portatives</span><br />
        Refroidies à l’eau
      </span>
    </Fragment>
    <Fragment slot="description">
      Refroidissement maîtrisé pour les relais, les transferts longue distance et les opérations prolongées.
    </Fragment>
  </PageHero>

  <!-- Main Capabilities -->
  <Section background="white">
    <CategoryIntro {...categoryIntro} />

    <!-- Accordion View for Mobile/Compact -->
    <div class="lg:hidden mb-12">
      <MobilePumpCards capabilities={waterCooledPumps} detailsBaseHref={productsBaseHref} locale="fr" />
    </div>

    <!-- Grid View for Desktop -->
    <DesktopPumpCards capabilities={waterCooledPumps} detailsBaseHref={productsBaseHref} locale="fr" />
  </Section>

  <ProductsCTA
    locale="fr"
    backgroundImage={heroBgImg}
    contactHref={requestQuoteHref}
    distributorsHref={distributorsHref}
  />
</BaseLayout>
