---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Section from '../../../components/layout/Section.astro';
import MobilePumpCards from '../../../components/products/MobilePumpCards.astro';
import DesktopPumpCards from '../../../components/products/DesktopPumpCards.astro';
import CategoryIntro from '../../../components/products/CategoryIntro.astro';
import ProductsCTA from '../../../components/products/ProductsCTA.astro';
import PageHero from '../../../components/layout/PageHero.astro';
import { Gauge } from 'lucide-react';

import { getFirepumps } from '../../../data/firepumps';
import heroBgImg from '@assets/portable-fire-pumps-hero.jpg';
import { getLocaleFromPathname, localizePath } from '@config/site';
import { getNonProductMetadata } from '@utils/nonProductMetadata';
import { buildItemListSchema } from '@utils/seo/schema';
import { SITE } from '@config/site';

const locale = getLocaleFromPathname(Astro.url.pathname);
const productsBaseHref = localizePath('/products', locale);
const requestQuoteHref = localizePath('/contact-us', locale);
const distributorsHref = localizePath('/distributors', locale);
const firepumps = getFirepumps('fr');

const AIR_COOLED_SLUGS = new Set(['ft510-a', 'ft300-400-a', 'tf516mh-ab']);
const airCooledPumps = firepumps.filter((pump) => AIR_COOLED_SLUGS.has(pump.slug));
const categoryIntro = {
  badge: 'Catégorie refroidie à l’air',
  title: 'Conçues pour les prises d’eau variables',
  subtitle: 'Refroidissement moteur autonome pour des prises d’eau plus variables.',
  description:
    'Les pompes incendie portatives refroidies à l’air conviennent bien lorsque la qualité de l’eau aspirée est variable ou que des débris peuvent compliquer l’exploitation. Comme le refroidissement moteur ne dépend pas de l’eau pompée, elles offrent une mise en oeuvre plus simple sur le terrain et une exploitation plus sereine dans des conditions moins idéales. Elles sont souvent retenues pour les interventions rapides, les accès éloignés et les configurations où la simplicité prime.',
  advantages: [
    'Refroidissement moteur indépendant de l’eau pompée',
    'Adaptées aux sources plus chargées ou irrégulières',
    'Déploiement simple pour les opérations terrain',
  ],
};
const metadata = getNonProductMetadata({
  pageKey: 'productsAirCooled',
  locale: 'fr',
  pathname: Astro.url.pathname,
  ogImageSrc: heroBgImg.src,
});
const structuredData = buildItemListSchema({
  listName: 'Pompes incendie portatives refroidies à l’air',
  canonicalUrl: metadata.canonicalUrl,
  items: airCooledPumps.map((pump) => ({
    name: pump.title,
    url: new URL(localizePath(`/products/${pump.slug}`, 'fr'), SITE.url).toString(),
    image: new URL(pump.image.src, SITE.url).toString(),
  })),
});
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  canonicalUrl={metadata.canonicalUrl}
  ogImage={metadata.ogImageUrl}
  locale="fr"
  structuredData={structuredData}
>
  <PageHero
    backgroundImage={heroBgImg}
    backgroundAlt="Pompes incendie portatives refroidies à l’air"
    badge="Produits"
    badgeIconComponent={Gauge}
    titleClass="text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight animate-fadeInUp"
    descriptionClass="text-xl md:text-2xl text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed animate-fadeInUp"
    descriptionStyle="animation-delay: 0.1s"
  >
    <Fragment slot="title">
      <span class="brand-gradient-text-fill">
        <span class="sm:whitespace-nowrap">Pompes incendie portatives</span><br />
        Refroidies à l’air
      </span>
    </Fragment>
    <Fragment slot="description">
      Refroidissement autonome pour une exploitation fiable lorsque la qualité d’eau est moins prévisible.
    </Fragment>
  </PageHero>

  <!-- Main Capabilities -->
  <Section background="white">
    <CategoryIntro {...categoryIntro} />

    <!-- Accordion View for Mobile/Compact -->
    <div class="lg:hidden mb-12">
      <MobilePumpCards capabilities={airCooledPumps} detailsBaseHref={productsBaseHref} locale="fr" />
    </div>

    <!-- Grid View for Desktop -->
    <DesktopPumpCards capabilities={airCooledPumps} detailsBaseHref={productsBaseHref} locale="fr" />
  </Section>

  <ProductsCTA
    locale="fr"
    backgroundImage={heroBgImg}
    contactHref={requestQuoteHref}
    distributorsHref={distributorsHref}
  />
</BaseLayout>
