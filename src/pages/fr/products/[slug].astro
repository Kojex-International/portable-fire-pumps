---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProductDetailPageContent from '../../../components/products/ProductDetailPageContent.astro';
import { getFirepumps, type Firepump } from '../../../data/firepumps';
import { SITE } from '../../../config/site';
import { getProductMetadata } from '../../../utils/productMetadata';
import { buildProductBreadcrumbSchema, buildProductSchema } from '../../../utils/seo/schema';

export async function getStaticPaths() {
  const frFirepumps = getFirepumps('fr');
  return frFirepumps.flatMap((pump) => {
    const slugs = [pump.slug, ...(pump.aliases ?? [])];
    return slugs.map((slug) => ({
      params: { slug },
      props: { pump, requestedSlug: slug },
    }));
  });
}

const { pump, requestedSlug } = Astro.props as { pump: Firepump; requestedSlug: string };

if (requestedSlug !== pump.slug) {
  return Astro.redirect(`/fr/products/${pump.slug}/`);
}

const metadata = getProductMetadata({
  pump,
  locale: 'fr',
  siteUrl: SITE.url,
  pathname: Astro.url.pathname,
});
const structuredData = [
  buildProductSchema({
    pump,
    locale: 'fr',
    canonicalUrl: metadata.canonicalUrl,
    imageUrl: metadata.ogImageUrl,
  }),
  buildProductBreadcrumbSchema({
    pump,
    locale: 'fr',
    canonicalUrl: metadata.canonicalUrl,
  }),
];
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  canonicalUrl={metadata.canonicalUrl}
  ogImage={metadata.ogImageUrl}
  locale="fr"
  structuredData={structuredData}
>
  <ProductDetailPageContent pump={pump} locale="fr" />
</BaseLayout>
