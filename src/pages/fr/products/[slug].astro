---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProductDetailPageContent from '../../../components/products/ProductDetailPageContent.astro';
import { getFirepumps, type Firepump } from '../../../data/firepumps';

export async function getStaticPaths() {
  const frFirepumps = getFirepumps('fr');
  return frFirepumps.flatMap((pump) => {
    const slugs = [pump.slug, ...(pump.aliases ?? [])];
    return slugs.map((slug) => ({
      params: { slug },
      props: { pump },
    }));
  });
}

const { pump } = Astro.props as { pump: Firepump };
---

<BaseLayout title={`${pump.title} - Portable Fire Pumps`}>
  <ProductDetailPageContent pump={pump} locale="fr" />
</BaseLayout>
