---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/layout/PageHero.astro';
import Section from '../../components/layout/Section.astro';
import SectionHeader from '../../components/layout/SectionHeading.astro';
import ProductsCTA from '../../components/products/ProductsCTA.astro';
import ProductRelatedPumps from '../../components/products/ProductRelatedPumps.astro';
import { Check, Gauge, Workflow } from 'lucide-react';

import heroBgImg from '@assets/product-features-hero.webp';
import relayDiagramImg from '@assets/portable-fire-pump-relay-pumping-diagram.webp';
import shibauraLogoMark from '@assets/shibaura-logo-mark.svg?url';
import { getNonProductMetadata } from '@utils/nonProductMetadata';
import { localizePath } from '@config/site';
import { getFirepumps } from '../../data/firepumps';

const metadata = getNonProductMetadata({
  pageKey: 'relayPumping',
  locale: 'fr',
  pathname: Astro.url.pathname,
  ogImageSrc: heroBgImg.src,
});

const waterCooledHref = localizePath('/products/water-cooled', 'fr');
const productsBaseHref = localizePath('/products', 'fr');
const ff500Href = localizePath('/products/ff500ar-a', 'fr');
const p572Href = localizePath('/products/p572s-a', 'fr');
const fk500Href = localizePath('/products/fk500-a', 'fr');
const contactHref = localizePath('/contact-us', 'fr');
const distributorsHref = localizePath('/distributors', 'fr');
const recommendedPumps = getFirepumps('fr').filter((pump) =>
  ['ff500ar-a', 'p572s-a', 'fk500-a'].includes(pump.slug)
);
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  canonicalUrl={metadata.canonicalUrl}
  ogImage={metadata.ogImageUrl}
  locale="fr"
  alternates={{
    en: 'https://www.portable-fire-pumps.com/en/long-distance-relay-pumping/',
    fr: 'https://www.portable-fire-pumps.com/fr/long-distance-relay-pumping/',
    xDefault: 'https://www.portable-fire-pumps.com/en/long-distance-relay-pumping/',
  }}
>
  <PageHero
    backgroundImage={heroBgImg}
    backgroundAlt="Pompage en relais sur longue distance avec pompes à incendie portatives"
    badge="Cas d’usage"
    badgeIconComponent={Workflow}
    titleClass="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight animate-fadeInUp"
    descriptionClass="text-xl md:text-2xl text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed animate-fadeInUp"
    descriptionStyle="animation-delay: 0.1s"
  >
    <Fragment slot="title">
      <span class="brand-gradient-text-fill">Relais d’eau sur longue distance</span>
    </Fragment>
    <Fragment slot="description">
      Les pompes à incendie portatives utilisées en relais permettent d’acheminer l’eau sur de longues distances lorsque la source est éloignée de la zone d’intervention.
    </Fragment>
  </PageHero>

  <Section background="white">
    <SectionHeader
      badge="Contexte opérationnel"
      badgeIconComponent={Gauge}
      title="Quand le pompage"
      highlight="en relais s’impose"
      description="Le pompage en relais devient nécessaire lorsque la distance à couvrir dépasse ce qu’une seule pompe peut alimenter efficacement. Chaque étape maintient le débit et la pression vers la zone d’intervention."
      class="mb-12"
    />

    <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
      <div class="space-y-6 text-lg leading-relaxed text-slate-700">
        <p>
          Cette configuration est particulièrement utile pour les feux de forêt, les points de prise d’eau éloignés, l’alimentation de sites isolés et les transferts prolongés. Le relais limite les pertes de charge dans les longues lignes de tuyaux et aide à maintenir une alimentation efficace au dernier point de pompage.
        </p>
        <ul class="space-y-3 text-base">
          <li class="flex items-start gap-3">
            <Check className="mt-1 h-5 w-5 shrink-0 text-green-600" />
            <span>Permet l’acheminement de l’eau sur de longues distances.</span>
          </li>
          <li class="flex items-start gap-3">
            <Check className="mt-1 h-5 w-5 shrink-0 text-green-600" />
            <span>Convient aux sources éloignées lorsque l’alimentation directe n’est pas possible.</span>
          </li>
          <li class="flex items-start gap-3">
            <Check className="mt-1 h-5 w-5 shrink-0 text-green-600" />
            <span>Demande une pompe stable sous charge, facile à amorcer et adaptée à une utilisation soutenue.</span>
          </li>
        </ul>
      </div>

      <figure class="lg:pt-1">
        <div class="overflow-hidden rounded-xl border border-slate-200 bg-white">
          <img src={relayDiagramImg.src} alt="Schéma de pompage en relais avec plusieurs étages de pompe" class="w-full block" />
        </div>
        <figcaption class="mt-4 text-sm leading-relaxed text-slate-600">
          Les configurations de pompage en relais privilégient souvent les pompes refroidies à l’eau pour les transferts soutenus lorsque l’eau disponible est relativement propre.
        </figcaption>
      </figure>
    </div>
  </Section>

  <Section background="gray">
    <SectionHeader
      badge="Pompes recommandées"
      badgeIconComponent={Gauge}
      title="Modèles à examiner"
      highlight="pour le pompage en relais"
      description="Ces modèles refroidis à l’eau constituent un bon point de départ pour les relais soutenus, l’acheminement sur longue distance et les transferts d’eau continus."
      class="mb-10"
    />

    <ProductRelatedPumps
      relatedPumps={recommendedPumps}
      productsHref={productsBaseHref}
      titleLeading="Pompes"
      titleHighlight="recommandées"
      shibauraLogoMark={shibauraLogoMark}
      locale="fr"
      showHeading={false}
      embedded={true}
    />
  </Section>

  <ProductsCTA
    locale="fr"
    backgroundImage={heroBgImg}
    contactHref={contactHref}
    distributorsHref={distributorsHref}
    badge="Catégorie adaptée"
    titleLine1="Commencer par"
    titleLine2="les pompes refroidies à l’eau"
    description="Les pompes à incendie portatives refroidies à l’eau conviennent généralement mieux aux relais prolongés et aux transferts d’eau soutenus lorsque l’eau disponible est relativement propre."
    primaryCta="Voir les pompes refroidies à l’eau"
    primaryHref={waterCooledHref}
    secondaryCta="Trouver un distributeur"
    secondaryHref={distributorsHref}
  />
</BaseLayout>
