---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/ui/Section.astro';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';
import FirepumpAccordion from '../../components/react/FirepumpAccordion';
import { Image } from 'astro:assets';
import ImageReveal from '../../components/react/ImageReveal';

import shibauraLogoMark from '@assets/shibaura-logo-mark.svg?url';
import checkIcon from '@assets/icons/check.svg?url';
import warehouseImg from '@assets/photo-1566576721346-d4a3b4eaeb55.jpg';
import manufacturingImg from '@assets/photo-1581091226825-a6a2a5aee158.jpg';
import transportationImg from '@assets/photo-1601584115197-04ecc0da31d7.jpg';
import supplyChainImg from '@assets/photo-1460925895917-afdab827c52f.jpg';
import valueAddedServicesImg from '@assets/photo-1558618666-fcd25c85cd64.jpg';
import technologyIntegrationImg from '@assets/photo-1558494949-ef010cbdcc31.jpg';
import heroBgImg from '@assets/photo-1586528116311-ad8dd3c8310d.jpg';
import ctaBgImg from '@assets/photo-1553413077-190dd305871c.jpg';

const shibauraLogoIcon = shibauraLogoMark;

const firepumps = [
  {
    title: 'Warehousing & Storage',
    subtitle: 'subtitle',
    description: 'State-of-the-art warehousing facilities equipped with advanced inventory management systems, climate control, and 24/7 security.',
    icon: shibauraLogoIcon,
    image: warehouseImg,
    features: [
      { label: 'Climate-controlled storage', icon: checkIcon },
      { label: 'Automated inventory tracking', icon: checkIcon },
      { label: 'Cross-docking capabilities', icon: checkIcon },
      { label: 'Hazmat certified facilities', icon: checkIcon },
      { label: 'Real-time stock visibility', icon: checkIcon }
    ]
  },
  {
    title: 'Manufacturing Services',
    subtitle: 'subtitle',
    description: 'ISO 9001 certified manufacturing with precision engineering, quality control, and flexible production capabilities.',
    icon: shibauraLogoIcon,
    image: manufacturingImg,
    features: [
      { label: 'CNC machining & fabrication', icon: checkIcon },
      { label: 'Assembly & kitting', icon: checkIcon },
      { label: 'Quality inspection', icon: checkIcon },
      { label: 'Prototype development', icon: checkIcon },
      { label: 'Custom tooling & fixtures', icon: checkIcon }
    ]
  },
  {
    title: 'Transportation & Distribution',
    subtitle: 'subtitle',
    description: 'Comprehensive multi-modal transportation network ensuring efficient, reliable delivery across all regions.',
    icon: shibauraLogoIcon,
    image: transportationImg,
    features: [
      { label: 'Ground transportation (LTL/FTL)', icon: checkIcon },
      { label: 'Air freight services', icon: checkIcon },
      { label: 'Ocean freight', icon: checkIcon },
      { label: 'Last-mile delivery', icon: checkIcon },
      { label: 'Route optimization', icon: checkIcon }
    ]
  },
  {
    title: 'Supply Chain Management',
    subtitle: 'subtitle',
    description: 'End-to-end supply chain solutions with advanced analytics, forecasting, and optimization capabilities.',
    icon: shibauraLogoIcon,
    image: supplyChainImg,
    features: [
      { label: 'Demand forecasting', icon: checkIcon },
      { label: 'Inventory optimization', icon: checkIcon },
      { label: 'Network design', icon: checkIcon },
      { label: 'Risk management', icon: checkIcon },
      { label: 'Performance analytics', icon: checkIcon }
    ]
  },
  {
    title: 'Value-Added Services',
    subtitle: 'subtitle',
    description: 'Comprehensive value-added services to enhance your product offerings and streamline operations.',
    icon: shibauraLogoIcon,
    image: valueAddedServicesImg,
    features: [
      { label: 'Product labeling & packaging', icon: checkIcon },
      { label: 'Returns management', icon: checkIcon },
      { label: 'Quality inspection', icon: checkIcon },
      { label: 'Kit assembly', icon: checkIcon },
      { label: 'Custom packaging design', icon: checkIcon }
    ]
  },
  {
    title: 'Technology & Integration',
    subtitle: 'subtitle',
    description: 'Advanced technology platform with seamless integration capabilities for complete visibility and control.',
    icon: shibauraLogoIcon,
    image: technologyIntegrationImg,
    features: [
      { label: 'WMS & TMS integration', icon: checkIcon },
      { label: 'EDI & API connectivity', icon: checkIcon },
      { label: 'Real-time tracking', icon: checkIcon },
      { label: 'Automated reporting', icon: checkIcon },
      { label: 'Mobile applications', icon: checkIcon }
    ]
  }
];
---

<BaseLayout title="Products - Portable Fire Pumps">
  <!-- Hero Section -->
  <section class="relative h-[70vh] min-h-[500px] flex items-center overflow-hidden">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0">
      <Image 
        src={heroBgImg}
        alt="Modern logistics and manufacturing capabilities"
        class="w-full h-full object-cover"
        width={2070}
        height={1380}
      />
      <div class="absolute inset-0 bg-linear-to-r from-slate-900/95 via-slate-900/80 to-slate-900/50"></div>
    </div>

    <!-- Content -->
    <div class="container mx-auto relative z-10 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center px-4 py-2 mb-6 bg-linear-to-r from-blue-600 to-teal-600 text-white text-sm font-semibold rounded-full shadow-lg">
          <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd" />
          </svg>
          Comprehensive Solutions
        </div>
        
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight">
          <span class="text-transparent bg-clip-text bg-linear-to-r from-blue-400 via-teal-400 to-blue-400">
            Products
          </span>
      </h1>
        
        <p class="text-xl md:text-2xl text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed">
        Comprehensive logistics and manufacturing solutions designed to optimize your operations 
        and drive sustainable growth.
      </p>
      </div>
    </div>
  </section>

  <!-- Main Capabilities -->
  <Section background="gray">
    <!-- Accordion View for Mobile/Compact -->
    <div class="lg:hidden mb-12">
      <FirepumpAccordion capabilities={firepumps} client:load />
    </div>
    
    <!-- Grid View for Desktop -->
    <div class="hidden lg:block space-y-24">
      {firepumps.map((capability, index) => (
        <div class={`grid grid-cols-1 lg:grid-cols-2 gap-12 items-center ${index % 2 === 1 ? 'lg:grid-flow-dense' : ''}`}>
          <div class={`${index % 2 === 1 ? 'lg:col-start-2' : ''} animate-fadeInUp`}>
            <div class="flex items-center gap-4 mb-4">
              <div class="flex items-center justify-center w-[3.125rem] h-[3.125rem] rounded-xl brand-gradient-bg text-white shadow-lg">
                <img src={capability.icon} alt="" class="w-9 h-9" aria-hidden="true" />
              </div>
              <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
                {capability.title}
              </h2>
            </div>
            <h3 class="text-lg md:text-xl font-semibold text-gray-700 mb-2">
              {capability.subtitle}
            </h3>
            <p class="text-lg text-gray-600 mb-6 leading-relaxed">
              {capability.description}
            </p>
            <ul class="space-y-3">
              {capability.features.map((feature, featureIndex) => (
                <li class="flex items-center space-x-3">
                  <div class="flex items-center justify-center shrink-0 w-5 h-5">
                    <img
                      src={feature.icon}
                      alt=""
                      class="block object-contain w-5 h-5"
                      aria-hidden="true"
                    />
                  </div>
                  <span class={`text-gray-700 whitespace-pre-line ${featureIndex === 0 ? 'font-semibold' : ''}`}>
                    {feature.label}
                  </span>
                </li>
              ))}
            </ul>
          </div>
          <div class={`${index % 2 === 1 ? 'lg:col-start-1 lg:row-start-1' : ''}`}>
            <ImageReveal client:load delay={index * 0.1}>
              <div class="relative aspect-4/3 group overflow-hidden rounded-2xl shadow-2xl">
                <Image 
                  src={capability.image}
                  alt={capability.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  width={1200}
                  height={800}
                />
                <div class="absolute inset-0 bg-black/2"></div>
                <div class="absolute inset-0 bg-linear-to-t from-slate-900/40 via-slate-900/10 to-transparent"></div>
                <div class="absolute bottom-0 left-0 right-0 p-8 text-white drop-shadow-lg">
                  <h3 class="text-2xl font-bold mb-2">{capability.title}</h3>
                  <p class="text-gray-200">{capability.description}</p>
                </div>
              </div>
            </ImageReveal>
          </div>
        </div>
      ))}
    </div>
  </Section>

  <!-- Process Section -->
  <Section background="white">
    <div class="text-center mb-16">
      <div class="inline-block px-4 py-2 mb-4 bg-blue-100 text-blue-800 text-sm font-semibold rounded-full">
        Our Approach
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        Our <span class="text-transparent bg-clip-text bg-linear-to-r from-blue-600 to-teal-600">Process</span>
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
        A streamlined approach to deliver exceptional results every time.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {[
        { 
          step: '01', 
          title: 'Consultation', 
          description: 'Understand your unique requirements and challenges',
          icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>`
        },
        { 
          step: '02', 
          title: 'Planning', 
          description: 'Design customized solutions tailored to your needs',
          icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
          </svg>`
        },
        { 
          step: '03', 
          title: 'Implementation', 
          description: 'Execute with precision and attention to detail',
          icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>`
        },
        { 
          step: '04', 
          title: 'Optimization', 
          description: 'Continuous improvement and performance monitoring',
          icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>`
        }
      ].map((process, index) => (
        <Card hover class="text-center animate-fadeInUp group" style={`animation-delay: ${index * 0.1}s`}>
          <div class="flex items-center justify-center w-16 h-16 mx-auto mb-4 rounded-xl bg-linear-to-br from-blue-500 to-teal-500 text-white shadow-lg group-hover:scale-110 transition-transform">
            <div set:html={process.icon} />
          </div>
          <div class="text-3xl font-bold text-transparent bg-clip-text bg-linear-to-r from-blue-600 to-teal-600 mb-2">{process.step}</div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">{process.title}</h3>
          <p class="text-gray-600 leading-relaxed">{process.description}</p>
        </Card>
      ))}
    </div>
  </Section>

  <!-- CTA Section -->
  <section class="relative py-32 overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <Image 
        src={ctaBgImg}
        alt="Modern warehouse operations"
        class="w-full h-full object-cover"
        width={2070}
        height={1380}
      />
      <div class="absolute inset-0 cta-overlay-gradient"></div>
    </div>

    <!-- Content -->
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-4xl mx-auto text-center text-white">
        <div class="inline-block px-4 py-2 mb-6 bg-white/10 backdrop-blur-sm text-white text-sm font-semibold rounded-full">
          Get Started Today
        </div>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
          Ready to Optimize with <span class="brand-gradient-text">Portable Fire Pumps</span>?
      </h2>
        <p class="text-xl md:text-2xl text-slate-200 mb-12 max-w-2xl mx-auto leading-relaxed">
          Let's discuss how our capabilities can transform your business and accelerate your growth.
      </p>
        
        <div class="flex flex-col sm:flex-row gap-6 justify-center">
          <Button href="/fr/request-a-quote" size="lg" class="brand-cta">
            Request a Quote
          </Button>
          <Button href="/fr/distributors" size="lg" variant="outline" class="border-2! border-white! text-white! hover:bg-white/10! shadow-2xl!">
            View Distributors
          </Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
