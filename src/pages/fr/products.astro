---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/ui/Section.astro';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import MobilePumpCards from '../../components/react/MobilePumpCards';
import { Image } from 'astro:assets';
import ImageReveal from '../../components/react/ImageReveal';
import { Gauge, Flame } from 'lucide-react';

import { getFirepumps } from '../../data/firepumps';
import heroBgImg from '@assets/portable-fire-pumps-hero.jpg';
import logoMark from '@assets/shibaura-logo-mark.svg';
import feature2StrokeEngineImg from '@assets/features/2StrokeEngine.png';
import featureCentrifugalPumpImg from '@assets/features/CentrifugalPump.png';
import featureVacuumPumpImg from '@assets/features/VacuumPump.png';
import featureDischargeValveImg from '@assets/features/DischargeValve.png';
import featureMonitoringSystemImg from '@assets/features/MonitoringSystem.png';
import featureImpellerImg from '@assets/features/Impeller.png';
import featureChokeSystemImg from '@assets/features/ChokeSystem.png';
import featureFuelFeedingSystemImg from '@assets/features/FuelFeedingSystem.png';
import featureAutoCoolantImg from '@assets/features/AutoCoolant.png';
import { getLocaleFromPathname, localizePath } from '@config/site';

const locale = getLocaleFromPathname(Astro.url.pathname);
const productsBaseHref = localizePath('/products', locale);
const requestQuoteHref = localizePath('/contact-us', locale);
const distributorsHref = localizePath('/distributors', locale);
const firepumps = getFirepumps('fr');

const productFeatures = [
  {
    title: 'Moteur à essence 2 temps',
    description:
      'Moteur Shibaura original, compact, léger et puissant, conçu pour les pompes à incendie. Le design 2 temps à haut régime offre de solides performances et une longue durée de service.',
    image: feature2StrokeEngineImg
  },
  {
    title: 'Pompe centrifuge',
    description:
      'Le moteur Shibaura original et la pompe centrifuge à un étage sont intégrés dans une unité compacte, pour plus d’efficacité et un excellent débit à longue distance.',
    image: featureCentrifugalPumpImg
  },
  {
    title: 'Vanne de refoulement rapide',
    description:
      'La vanne à levier permet un contrôle rapide et précis du refoulement, avec rotation à 180° pour améliorer la capacité d’extinction.',
    image: featureDischargeValveImg
  },
  {
    title: 'Pompe à vide',
    description:
      'Pompe à vide Shibaura originale, légère et compacte, qui évacue rapidement l’air dans la ligne d’aspiration pour un amorçage rapide.',
    image: featureVacuumPumpImg
  },
  {
    title: "Système d’alerte et de surveillance",
    description:
      'Des voyants d’alerte signalent les anomalies (niveau d’huile bas, etc.) et le moteur se coupe automatiquement en situation d’urgence.',
    image: featureMonitoringSystemImg
  },
  {
    title: 'Turbine (impeller)',
    description:
      'Turbine Shibaura conçue pour un fort volume d’eau et le refoulement à longue distance. Traitement de surface spécial pour limiter la corrosion.',
    image: featureImpellerImg
  },
  {
    title: 'Circulation automatique du liquide de refroidissement',
    description:
      'La circulation en boucle fermée réduit la consommation d’eau en faible approvisionnement et limite les surfaces glissantes pendant les opérations.',
    image: featureAutoCoolantImg
  },
  {
    title: "Système d’alimentation en carburant avancé",
    description:
      'Alimentation séparée type automobile pour un mélange essence/huile optimal. Le capteur de niveau d’huile facilite les contrôles rapides.',
    image: featureFuelFeedingSystemImg
  },
  {
    title: 'Système de starter automatique',
    description:
      'Les capteurs de température d’air et moteur ajustent automatiquement le starter pour un démarrage facile, une montée en température rapide et un fonctionnement immédiat.',
    image: featureChokeSystemImg
  }
];

const sortedProductFeatures = [...productFeatures].sort(
  (a, b) => Number(Boolean(b.image)) - Number(Boolean(a.image))
);
const hasMoreProductFeatures = sortedProductFeatures.length > 3;
---

<BaseLayout title="Produits - Portable Fire Pumps">
  <!-- Hero Section -->
  <section class="relative h-[70vh] min-h-[500px] flex items-center overflow-hidden">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0 bg-slate-900">
      <Image 
        src={heroBgImg}
        alt="Pompes à incendie portatives"
        class="w-full h-full object-cover"
        loading="eager"
        decoding="async"
        fetchpriority="high"
        width={2070}
        height={1380}
      />
      <div class="absolute inset-0 bg-linear-to-r from-slate-900/95 via-slate-900/80 to-slate-900/50"></div>
    </div>

    <!-- Content -->
    <div class="container mx-auto relative z-10 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center px-4 py-2 mb-6 bg-white/10 backdrop-blur-[6px] text-white text-sm leading-none font-semibold rounded-full shadow-lg border border-white/15">
          <Gauge className="w-4 h-4 mr-2" />
          Produits
        </div>
        
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight animate-fadeInUp">
          <span class="text-[var(--brand-400)]">
            Pompes à incendie portatives
          </span>
      </h1>
        
        <p class="text-xl md:text-2xl text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed animate-fadeInUp" style="animation-delay: 0.1s">
        Conçues pour une performance fiable et un déploiement rapide en intervention.
      </p>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </section>

  <!-- Product Features -->
  <Section background="white" id="product-features">
    <SectionHeader
      badge="Caractéristiques"
      badgeIconComponent={Gauge}
      title="Performance et conception"
      highlight="des pompes"
      description="Conçues pour une réponse rapide, un amorçage fiable et un usage terrain exigeant."
      class="mb-12"
    />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {sortedProductFeatures.slice(0, 3).map((feature, index) => (
        <ImageReveal client:load delay={index * 0.05} className="overflow-visible rounded-xl">
          <Card hover class="h-full overflow-hidden border-slate-200/60">
            {feature.image ? (
              <div class="mb-4 flex justify-center">
                <div class="inline-block overflow-hidden rounded-lg bg-white">
                  <Image
                    src={feature.image}
                    alt={feature.title}
                    class="block h-40 w-auto object-contain"
                    width={800}
                    height={600}
                  />
                </div>
              </div>
            ) : null}
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-gray-900 mb-2">{feature.title}</h3>
                <p class="text-sm text-gray-600 leading-relaxed">{feature.description}</p>
              </div>
            </div>
          </Card>
        </ImageReveal>
      ))}
    </div>

    {hasMoreProductFeatures ? (
      <div class="mt-10">
        <div
          id="product-features-more"
          class="overflow-hidden max-h-0 opacity-0 transition-[max-height,opacity] duration-500 ease-in-out"
        >
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {sortedProductFeatures.slice(3).map((feature, index) => (
              <ImageReveal client:load delay={0.05 + index * 0.05} className="overflow-visible rounded-xl">
                <Card hover class="h-full overflow-hidden border-slate-200/60">
                  {feature.image ? (
                    <div class="mb-4 flex justify-center">
                      <div class="inline-block overflow-hidden rounded-lg bg-white">
                        <Image
                          src={feature.image}
                          alt={feature.title}
                          class="block h-40 w-auto object-contain"
                          width={800}
                          height={600}
                        />
                      </div>
                    </div>
                  ) : null}
                  <div class="flex items-start gap-4">
                    <div class="w-11 h-11 rounded-xl flex items-center justify-center shrink-0">
                      <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                    </div>
                    <div>
                      <h3 class="text-lg font-bold text-gray-900 mb-2">{feature.title}</h3>
                      <p class="text-sm text-gray-600 leading-relaxed">{feature.description}</p>
                    </div>
                  </div>
                </Card>
              </ImageReveal>
            ))}
          </div>
        </div>

        <div class="mt-8 flex justify-center">
          <button
            type="button"
            class="brand-cta flex items-center justify-center gap-2 px-5 py-3 text-sm rounded-full"
            data-feature-toggle
            aria-expanded="false"
            aria-controls="product-features-more"
          >
            Afficher toutes les caractéristiques
            <svg class="w-4 h-4 transition-transform duration-300" data-feature-toggle-icon fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
        </div>
      </div>
    ) : null}
  </Section>

  <!-- Main Capabilities -->
  <Section background="white">
    <!-- Accordion View for Mobile/Compact -->
    <div class="lg:hidden mb-12">
      <MobilePumpCards capabilities={firepumps} detailsBaseHref={productsBaseHref} locale="fr" />
    </div>
    
    <!-- Grid View for Desktop -->
    <div class="hidden lg:block space-y-24">
      {firepumps.map((capability, index) => (
        <div
          class={`group grid grid-cols-1 lg:grid-cols-2 gap-12 items-center cursor-pointer transition-all duration-300 hover:-translate-y-1 ${index % 2 === 1 ? 'lg:grid-flow-dense' : ''}`}
          role="link"
          tabindex="0"
          aria-label={`Voir les détails pour ${capability.title}`}
          onclick={`if (event.target.closest('a,button')) return; window.location.href='${productsBaseHref}/${capability.slug}';`}
          onkeydown={`if ((event.key === 'Enter' || event.key === ' ') && !event.target.closest('a,button')) { event.preventDefault(); window.location.href='${productsBaseHref}/${capability.slug}'; }`}
        >
          <div class={`${index % 2 === 1 ? 'lg:col-start-2' : ''} animate-fadeInUp`}>
            <div class="flex items-center gap-4 mb-4">
              <div class="flex items-center justify-center w-[52px] h-[52px] rounded-lg group-hover:scale-110 transition-transform">
                <span
                  aria-hidden="true"
                  class="w-[52px] h-[52px] brand-gradient-bg"
                  style={`-webkit-mask-image: url(${logoMark.src}); mask-image: url(${logoMark.src}); -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat; -webkit-mask-position: center; mask-position: center; -webkit-mask-size: contain; mask-size: contain;`}
                ></span>
              </div>
              <h2
                class="text-3xl md:text-4xl font-bold text-gray-900 brand-gradient-hover"
                data-text={capability.title}
              >
                {capability.title}
              </h2>
            </div>
            <h3 class="text-lg md:text-xl font-semibold text-gray-700 mb-2">
              {capability.subtitle}
            </h3>
            <p class="text-lg text-gray-600 mb-6 leading-relaxed">
              {capability.description}
            </p>
            <ul class="space-y-3">
              {capability.features.map((feature, featureIndex) => (
                <li class="flex items-center space-x-3">
                  <div class="flex items-center justify-center shrink-0 w-5 h-5">
                    <img
                      src={feature.icon}
                      alt=""
                      class="block object-contain w-5 h-5"
                      aria-hidden="true"
                    />
                  </div>
                  <span class={`text-gray-700 whitespace-pre-line ${featureIndex === 0 ? 'font-semibold' : ''}`}>
                    {feature.label}
                  </span>
                </li>
              ))}
            </ul>
          </div>
          <div class={`${index % 2 === 1 ? 'lg:col-start-1 lg:row-start-1' : ''}`}>
            <ImageReveal client:load delay={index * 0.1}>
              <div class="relative aspect-4/3 group overflow-hidden rounded-2xl shadow-xl bg-white transition-shadow duration-300 group-hover:shadow-2xl">
                <Image 
                  src={capability.image}
                  alt={capability.title}
                  class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-700"
                  width={1200}
                  height={800}
                />
              </div>
            </ImageReveal>
          </div>
        </div>
      ))}
    </div>
  </Section>

  <!-- Process Section -->
  <script>
    const featureToggle = document.querySelector('[data-feature-toggle]');
    const featureToggleIcon = document.querySelector('[data-feature-toggle-icon]');
    const featureMore = document.querySelector('#product-features-more');

    if (featureToggle && featureMore) {
      featureToggle.addEventListener('click', () => {
        const isOpen = featureMore.classList.contains('is-open');
        featureMore.classList.toggle('is-open');
        featureMore.classList.toggle('max-h-0', isOpen);
        featureMore.classList.toggle('opacity-0', isOpen);
        featureMore.classList.toggle('max-h-[2000px]', !isOpen);
        featureMore.classList.toggle('opacity-100', !isOpen);
        featureToggle.setAttribute('aria-expanded', String(!isOpen));
        featureToggle.textContent = isOpen
          ? 'Afficher toutes les caractéristiques'
          : 'Afficher moins de caractéristiques';
        if (featureToggleIcon) {
          featureToggle.appendChild(featureToggleIcon);
          featureToggleIcon.classList.toggle('rotate-180', !isOpen);
        }
      });
    }
  </script>
