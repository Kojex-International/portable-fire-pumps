---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/layout/Section.astro';
import Button from '@components/ui/Button.astro';
import { CheckCircle2 } from 'lucide-react';
import heroOgImage from '@assets/contact-rfq-hero.webp';
import { getNonProductMetadata } from '@utils/nonProductMetadata';
const metadata = getNonProductMetadata({
  pageKey: 'contactThanks',
  locale: 'fr',
  pathname: Astro.url.pathname,
  ogImageSrc: heroOgImage.src,
});
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  canonicalUrl={metadata.canonicalUrl}
  ogImage={metadata.ogImageUrl}
  locale="fr"
  robots="noindex, follow"
>
  <Section background="white">
    <div class="max-w-3xl mx-auto py-16 flex flex-col items-center">
      <div class="inline-flex flex-col items-center mb-8">
        <div class="relative inline-flex items-center justify-center">
          <span class="absolute right-full mr-3 inline-flex items-center justify-center text-green-600">
            <CheckCircle2 className="w-8 h-8" />
          </span>
          <h1 class="text-3xl md:text-4xl font-bold text-gray-900">
            Merci de nous avoir contactés
          </h1>
        </div>
        <p class="text-lg text-gray-600 text-center mt-6">
          Nous avons bien reçu votre message et nous vous répondrons sous peu.
        </p>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="/fr/" size="lg" class="brand-cta !px-6 !py-2.5 !text-base">
          Retour à l’accueil
        </Button>
        <Button href="/fr/products/" size="lg" variant="outline" class="!px-6 !py-2.5 !text-base">
          Voir les produits
        </Button>
      </div>
    </div>
  </Section>
</BaseLayout>
