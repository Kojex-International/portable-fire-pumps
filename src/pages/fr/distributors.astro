---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/ui/Section.astro';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import PageHero from '../../components/heroes/PageHero.astro';
import { Image } from 'astro:assets';
import ImageReveal from '../../components/react/ImageReveal';
import FacilityStats from '../../components/react/FacilityStats';
import { getLocaleFromPathname, localizePath } from '@config/site';
import { Handshake, UserPlus } from 'lucide-react';

import easternCanadaDistributorImg from '@assets/distributors/logo-larsenal.svg';
