const locale = getLocaleFromPathname(Astro.url.pathname);
const requestQuoteHref = localizePath('/contact-us', locale);
const distributorsHref = localizePath('/distributors', locale);
---

<BaseLayout title="Distributeurs - Portable Fire Pumps">
  <PageHero
    backgroundImage={distributorsHeroImg}
    backgroundAlt="Réseau de distributeurs"
    badge="Notre réseau de distributeurs"
    badgeIconComponent={Handshake}
    titleClass="text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight animate-fadeInUp"
    descriptionClass="text-xl md:text-2xl text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed animate-fadeInUp"
    descriptionStyle="animation-delay: 0.1s"
  >
    <Fragment slot="title">
      <span class="brand-gradient-text-fill">
        Distributeurs
      </span>
    </Fragment>
    <Fragment slot="description">
      Partenaires de confiance à travers l’Amérique du Nord, offrant expertise technique, pièces et service pour les pompes incendie portatives.
    </Fragment>
  </PageHero>

  <!-- Quick Stats -->
  <!-- <Section background="white" class="relative z-20 -mt-20 lg:-mt-28 pt-0!">
    <FacilityStats client:load />
  </Section> -->

  <!-- Facilities Grid -->
  <Section background="gray">
    <SectionHeader
      badge="Nos distributeurs"
      badgeIconComponent={Handshake}
      title="Réseau de distributeurs"
      highlight="de confiance"
      description="Partenaires vérifiés disposant d’une expertise reconnue en intervention d’urgence et en protection contre les incendies de forêt."
      class="mb-16"
    />

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 auto-rows-fr">
      {distributors.map((distributor, index) => (
        <ImageReveal client:load delay={index * 0.1} className="h-full">
          <Card hover class="overflow-hidden animate-fadeInUp group h-full flex flex-col" style={`animation-delay: ${index * 0.1}s`}>
            <!-- Distributor Image -->
            <div class="relative h-64 overflow-hidden bg-black">
              <Image 
                src={distributor.image}
                alt={distributor.name}
                class="w-full h-full object-contain p-6"
              />
              <div class="absolute inset-0 bg-linear-to-t from-gray-900/80 via-gray-900/40 to-transparent"></div>
            </div>

            <div class="p-6 space-y-5 flex-1 flex flex-col">
              <div>
                <h3 class="text-2xl font-bold text-gray-900 mb-1">{distributor.name}</h3>
                <p class="text-sm text-gray-500">{distributor.type}</p>
                <p class="text-sm font-semibold text-primary-700">{distributor.region}</p>
              </div>
              <p class="text-sm text-gray-600 leading-relaxed">
                {distributor.description}
              </p>

              <!-- Contact -->
              <div>
                <h4 class="text-sm font-semibold text-gray-700 uppercase mb-3 tracking-wide flex items-center gap-2">
                  <svg class="w-4 h-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16h6M12 14a4 4 0 100-8 4 4 0 000 8z" />
                  </svg>
                  Contact
                </h4>
                <div class="space-y-2 text-sm text-gray-600">
                  <p class="flex items-start gap-2">
                    <svg class="w-4 h-4 text-primary-600 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    <span>{distributor.address}</span>
                  </p>
                  <p class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                    </svg>
                    <span>{distributor.phone}{distributor.phoneAlt ? ` | ${distributor.phoneAlt}` : ''}</span>
                  </p>
                  <p class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12H8m8 0l-8-5m8 5l-8 5" />
                    </svg>
                    <a href={`mailto:${distributor.email}`} class="text-primary-700 hover:text-primary-900 underline-offset-4 hover:underline">
                      {distributor.email}
                    </a>
                  </p>
                  <p class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 010 5.656M15 7a7 7 0 010 10M9 13a3 3 0 010-2m3-6a9 9 0 010 14" />
                    </svg>
                    <a href={distributor.website} class="text-primary-700 hover:text-primary-900 underline-offset-4 hover:underline" target="_blank" rel="noreferrer">
                      {distributor.website.replace('https://', '').replace('http://', '')}
                    </a>
                  </p>
                </div>
              </div>

              <!-- Focus -->
              <div class="border-t border-gray-200 pt-4">
                <h4 class="text-sm font-semibold text-gray-700 uppercase mb-3 tracking-wide flex items-center gap-2">
                  <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  Couverture et services
                </h4>
                <p class="text-sm text-gray-600 mb-3">
                  {distributor.focus}
                </p>
                <ul class="grid grid-cols-1 gap-2.5">
                  {distributor.services.map((service) => (
                    <li class="flex items-start space-x-2.5 text-sm">
                      <svg class="w-4 h-4 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      <span class="text-gray-600">{service}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </Card>
        </ImageReveal>
      ))}
    </div>
  </Section>

  <!-- Map Section -->
  <!-- <Section background="white">
