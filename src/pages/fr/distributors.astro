---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/layout/Section.astro';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';
import SectionHeader from '../../components/layout/SectionHeading.astro';
import PageHero from '../../components/layout/PageHero.astro';
import { Image } from 'astro:assets';
import ImageReveal from '../../components/react/ImageReveal';
import { getLocaleFromPathname, localizePath } from '@config/site';
import { Handshake, UserPlus } from 'lucide-react';
import { getNonProductMetadata } from '@utils/nonProductMetadata';

import easternCanadaDistributorImg from '@assets/distributors/larsenal-distributor-logo.svg';
import westernCanadaDistributorImg from '@assets/distributors/flash-wildfire-services-logo.avif';

import distributorsHeroImg from '@assets/distributors-network-hero.png';
import distributorsCtaImg from '@assets/distributors-support-cta.png';

const distributors = [
  {
    name: "L'Arsenal",
    location: 'Drummondville, Québec',
    address: '2250, rue André-C.-Hamel, Drummondville (QC) J2C 8B1',
    type: "Appareils et équipements d’intervention d’urgence",
    region: 'Québec',
    image: easternCanadaDistributorImg,
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
    </svg>`,
    phone: '819 474-2111',
    phoneAlt: '1 800 266-7610',
    email: 'info@larsenal.ca',
    website: 'https://larsenal.ca/',
    description:
      "Fondée en 1998, L’Arsenal offre des produits et services destinés aux services d’incendie, incluant la vente de camions et d’équipements d’intervention, ainsi que des services d’entretien, de réparation et de pièces.",
    focus:
      "Basée à Drummondville, L’Arsenal dessert les services d’incendie du Québec ainsi que les organisations industrielles, gouvernementales et institutionnelles.",
    services: [
      "Camions d’incendie et équipements d’intervention",
      "Services d’entretien et de réparation",
      'Pièces et soutien technique'
    ]
  },
  {
    name: 'Flash Wildfire Services',
    location: 'Sherwood Park, Alberta',
    address: '2899 Broadmoor Boulevard, 150, Sherwood Park (AB) T8H 1B5',
    type: 'Équipements de protection contre les incendies de forêt',
    region: 'Colombie-Britannique, Alberta, Saskatchewan',
    image: westernCanadaDistributorImg,
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
    </svg>`,
    phone: '780 467 7234',
    email: 'info@flashwildfireservices.ca',
    website: 'https://www.flashwildfireservices.ca/',
    description:
      'Fournisseur de pompes pour incendies de forêt, de systèmes de gicleurs, de composants WATERAX, ainsi que de tuyaux et raccords destinés à la protection contre les incendies.',
    focus:
      'Au service des propriétés situées en interface habitat-forêt (WUI), des propriétaires, des services publics, des municipalités et des applications commerciales de protection incendie.',
    services: [
      'Pompes pour incendies de forêt et composants WATERAX',
      'Systèmes de gicleurs et trousses de protection',
      'Tuyaux, raccords et quincaillerie'
    ]
  }
];

const locale = getLocaleFromPathname(Astro.url.pathname);
const requestQuoteHref = localizePath('/contact-us', locale);
const distributorsHref = localizePath('/distributors', locale);
const metadata = getNonProductMetadata({
  pageKey: 'distributors',
  locale: 'fr',
  pathname: Astro.url.pathname,
  ogImageSrc: distributorsHeroImg.src,
});
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  canonicalUrl={metadata.canonicalUrl}
  ogImage={metadata.ogImageUrl}
>
  <PageHero
    backgroundImage={distributorsHeroImg}
    backgroundAlt="Réseau canadien de distributeurs de pompes incendie portables"
    badge="Notre réseau de distributeurs"
    badgeIconComponent={Handshake}
    titleClass="text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight animate-fadeInUp"
    descriptionClass="text-xl md:text-2xl text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed animate-fadeInUp"
    descriptionStyle="animation-delay: 0.1s"
  >
    <Fragment slot="title">
      <span class="brand-gradient-text-fill">
        Distributeurs
      </span>
    </Fragment>
    <Fragment slot="description">
      Partenaires de confiance à travers l’Amérique du Nord, offrant expertise technique, pièces et service pour les pompes incendie portatives.
    </Fragment>
  </PageHero>

  <!-- Facilities Grid -->
  <Section background="gray">
    <SectionHeader
      badge="Nos distributeurs"
      badgeIconComponent={Handshake}
      title="Réseau de distributeurs"
      highlight="de confiance"
      description="Partenaires vérifiés disposant d’une expertise reconnue en intervention d’urgence et en protection contre les incendies de forêt."
      class="mb-16"
    />

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 auto-rows-fr">
      {distributors.map((distributor, index) => (
        <ImageReveal client:load delay={index * 0.1} className="h-full">
          <Card hover class="overflow-hidden animate-fadeInUp group h-full flex flex-col" style={`animation-delay: ${index * 0.1}s`}>
            <!-- Distributor Image -->
            <div class="relative h-64 overflow-hidden bg-black">
              <Image 
                src={distributor.image}
                alt={distributor.name}
                class="w-full h-full object-contain p-6"
              />
              <div class="absolute inset-0 bg-linear-to-t from-gray-900/80 via-gray-900/40 to-transparent"></div>
            </div>

            <div class="p-6 space-y-5 flex-1 flex flex-col">
              <div>
                <h3 class="text-2xl font-bold text-gray-900 mb-1">{distributor.name}</h3>
                <p class="text-sm text-gray-500">{distributor.type}</p>
                <p class="text-sm font-semibold text-primary-700">{distributor.region}</p>
              </div>
              <p class="text-sm text-gray-600 leading-relaxed">
                {distributor.description}
              </p>

              <!-- Contact -->
              <div>
                <h4 class="text-sm font-semibold text-gray-700 uppercase mb-3 tracking-wide flex items-center gap-2">
                  <svg class="w-4 h-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16h6M12 14a4 4 0 100-8 4 4 0 000 8z" />
                  </svg>
                  Contact
                </h4>
                <div class="space-y-2 text-sm text-gray-600">
                  <p class="flex items-start gap-2">
                    <svg class="w-4 h-4 text-primary-600 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    <span>{distributor.address}</span>
                  </p>
                  <p class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                    </svg>
                    <span>{distributor.phone}{distributor.phoneAlt ? ` | ${distributor.phoneAlt}` : ''}</span>
                  </p>
                  <p class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12H8m8 0l-8-5m8 5l-8 5" />
                    </svg>
                    <a href={`mailto:${distributor.email}`} class="text-primary-700 hover:text-primary-900 underline-offset-4 hover:underline">
                      {distributor.email}
                    </a>
                  </p>
                  <p class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 010 5.656M15 7a7 7 0 010 10M9 13a3 3 0 010-2m3-6a9 9 0 010 14" />
                    </svg>
                    <a href={distributor.website} class="text-primary-700 hover:text-primary-900 underline-offset-4 hover:underline" target="_blank" rel="noreferrer">
                      {distributor.website.replace('https://', '').replace('http://', '')}
                    </a>
                  </p>
                </div>
              </div>

              <!-- Focus -->
              <div class="border-t border-gray-200 pt-4">
                <h4 class="text-sm font-semibold text-gray-700 uppercase mb-3 tracking-wide flex items-center gap-2">
                  <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  Couverture et services
                </h4>
                <p class="text-sm text-gray-600 mb-3">
                  {distributor.focus}
                </p>
                <ul class="grid grid-cols-1 gap-2.5">
                  {distributor.services.map((service) => (
                    <li class="flex items-start space-x-2.5 text-sm">
                      <svg class="w-4 h-4 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      <span class="text-gray-600">{service}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </Card>
        </ImageReveal>
      ))}
    </div>
  </Section>

  <!-- CTA Section -->
  <section class="relative py-24 md:py-28 overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <Image 
        src={distributorsCtaImg}
        alt="Discussion de partenariat pour distributeurs de pompes incendie portables"
        class="w-full h-full object-cover"
        width={2070}
        height={1380}
      />
      <div class="absolute inset-0 cta-overlay-gradient"></div>
    </div>

    <!-- Content -->
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-4xl mx-auto text-center text-white">
        <div class="inline-flex items-center px-4 py-2 mb-6 bg-white/10 backdrop-blur-sm text-white text-sm font-semibold rounded-full">
          <UserPlus className="w-4 h-4 mr-2" />
          Revendeurs recherchés
        </div>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
          Développement de notre
          <span class="block text-[var(--brand-400)]">réseau de distribution</span>
        </h2>
        <p class="text-xl md:text-2xl text-slate-200 mb-8 max-w-2xl mx-auto leading-relaxed">
          Nous poursuivons l’expansion de notre réseau de distributeurs pour les pompes incendie portatives. Communiquez avec nous si vous souhaitez discuter d’une possibilité de partenariat.
        </p>
        <div class="flex flex-col sm:flex-row gap-6 justify-center">
          <Button href={requestQuoteHref} size="lg" class="brand-cta">
            Nous joindre
          </Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
