---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/ui/Section.astro';
import Button from '@components/ui/Button.astro';
import TestimonialCard from '@components/ui/TestimonialCard.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import UseCaseTabs from '@components/react/UseCaseTabs';
import StatsCards from '@components/react/StatsCards';
import { Image } from 'astro:assets';
import { Briefcase, Users, Rocket } from 'lucide-react';

import ecommerceImg from '@assets/photo-1607082349566-187342175e2f.jpg';
import healthcareImg from '@assets/photo-1587854692152-cbe660dbde88.jpg';
import automotiveImg from '@assets/photo-1581091226825-a6a2a5aee158.jpg';
import technologyImg from '@assets/photo-1518770660439-4636190af475.jpg';
import consumerGoodsImg from '@assets/photo-1558618666-fcd25c85cd64.jpg';
import foodBeverageImg from '@assets/photo-1542838132-92c53300491e.jpg';

import testimonial1Img from '@assets/photo-1494790108377-be9c29b29330.jpg';
import testimonial2Img from '@assets/photo-1559839734-2b71ea197ec2.jpg';
import testimonial3Img from '@assets/photo-1507003211169-0a1dd7228f2d.jpg';

import heroBgImg from '@assets/photo-1551288049-bebda4e38f71.jpg';
import ctaBgImg from '@assets/photo-1553413077-190dd305871c.jpg';

const useCases:any[] = [
  {
    industry: 'E-commerce et détail',
    iconName: 'ShoppingCart',
    image: ecommerceImg,
    challenge: "Gérer des volumes de commandes élevés en période de pointe avec des délais serrés et des attentes fortes sur la rapidité d'exécution.",
    solution: "Entreposage évolutif avec traitement automatisé des commandes, expédition le jour même et gestion intégrée des retours.",
    results: [
      '40 % de réduction du temps de traitement',
      '99,5 % de précision des commandes',
      '2 jours de délai moyen de livraison',
      '95 % de satisfaction client'
    ]
  },
  {
    industry: 'Santé et pharmaceutique',
    iconName: 'Heart',
    image: healthcareImg,
    challenge: "Maintenir des contrôles de température stricts, la conformité réglementaire et la traçabilité des produits médicaux sensibles.",
    solution: "Installations à température contrôlée, chaîne du froid validée, suivi en temps réel et traçabilité complète.",
    results: [
      '100 % de conformité réglementaire',
      'Zéro écart de température',
      'Traçabilité complète des lots',
      'Réduction du gaspillage de 30 %'
    ]
  },
  {
    industry: 'Automobile et manufacturier',
    iconName: 'Car',
    image: automotiveImg,
    challenge: "Coordonner la livraison juste-à-temps de composants sur plusieurs sites de production tout en réduisant les coûts de stock.",
    solution: "Centres de distribution stratégiques, logistique en tournées et gestion prédictive des inventaires.",
    results: [
      '50 % de réduction des coûts de stock',
      '99,8 % de livraisons à l’heure',
      "Zéro arrêt de ligne de production",
      'Amélioration de la trésorerie'
    ]
  },
  {
    industry: 'Technologie et électronique',
    iconName: 'Laptop',
    image: technologyImg,
    challenge: "Manipulation sécurisée d'équipements à forte valeur, logistique retour efficace et gestion rapide du cycle de vie produit.",
    solution: "Environnements protégés ESD, chaîne de custody sécurisée, retours optimisés et programmes de récupération d’actifs.",
    results: [
      'Zéro incident de sécurité',
      'Traitement des retours en 48 h',
      '85 % de taux de récupération',
      'Réduction des pertes de 60 %'
    ]
  },
  {
    industry: 'Biens de consommation',
    iconName: 'Package',
    image: consumerGoodsImg,
    challenge: "Gérer des portefeuilles variés avec des durées de vie produit différentes, des campagnes promotionnelles et une demande saisonnière.",
    solution: "Entreposage multi-clients, gestion FEFO, étiquetage promotionnel et distribution pilotée par la demande.",
    results: [
      '35 % d’amélioration de la rotation des stocks',
      'Réduction des pertes de 45 %',
      'Mise en place promo en 3 jours',
      'Capacité flexible et évolutive'
    ]
  },
  {
    industry: 'Agroalimentaire',
    iconName: 'UtensilsCrossed',
    image: foodBeverageImg,
    challenge: "Maintenir les normes de sécurité alimentaire, gérer les produits périssables et assurer la conformité HACCP.",
    solution: "Installations conformes, zones à température contrôlée, suivi des lots et transport réfrigéré spécialisé.",
    results: [
      '100 % de conformité sécurité alimentaire',
      '2 % de taux de perte produit',
      'Capacité complète de rappel de lot',
      'Fraîcheur produit prolongée'
    ]
  }
];

const testimonials:any[] = [
  {
    quote: "La solution d’entreposage automatisé de Portable Fire Pumps a transformé nos opérations e-commerce. Nous avons réduit le temps de traitement de 40 % et atteint 99,5 % de précision.",
    name: "Sarah Mitchell",
    role: "VP opérations, TechRetail",
    image: testimonial1Img,
    ringColor: "ring-blue-200"
  },
  {
    quote: "Leur logistique chaîne du froid est remarquable. Nous maintenons 100 % de conformité avec zéro écart de température et une traçabilité complète.",
    name: "Dr. James Chen",
    role: "Directeur, PharmaLogistics",
    image: testimonial2Img,
    ringColor: "ring-teal-200"
  },
  {
    quote: "Livraison juste-à-temps avec 99,8 % de ponctualité et zéro arrêt de production. Leur réseau a réduit nos coûts de stock de 50 %.",
    name: "Robert Johnson",
    role: "Responsable opérations, AutoParts Co.",
    image: testimonial3Img,
    ringColor: "ring-blue-200"
  }
];
---

<BaseLayout title="Applications - Portable Fire Pumps">
  <!-- Hero Section -->
  <section class="relative h-[70vh] min-h-[500px] flex items-center overflow-hidden">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0 bg-slate-900">
      <Image 
        src={heroBgImg}
        alt="Applications et cas d'usage"
        class="w-full h-full object-cover"
        loading="eager"
        decoding="async"
        fetchpriority="high"
        width={2070}
        height={1380}
      />
      <div class="absolute inset-0 bg-linear-to-r from-slate-900/95 via-slate-900/80 to-slate-900/50"></div>
    </div>

    <!-- Content -->
    <div class="container mx-auto relative z-10 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center px-4 py-2 mb-6 bg-white/10 backdrop-blur-[6px] text-white text-sm leading-none font-semibold rounded-full shadow-lg border border-white/15">
          <Briefcase className="w-4 h-4 mr-2" />
          Solutions sectorielles
        </div>
        
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight">
          <span class="text-[var(--brand-400)]">
            Applications
          </span>
        </h1>
        
        <p class="text-xl md:text-2xl text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed">
          Solutions terrain avec résultats mesurables dans des secteurs variés.
          Découvrez des déploiements concrets.
        </p>
      </div>
    </div>
  </section>

  <!-- Use Cases with Tabs -->
  <Section background="gray">
    <UseCaseTabs useCases={useCases} locale="fr" client:load />
  </Section>

  <!-- Success Metrics -->
  <Section background="white">
    <SectionHeader
      title="Résultats"
      highlight="prouvés"
      description="Des améliorations mesurables sur les indicateurs clés de performance."
      class="mb-16"
    />

    <StatsCards 
      stats={[
        { value: '99.8%', label: "Livraison à l'heure", iconName: 'CheckCircle2' },
        { value: '45%', label: 'Économies moyennes', iconName: 'TrendingDown' },
        { value: '500+', label: 'Clients satisfaits', iconName: 'Users' },
        { value: '50M+', label: 'Unités expédiées', iconName: 'Package' }
      ]}
      client:load 
    />
  </Section>

  <!-- Testimonials Section -->
  <Section background="gray">
    <SectionHeader
      badge="Retours clients"
      badgeIconComponent={Users}
      title="La confiance de"
      highlight="leaders sectoriels"
      description="Comment nos clients ont transformé leurs opérations et obtenu des résultats concrets."
      class="mb-16"
    />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {testimonials.map((testimonial) => (
        <TestimonialCard testimonial={testimonial} />
      ))}
    </div>
  </Section>

  <!-- CTA Section -->
  <section class="relative py-24 md:py-28 overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <Image 
        src={ctaBgImg}
        alt="Travaillons ensemble"
        class="w-full h-full object-cover"
        width={2070}
        height={1380}
      />
      <div class="absolute inset-0 cta-overlay-gradient"></div>
    </div>

    <!-- Content -->
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-4xl mx-auto text-center text-white">
        <div class="inline-flex items-center px-4 py-2 mb-6 bg-white/10 backdrop-blur-sm text-white text-sm font-semibold rounded-full">
          <Rocket className="w-4 h-4 mr-2" />
          Commencer aujourd'hui
        </div>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
          Prêt à transformer vos <span class="text-transparent bg-clip-text bg-linear-to-r from-blue-400 to-teal-400">opérations</span> ?
        </h2>
        <p class="text-xl md:text-2xl text-slate-200 mb-12 max-w-2xl mx-auto leading-relaxed">
          Chaque secteur a ses contraintes. Construisons ensemble une solution adaptée.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-6 justify-center">
          <Button href="/fr/contact-us" size="lg" class="bg-blue-600! hover:bg-blue-700! text-white! shadow-2xl!">
            Contact
          </Button>
          <Button href="/fr/products" size="lg" variant="outline" class="border-2! border-white! text-white! hover:bg-white/10! shadow-2xl!">
            Voir les produits
          </Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
