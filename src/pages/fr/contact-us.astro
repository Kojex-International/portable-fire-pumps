---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/layout/Section.astro';
import Card from '@components/ui/Card.astro';
import PageHero from '@components/layout/PageHero.astro';
import RFQForm from '@components/forms/RFQForm';
import { MessageSquare, Clock, Shield, CheckCircle2, Phone, Mail, Award, TrendingUp, Users } from 'lucide-react';
import rfqBgImg from '@assets/contact-rfq-hero.png';
import { getNonProductMetadata } from '@utils/nonProductMetadata';
import { buildContactPageSchema } from '@utils/seo/schema';
const metadata = getNonProductMetadata({
  pageKey: 'contact',
  locale: 'fr',
  pathname: Astro.url.pathname,
  ogImageSrc: rfqBgImg.src,
});
const structuredData = buildContactPageSchema(metadata.canonicalUrl, 'fr');
---
<style>
  .sidebar-icon-sub {
    color: #64748b;
  }
</style>



<BaseLayout
  title={metadata.title}
  description={metadata.description}
  canonicalUrl={metadata.canonicalUrl}
  ogImage={metadata.ogImageUrl}
  locale="fr"
  structuredData={structuredData}
>
  <form
    name="pump-inquiry-fr"
    method="POST"
    data-netlify="true"
    netlify-honeypot="bot-field"
    action="/fr/contact-us/thanks/"
    hidden
  >
    <input type="hidden" name="form-name" value="pump-inquiry-fr" />
    <input type="hidden" name="bot-field" />
    <input type="hidden" name="locale" value="fr" />
    <input type="text" name="firstName" />
    <input type="text" name="lastName" />
    <input type="email" name="email" />
    <input type="tel" name="phone" />
    <input type="text" name="organization" />
    <input type="text" name="industry" />
    <input type="text" name="services" />
    <input type="text" name="timeline" />
    <input type="text" name="volume" />
    <textarea name="details"></textarea>
  </form>

  <PageHero
    backgroundImage={rfqBgImg}
    backgroundAlt="Consultation en vente et support pour pompes incendie portables"
    badge="Contact ventes et support"
    badgeIconComponent={MessageSquare}
    sectionClass="relative h-[500px] md:h-[600px] flex items-center overflow-hidden"
    badgeClass="inline-flex items-center px-4 py-2 mb-6 bg-white/10 backdrop-blur-[6px] text-white text-sm leading-none font-semibold rounded-full shadow-lg border border-white/15 animate-fadeInUp"
    titleClass="text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight animate-fadeInUp"
    descriptionClass="text-xl md:text-2xl text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed animate-fadeInUp"
    descriptionStyle="animation-delay: 0.2s"
  >
    <Fragment slot="title">
      <span class="brand-gradient-text-fill">Nous joindre</span>
    </Fragment>
    <Fragment slot="description">
      Contactez-nous pour un devis, des conseils sur les pompes et le support pièces ou service.
      Nous répondons généralement sous 24 heures.
    </Fragment>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 pt-8 border-t border-white/20 animate-fadeInUp" style="animation-delay: 0.3s">
      <div class="group">
        <div class="text-lg md:text-xl font-semibold text-slate-100 mb-1">24 h</div>
        <div class="text-sm text-slate-300">Délai de réponse</div>
      </div>
      <div class="group">
        <div class="text-lg md:text-xl font-semibold text-slate-100 mb-1">70+ ans</div>
        <div class="text-sm text-slate-300">Expertise pompes</div>
      </div>
      <div class="group">
        <div class="text-lg md:text-xl font-semibold text-slate-100 mb-1">Terrain</div>
        <div class="text-sm text-slate-300">Fiabilité</div>
      </div>
      <div class="group">
        <div class="text-lg md:text-xl font-semibold text-slate-100 mb-1">Support</div>
        <div class="text-sm text-slate-300">Pièces & service</div>
      </div>
    </div>
  </PageHero>

  <!-- Main Form Section -->
  <Section background="gray">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <!-- Form -->
      <div class="lg:col-span-2">
        <Card>
          <RFQForm locale="fr" />
        </Card>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <!-- Contact Info Card -->
        <Card class="bg-slate-50 border-slate-200">
          <div class="flex items-center mb-4">
            <div class="w-10 h-10 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center mr-3">
              <Phone className="w-5 h-5 sidebar-icon-sub" />
            </div>
            <h3 class="text-xl font-bold text-gray-900">Besoin d'aide ?</h3>
          </div>
          <div class="space-y-4 text-sm">
            <div class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-sm transition-shadow">
              <div class="w-10 h-10 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center shrink-0">
                <Phone className="w-5 h-5 sidebar-icon-sub" />
              </div>
              <div>
                <div class="font-semibold text-gray-900">Téléphone</div>
                <div class="text-gray-600 font-medium">438 377 6729</div>
                <div class="text-gray-500 text-xs">Lun-Ven, 8h-18h EST</div>
              </div>
            </div>

            <div class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-sm transition-shadow">
              <div class="w-10 h-10 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center shrink-0">
                <Mail className="w-5 h-5 sidebar-icon-sub" />
              </div>
              <div>
                <div class="font-semibold text-gray-900">Courriel</div>
                <div class="text-gray-600 font-medium">info@kojex.com</div>
                <div class="text-gray-500 text-xs">Réponse sous 24 h</div>
              </div>
            </div>

            <!-- Live Chat hidden for now -->
          </div>
        </Card>

        <!-- What to Expect Card -->
        <Card class="bg-slate-50 border-slate-200">
          <div class="flex items-center mb-4">
            <div class="w-10 h-10 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center mr-3">
              <Clock className="w-5 h-5 sidebar-icon-sub" />
            </div>
            <h3 class="text-xl font-bold text-gray-900">À quoi s'attendre</h3>
          </div>
          <ol class="space-y-4 text-sm">
            <li class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-sm transition-shadow">
              <span class="shrink-0 w-8 h-8 rounded-full bg-slate-100 border border-slate-200 sidebar-icon-sub flex items-center justify-center font-bold text-sm">1</span>
              <div>
                <span class="text-gray-900 font-semibold block">Demande reçue</span>
                <span class="text-gray-600">Nous confirmons immédiatement la réception de votre demande.</span>
              </div>
            </li>
            <li class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-sm transition-shadow">
              <span class="shrink-0 w-8 h-8 rounded-full bg-slate-100 border border-slate-200 sidebar-icon-sub flex items-center justify-center font-bold text-sm">2</span>
              <div>
                <span class="text-gray-900 font-semibold block">Réponse sous 24 heures</span>
                <span class="text-gray-600">Notre équipe analyse votre demande et répond sous un jour ouvrable.</span>
              </div>
            </li>
            <li class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-sm transition-shadow">
              <span class="shrink-0 w-8 h-8 rounded-full bg-slate-100 border border-slate-200 sidebar-icon-sub flex items-center justify-center font-bold text-sm">3</span>
              <div>
                <span class="text-gray-900 font-semibold block">Devis ou suivi support</span>
                <span class="text-gray-600">Nous fournissons le devis pertinent, des conseils produits ou le support pièces/service.</span>
              </div>
            </li>
          </ol>
        </Card>

        <!-- Trust Indicators -->
        <Card class="bg-slate-50 border-slate-200">
          <div class="flex items-center mb-4">
            <div class="w-10 h-10 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center mr-3">
              <Award className="w-5 h-5 sidebar-icon-sub" />
            </div>
            <h3 class="text-xl font-bold text-gray-900">Pourquoi nous choisir ?</h3>
          </div>
          <ul class="space-y-3 text-sm">
            <li class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-sm transition-shadow">
              <div class="w-8 h-8 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center shrink-0">
                <TrendingUp className="w-4 h-4 sidebar-icon-sub" />
              </div>
              <span class="text-gray-700 pt-1">70+ ans en pompes à incendie portatives</span>
            </li>
            <li class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-sm transition-shadow">
              <div class="w-8 h-8 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center shrink-0">
                <CheckCircle2 className="w-4 h-4 sidebar-icon-sub" />
              </div>
              <span class="text-gray-700 pt-1">Fiabilité terrain et conception robuste</span>
            </li>
            <li class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-sm transition-shadow">
              <div class="w-8 h-8 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center shrink-0">
                <Shield className="w-4 h-4 sidebar-icon-sub" />
              </div>
              <span class="text-gray-700 pt-1">Pièces de rechange et support distributeurs</span>
            </li>
            <li class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-sm transition-shadow">
              <div class="w-8 h-8 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center shrink-0">
                <Users className="w-4 h-4 sidebar-icon-sub" />
              </div>
              <span class="text-gray-700 pt-1">Support municipal, industriel et incendies de forêt</span>
            </li>
          </ul>
        </Card>
      </div>
    </div>
  </Section>

</BaseLayout>
