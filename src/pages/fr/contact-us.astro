---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/ui/Section.astro';
import Card from '@components/ui/Card.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import RFQForm from '@components/react/RFQForm';
import { getLocaleFromPathname, localizePath } from '@config/site';
import { Image } from 'astro:assets';
import { MessageSquare, Clock, Shield, CheckCircle2, Phone, Mail, MessageCircle, Award, TrendingUp, Users } from 'lucide-react';
import rfqBgImg from '@assets/contactus.png';
import warehouseImg from '@assets/photo-1563013544-824ae1b704d3.jpg';

const locale = getLocaleFromPathname(Astro.url.pathname);
const thanksHref = localizePath('/contact-us/thanks', locale);
---
<style>
  .sidebar-icon-sub {
    color: #64748b;
  }
</style>



<BaseLayout title="Contact - Portable Fire Pumps">
  <!-- Hero Section with Professional Image -->
  <section class="relative h-[500px] md:h-[600px] flex items-center overflow-hidden">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0 bg-slate-900">
      <Image 
        src={rfqBgImg}
        alt="Professional logistics and supply chain management"
        class="w-full h-full object-cover"
        loading="eager"
        decoding="async"
        fetchpriority="high"
        width={2070}
        height={1380}
      />
      <div class="absolute inset-0 bg-linear-to-r from-slate-900/95 via-slate-900/80 to-slate-900/50"></div>
    </div>

    <!-- Content -->
    <div class="container mx-auto relative z-10 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center px-4 py-2 mb-6 bg-white/10 backdrop-blur-[6px] text-white text-sm leading-none font-semibold rounded-full shadow-lg border border-white/15 animate-fadeInUp">
          <MessageSquare className="w-4 h-4 mr-2" />
          Contact ventes et support
        </div>
        
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight animate-fadeInUp" style="animation-delay: 0.1s">
          <span class="text-[var(--brand-400)]">Contact</span>
        </h1>
        
        <p class="text-xl md:text-2xl text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed animate-fadeInUp" style="animation-delay: 0.2s">
          Contactez-nous pour un devis ou pour discuter de vos besoins en pompes à incendie, de votre contexte d'utilisation et du support pièces/service.
          Nous répondons généralement sous 24 heures avec les prochaines étapes.
        </p>

        <!-- Quick Stats -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 pt-8 border-t border-white/20 animate-fadeInUp" style="animation-delay: 0.3s">
          <div class="group">
            <div class="text-lg md:text-xl font-semibold text-slate-100 mb-1">24hr</div>
            <div class="text-sm text-slate-300">Délai de réponse</div>
          </div>
          <div class="group">
            <div class="text-lg md:text-xl font-semibold text-slate-100 mb-1">70+ ans</div>
            <div class="text-sm text-slate-300">Expertise pompes</div>
          </div>
          <div class="group">
            <div class="text-lg md:text-xl font-semibold text-slate-100 mb-1">Terrain</div>
            <div class="text-sm text-slate-300">Fiabilité</div>
          </div>
          <div class="group">
            <div class="text-lg md:text-xl font-semibold text-slate-100 mb-1">Support</div>
            <div class="text-sm text-slate-300">Pièces & service</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>

    <!-- Wave separator -->
    <!-- <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
        <path d="M0 120L60 110C120 100 240 80 360 70C480 60 600 60 720 65C840 70 960 80 1080 85C1200 90 1320 90 1380 90L1440 90V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0Z" fill="white"/>
      </svg>
    </div> -->
  </section>

  <!-- Main Form Section -->
  <Section background="gray">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <!-- Form -->
      <div class="lg:col-span-2">
        <Card>
          <RFQForm action={thanksHref} locale="fr" />
        </Card>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <!-- Contact Info Card -->
        <Card class="bg-slate-50 border-slate-200">
          <div class="flex items-center mb-4">
            <div class="w-10 h-10 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center mr-3">
              <Phone className="w-5 h-5 sidebar-icon-sub" />
            </div>
            <h3 class="text-xl font-bold text-gray-900">Besoin d'aide ?</h3>
          </div>
          <div class="space-y-4 text-sm">
            <div class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-sm transition-shadow">
              <div class="w-10 h-10 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center shrink-0">
                <Phone className="w-5 h-5 sidebar-icon-sub" />
              </div>
              <div>
                <div class="font-semibold text-gray-900">Téléphone</div>
                <div class="text-gray-600 font-medium">438 377 6729</div>
                <div class="text-gray-500 text-xs">Lun-Ven, 8h-18h EST</div>
              </div>
            </div>

            <div class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-sm transition-shadow">
              <div class="w-10 h-10 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center shrink-0">
                <Mail className="w-5 h-5 sidebar-icon-sub" />
              </div>
              <div>
                <div class="font-semibold text-gray-900">Courriel</div>
                <div class="text-gray-600 font-medium">info@kojex.com</div>
                <div class="text-gray-500 text-xs">Réponse sous 24 h</div>
              </div>
            </div>

            <!-- Live Chat hidden for now -->
          </div>
        </Card>

        <!-- What to Expect Card -->
        <Card class="bg-slate-50 border-slate-200">
          <div class="flex items-center mb-4">
            <div class="w-10 h-10 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center mr-3">
              <Clock className="w-5 h-5 sidebar-icon-sub" />
            </div>
            <h3 class="text-xl font-bold text-gray-900">À quoi s'attendre</h3>
          </div>
          <ol class="space-y-4 text-sm">
            <li class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-sm transition-shadow">
              <span class="shrink-0 w-8 h-8 rounded-full bg-slate-100 border border-slate-200 sidebar-icon-sub flex items-center justify-center font-bold text-sm">1</span>
              <div>
                <span class="text-gray-900 font-semibold block">Réponse</span>
                <span class="text-gray-600">Analyse de votre demande sous 24 heures</span>
              </div>
            </li>
            <li class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-sm transition-shadow">
              <span class="shrink-0 w-8 h-8 rounded-full bg-slate-100 border border-slate-200 sidebar-icon-sub flex items-center justify-center font-bold text-sm">2</span>
              <div>
                <span class="text-gray-900 font-semibold block">Analyse</span>
                <span class="text-gray-600">Validation de vos besoins et contraintes</span>
              </div>
            </li>
            <li class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-sm transition-shadow">
              <span class="shrink-0 w-8 h-8 rounded-full bg-slate-100 border border-slate-200 sidebar-icon-sub flex items-center justify-center font-bold text-sm">3</span>
              <div>
                <span class="text-gray-900 font-semibold block">Recommandation</span>
                <span class="text-gray-600">Réception des prochaines étapes et informations utiles</span>
              </div>
            </li>
            <li class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-sm transition-shadow">
              <span class="shrink-0 w-8 h-8 rounded-full bg-slate-100 border border-slate-200 sidebar-icon-sub flex items-center justify-center font-bold text-sm">4</span>
              <div>
                <span class="text-gray-900 font-semibold block">Support</span>
                <span class="text-gray-600">Accompagnement, pièces et support service</span>
              </div>
            </li>
          </ol>
        </Card>

        <!-- Trust Indicators -->
        <Card class="bg-slate-50 border-slate-200">
          <div class="flex items-center mb-4">
            <div class="w-10 h-10 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center mr-3">
              <Award className="w-5 h-5 sidebar-icon-sub" />
            </div>
            <h3 class="text-xl font-bold text-gray-900">Pourquoi nous choisir ?</h3>
          </div>
          <ul class="space-y-3 text-sm">
            <li class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-sm transition-shadow">
              <div class="w-8 h-8 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center shrink-0">
                <TrendingUp className="w-4 h-4 sidebar-icon-sub" />
              </div>
              <span class="text-gray-700 pt-1">70+ ans en pompes à incendie portatives</span>
            </li>
            <li class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-sm transition-shadow">
              <div class="w-8 h-8 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center shrink-0">
                <CheckCircle2 className="w-4 h-4 sidebar-icon-sub" />
              </div>
              <span class="text-gray-700 pt-1">Fiabilité terrain et conception robuste</span>
            </li>
            <li class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-sm transition-shadow">
              <div class="w-8 h-8 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center shrink-0">
                <Shield className="w-4 h-4 sidebar-icon-sub" />
              </div>
              <span class="text-gray-700 pt-1">Pièces de rechange et support distributeurs</span>
            </li>
            <li class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-sm transition-shadow">
              <div class="w-8 h-8 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center shrink-0">
                <Users className="w-4 h-4 sidebar-icon-sub" />
              </div>
              <span class="text-gray-700 pt-1">Support municipal, industriel et feux de végétation</span>
            </li>
          </ul>
        </Card>
      </div>
    </div>
  </Section>

  <!-- Trust & Success Section hidden for now -->
  <!-- <Section background="white">
    <SectionHeader
      badge="Équipes d'intervention"
      title="Équipez vos équipes avec des"
      highlight="pompes incendie portatives"
      description="Nous soutenons la protection contre les feux de forêt, les services municipaux, les sites industriels et les opérations en zones éloignées."
      class="mb-12"
    />

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
      <Card class="text-center hover:shadow-xl transition-all duration-300">
        <div class="w-16 h-16 rounded-full bg-linear-to-br from-blue-600 to-teal-600 flex items-center justify-center mx-auto mb-4">
          <Shield className="w-8 h-8 text-white" />
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Fiable et sécurisé</h3>
        <p class="text-gray-600">
          Équipements fiables et robustes, conçus pour des interventions exigeantes.
        </p>
      </Card>

      <Card class="text-center hover:shadow-xl transition-all duration-300">
        <div class="w-16 h-16 rounded-full bg-linear-to-br from-green-600 to-emerald-600 flex items-center justify-center mx-auto mb-4">
          <TrendingUp className="w-8 h-8 text-white" />
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Solutions évolutives</h3>
        <p class="text-gray-600">
          Solutions adaptées aux besoins municipaux, industriels et aux feux de végétation.
        </p>
      </Card>

      <Card class="text-center hover:shadow-xl transition-all duration-300">
        <div class="w-16 h-16 rounded-full bg-linear-to-br from-purple-600 to-pink-600 flex items-center justify-center mx-auto mb-4">
          <Users className="w-8 h-8 text-white" />
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Support expert</h3>
        <p class="text-gray-600">
          Équipe dédiée pour les pièces, le service et l'accompagnement.
        </p>
      </Card>
    </div>

    <div class="relative rounded-2xl overflow-hidden shadow-2xl">
      <div class="absolute inset-0">
        <Image 
          src={warehouseImg}
          alt="Installations modernes de logistique"
          class="w-full h-full object-cover"
          width={2070}
          height={800}
        />
        <div class="absolute inset-0 bg-linear-to-r from-slate-900/90 via-blue-900/80 to-slate-900/70"></div>
      </div>
      <div class="relative z-10 p-12 md:p-16 text-center text-white">
        <h3 class="text-3xl md:text-4xl font-bold mb-4">
          Prêt à améliorer votre capacité opérationnelle ?
        </h3>
        <p class="text-xl text-slate-200 mb-8 max-w-2xl mx-auto">
          Contactez-nous dès aujourd'hui pour obtenir un accompagnement personnalisé selon vos besoins.
        </p>
        <a 
          href="#rfq-form" 
          class="inline-flex items-center px-8 py-4 bg-linear-to-r from-blue-600 to-teal-600 hover:from-blue-700 hover:to-teal-700 text-white font-semibold rounded-lg shadow-lg hover:shadow-xl transition-all duration-200"
        >
          Demander un devis
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </Section> -->
</BaseLayout>
