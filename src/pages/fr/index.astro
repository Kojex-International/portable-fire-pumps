---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PremiumHero from '../../components/sections/PremiumHero.astro';
import ServiceHighlights from '../../components/sections/ServiceHighlights.astro';
import PremiumCTA from '../../components/sections/PremiumCTA.astro';
import SectionHeader from '../../components/layout/SectionHeading.astro';
import logoMark from '@assets/shibaura-logo-mark.svg';
import heroOgImage from '@assets/portable-fire-pumps-hero.jpg';
import { getNonProductMetadata } from '@utils/nonProductMetadata';
import { localizePath } from '@config/site';

const featuresHref = localizePath('/features', 'fr');
const useCasesHref = localizePath('/use-cases', 'fr');
const resourcesHref = localizePath('/resources', 'fr');
const distributorsHref = localizePath('/distributors', 'fr');
const aboutHref = localizePath('/about-us', 'fr');
const metadata = getNonProductMetadata({
  pageKey: 'home',
  locale: 'fr',
  pathname: Astro.url.pathname,
  ogImageSrc: heroOgImage.src,
});
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  canonicalUrl={metadata.canonicalUrl}
  ogImage={metadata.ogImageUrl}
>
  <PremiumHero />
  <section class="bg-white">
    <div class="container mx-auto mobile-container-gutter py-12">
      <SectionHeader
        badge="À propos de Shibaura Rabbit"
        badgeIcon={logoMark.src}
        title="Pompes incendie portatives"
        highlight="de confiance"
        class="mb-4"
      >
        <p class="text-lg md:text-xl text-slate-700 mb-4">
          pour l’Amérique du Nord
        </p>
        <p class="text-lg md:text-xl text-slate-700">
          Bienvenue sur le portail des pompes incendie portatives Shibaura Rabbit, présenté par Kojex International.
          Nous sommes le distributeur exclusif des pompes Rabbit au Canada et aux États-Unis.
        </p>
        <p class="text-lg md:text-xl text-slate-700 mt-4">
          La conception distinctive des pompes Shibaura Rabbit facilite l’inspection et l’entretien, tout en assurant
          une fiabilité éprouvée sur le terrain.
        </p>
        <p class="text-lg md:text-xl text-slate-700 mt-4">
          Les équipements Shibaura Rabbit sont particulièrement adaptés aux régions rurales et aux sites où les
          infrastructures ne permettent pas l’utilisation d’équipements d’intervention permanents.
        </p>
      </SectionHeader>
    </div>
  </section>
  <ServiceHighlights />
  <PremiumCTA
    description="Besoin d’un peu plus de contexte avant de choisir une pompe? Comparez les caractéristiques techniques, consultez les ressources documentaires, repérez le bon distributeur ou découvrez l’accompagnement de Kojex."
    supportLinks={[
      { href: featuresHref, label: 'Caractéristiques' },
      { href: useCasesHref, label: 'Cas d’usage' },
      { href: resourcesHref, label: 'Ressources' },
      { href: distributorsHref, label: 'Distributeurs' },
      { href: aboutHref, label: 'À propos de Kojex' },
    ]}
  />
</BaseLayout>
