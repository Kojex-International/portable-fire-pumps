---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PremiumHero from '../../components/home/PremiumHero.astro';
import ServiceHighlights from '../../components/home/ServiceHighlights.astro';
import ImageGrid from '../../components/home/ImageGrid.astro';
import StatsShowcase from '../../components/home/StatsShowcase.astro';
import IndustriesServed from '../../components/home/IndustriesServed.astro';
import TechnologyInnovation from '../../components/home/TechnologyInnovation.astro';
import ProcessWorkflow from '../../components/home/ProcessWorkflow.astro';
import Testimonials from '../../components/home/Testimonials.astro';
import PremiumCTA from '../../components/home/PremiumCTA.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import logoMark from '@assets/shibaura-logo-mark.svg';
---

<BaseLayout>
  <PremiumHero />
  <section class="bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <SectionHeader
        badge="À propos de Shibaura Rabbit"
        badgeIcon={logoMark.src}
        title="Pompes incendie portatives"
        highlight="de confiance"
        class="mb-4"
      >
        <p class="text-lg md:text-xl text-slate-700 mb-4">
          pour l’Amérique du Nord
        </p>
        <p class="text-lg md:text-xl text-slate-700">
          Bienvenue sur le portail des pompes incendie portatives Shibaura Rabbit, présenté par Kojex International.
          Nous sommes le distributeur exclusif des pompes Rabbit au Canada et aux États-Unis.
        </p>
        <p class="text-lg md:text-xl text-slate-700 mt-4">
          La conception distinctive des pompes Shibaura Rabbit facilite l’inspection et l’entretien, tout en assurant
          une fiabilité éprouvée sur le terrain.
        </p>
        <p class="text-lg md:text-xl text-slate-700 mt-4">
          Les équipements Shibaura Rabbit sont particulièrement adaptés aux régions rurales et aux sites où les
          infrastructures ne permettent pas l’utilisation d’équipements d’intervention permanents.
        </p>
      </SectionHeader>
    </div>
  </section>
  <ServiceHighlights />
  <!-- <ImageGrid />
  <IndustriesServed />
  <TechnologyInnovation />
  <ProcessWorkflow />
  <StatsShowcase />
  <Testimonials /> -->
  <PremiumCTA />
</BaseLayout>
