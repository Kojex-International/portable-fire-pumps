import formsTemplatesImg from '@assets/photo-1450101499163-c8848c66ca85.jpg';
import heroBgImg from '@assets/resources-hero.png';
import catalogPdf from '../../data/Shibaura_Catalog2024_9.pdf';
import ft300400ManualPdf from '../../data/manuals/aircooled/ft300-400Manual.pdf';
import ft450500ManualPdf from '../../data/manuals/aircooled/ft450-500Manual.pdf';
