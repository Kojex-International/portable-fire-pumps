const docCategories = [
  {
    id: 'product-catalogs',
    title: 'Catalogues de produits',
    iconPath: iconPaths.catalog,
    image: pumpCatalogImg,
    color: 'from-[var(--brand-1)] to-[var(--brand-2)]',
    gradient: 'linear-gradient(135deg, var(--brand-1), var(--brand-2))',
    bgColor: 'bg-rose-50',
    iconColor: 'text-rose-600',
    docs: [
      { title: 'Catalogue produits Shibaura 2024', description: 'Consultez la gamme complète des pompes à incendie portatives Shibaura', type: 'PDF', size: '19 MB', href: catalogPdf, thumb: catalogCardImg }
    ]
  },
  {
    id: 'pump-instruction-manuals',
    title: "Manuels d'exploitation des pompes",
    iconPath: iconPaths.manual,
    image: firepumpManualsImg,
