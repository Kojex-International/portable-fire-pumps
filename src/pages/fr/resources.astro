    iconPath: iconPaths.parts,
    image: partsListImg,
    color: 'from-green-500 to-emerald-500',
    gradient: 'linear-gradient(135deg, #22c55e, #10b981)',
    bgColor: 'bg-green-50',
    iconColor: 'text-green-600',
    docs: [
      { title: 'FI6000/FI7000/FI8000', description: 'Liste de pièces', type: 'PDF', size: '1.1 MB', href: fi6000fi7000fi8000PartsPdf, thumb: ff500Img },
      { title: 'FT300/FT400', description: 'Liste de pièces', type: 'PDF', size: '2.5 MB', href: ft300ft400PartsPdf, thumb: ft300Img },
      { title: 'FT450/FT500', description: 'Liste de pièces', type: 'PDF', size: '4.2 MB', href: ft450ft500PartsPdf, thumb: ft500Img },
      { title: 'FT510', description: 'Liste de pièces', type: 'PDF', size: '4.2 MB', href: ft510PartsPdf, thumb: ft510Img },
      { title: 'P509R', description: 'Liste de pièces', type: 'PDF', size: '0.7 MB', href: p509rPartsPdf },
      { title: 'P555', description: 'Liste de pièces', type: 'PDF', size: '0.5 MB', href: p555PartsPdf },
      { title: 'P572', description: 'Liste de pièces', type: 'PDF', size: '1.0 MB', href: p572PartsPdf, thumb: p572sImg }
    ]
  },
  // {
  //   title: 'Compliance & Certifications',
  //   iconPath: iconPaths.shield,
  //   image: technicalDocumentationImg,
  //   color: 'from-amber-500 to-orange-500',
  //   gradient: 'linear-gradient(135deg, #f59e0b, #f97316)',
  //   bgColor: 'bg-amber-50',
  //   iconColor: 'text-amber-600',
  //   docs: [
  //     { title: 'ISO 9001 Certificate', description: 'Quality management system certification documentation', type: 'PDF', size: '1.2 MB' },
  //     { title: 'FDA Registration', description: 'Food and drug administration compliance records', type: 'PDF', size: '2.3 MB' },
  //     { title: 'C-TPAT Certification', description: 'Customs trade partnership against terrorism', type: 'PDF', size: '1.8 MB' },
  //     { title: 'Safety Data Sheets', description: 'Comprehensive material safety information database', type: 'PDF', size: '5.4 MB' }
  //   ]
  // },
  // {
  //   title: 'Best Practices',
  //   iconPath: iconPaths.lightbulb,
  //   image: operationsManualImg,
  //   color: 'from-indigo-500 to-blue-500',
  //   gradient: 'linear-gradient(135deg, #6366f1, #3b82f6)',
  //   bgColor: 'bg-indigo-50',
  //   iconColor: 'text-indigo-600',
  //   docs: [
  //     { title: 'Inventory Optimization', description: 'Strategies to maximize efficiency and reduce costs', type: 'PDF', size: '3.6 MB' },
  //     { title: 'Packaging Guidelines', description: 'Best practices for product protection and presentation', type: 'PDF', size: '2.8 MB' },
  //     { title: 'Supply Chain Tips', description: 'Proven methods to streamline your operations', type: 'PDF', size: '4.2 MB' },
  //     { title: 'Sustainability Guide', description: 'Eco-friendly logistics solutions and practices', type: 'PDF', size: '3.9 MB' }
  //   ]
  // },
  // {
  //   title: 'Forms & Templates',
  //   iconPath: iconPaths.fileText,
  //   image: formsTemplatesImg,
  //   color: 'from-teal-500 to-cyan-500',
  //   gradient: 'linear-gradient(135deg, #14b8a6, #06b6d4)',
  //   bgColor: 'bg-teal-50',
  //   iconColor: 'text-teal-600',
  //   docs: [
  //     { title: 'Bill of Lading Template', description: 'Standard shipping documentation template', type: 'DOC', size: '0.5 MB' },
  //     { title: 'Packing List Form', description: 'Itemized shipment details and inventory form', type: 'XLS', size: '0.3 MB' },
  //     { title: 'Inspection Checklist', description: 'Quality control and verification template', type: 'DOC', size: '0.4 MB' },
  //     { title: 'Incident Report Form', description: 'Standardized issue reporting and tracking form', type: 'PDF', size: '0.6 MB' }
  //   ]
  // }
];

const faqs = [
  {
    question: 'How do I access the customer portal?',
    answer: 'Contact your account manager to receive login credentials for our secure customer portal. Once registered, you can track shipments, view inventory, generate reports, and manage your account 24/7 from anywhere in the world.'
  },
  {
    question: 'What file formats are supported for EDI?',
    answer: 'We support all standard EDI formats including X12 (850, 856, 810, 997, etc.), EDIFACT, and custom XML formats. Our integration team can work with your existing systems to ensure seamless data exchange and compatibility.'
  },
  {
    question: 'Where can I find safety data sheets (SDS)?',
    answer: 'All safety data sheets are available in the Compliance & Certifications section of this documentation center. You can also request specific SDS documents directly from your account manager or through our support portal.'
  },
  {
    question: 'How often is documentation updated?',
    answer: 'Documentation is reviewed and updated quarterly, or more frequently as needed for regulatory changes, system updates, or process improvements. You will be notified of any critical updates via email and through the customer portal.'
  },
  {
    question: 'Can I download multiple documents at once?',
    answer: 'Yes, you can select multiple documents and download them as a ZIP archive. Simply use the bulk selection feature available in each category section to download multiple files simultaneously.'
  },
  {
    question: 'Is there a mobile app for accessing documentation?',
    answer: 'Yes, our mobile application is available for both iOS and Android devices. You can download it from the App Store or Google Play Store. The app provides full access to all documentation and features offline reading capabilities.'
  }
];

const storageNotes = [
  "Assurez-vous que le réservoir d'essence reste plein. Un niveau bas laisse davantage d'air dans le réservoir et augmente les risques de condensation et de corrosion.",
  "La durée de conservation de l'essence est d'environ six mois. Utilisez toujours du carburant récent pour préserver la fiabilité et les performances.",
  "Une essence vieillie peut se dégrader et créer des dépôts qui perturbent le fonctionnement du moteur, du carburateur ou du système d'injection.",
  "Consultez le mode d'emploi de votre modèle. Les bonnes pratiques de stockage peuvent varier selon le type de pompe."
];
---

<BaseLayout title="Ressources - Portable Fire Pumps">
  <!-- Hero Section with Professional Background -->
  <section class="relative h-[70vh] min-h-[500px] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-slate-900">
      <Image 
        src={heroBgImg}
        alt="Documentation et ressources"
        class="w-full h-full object-cover"
        loading="eager"
        decoding="async"
        fetchpriority="high"
        width={2070}
        height={1380}
      />
      <div class="absolute inset-0 bg-linear-to-r from-slate-900/95 via-slate-900/80 to-slate-900/50"></div>
    </div>

    <div class="container mx-auto relative z-10 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center px-4 py-2 mb-6 bg-white/10 backdrop-blur-[6px] text-white text-sm leading-none font-semibold rounded-full shadow-lg border border-white/15">
          <Library className="w-4 h-4 mr-2" />
          Centre de ressources
        </div>
        
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight animate-fadeInUp">
          <span class="text-[var(--brand-400)]">
            Ressources
          </span>
        </h1>
        
        <p class="text-xl md:text-2xl text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed animate-fadeInUp" style="animation-delay: 0.1s">
          Téléchargez les catalogues, les manuels d'exploitation et les listes de pièces.
        </p>

        <div class="flex flex-wrap justify-center gap-4 text-sm text-slate-300 animate-fadeInUp" style="animation-delay: 0.2s">
          <div class="flex items-center">
            <svg class="w-4 h-4 mr-2 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>Documentation pompes</span>
          </div>
          <div class="flex items-center">
            <svg class="w-4 h-4 mr-2 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>Mises à jour régulières</span>
          </div>
          <div class="flex items-center">
            <svg class="w-4 h-4 mr-2 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>Accès 24/7</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </section>

  <!-- Search Bar -->
  <Section background="gray">
    <div class="max-w-4xl mx-auto mb-16">
      <Card class="p-6 shadow-xl border-2 border-gray-100">
        <form id="doc-search-form" class="flex flex-col md:flex-row gap-4">
          <div class="flex-1 relative">
            <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input
              type="text"
              placeholder="Rechercher des documents, manuels et ressources..."
              class="w-full pl-12 pr-16 py-4 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all text-lg"
              id="doc-search"
            />
            <button
              id="doc-search-clear"
              type="button"
              class="hidden absolute right-4 top-1/2 -translate-y-1/2 text-sm text-gray-500 hover:text-gray-700"
              aria-label="Effacer la recherche"
            >
              Effacer
            </button>
          </div>
          <button id="doc-search-submit" type="submit" class="brand-cta !px-8 !py-4 !rounded-xl text-base flex items-center justify-center gap-2 transition-transform active:scale-95">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            Rechercher
          </button>
        </form>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="text-sm text-gray-500">Liens rapides :</span>
          <a href="#product-catalogs" class="text-sm text-blue-600 hover:text-blue-800 font-medium">Catalogues de produits</a>
          <span class="text-gray-300">•</span>
          <a href="#pump-instruction-manuals" class="text-sm text-blue-600 hover:text-blue-800 font-medium">Manuels d'exploitation</a>
          <span class="text-gray-300">•</span>
          <a href="#parts-lists" class="text-sm text-blue-600 hover:text-blue-800 font-medium">Listes de pièces</a>
          <span class="text-gray-300">•</span>
          <a href="#fire-pump-storage-notes" class="text-sm text-blue-600 hover:text-blue-800 font-medium">Notes de stockage</a>
        </div>
        <p id="doc-search-feedback" class="mt-3 text-sm text-gray-500" aria-live="polite"></p>
      </Card>
    </div>

    <SectionHeader
      badge="Bibliothèque documentaire"
      badgeIconComponent={Library}
      title="Parcourir les"
      highlight="ressources disponibles"
      description="Accédez aux catalogues, manuels et listes de pièces en un seul endroit."
      class="mb-16"
    />

    <!-- Documentation Categories -->
    <div class="space-y-20">
      {docCategories.map((category, index) => {
        const categoryId = category.id ?? category.title.toLowerCase().replace(/\s+/g, '-');
        return (
        <div class="animate-fadeInUp" style={`animation-delay: ${index * 0.1}s`} id={categoryId} data-doc-category>
          <!-- Category Header with Image -->
          <div class="mb-8">
            <ImageReveal client:load delay={index * 0.1}>
              <div class="relative h-64 rounded-2xl overflow-hidden shadow-2xl group">
                <Image 
                  src={category.image}
                  alt={category.title}
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                  width={2070}
                  height={1380}
                />
                <div class="absolute inset-0 bg-linear-to-r from-slate-900/15 via-slate-800/35 to-slate-900/55"></div>
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="text-center text-white">
                    <div class="w-20 h-20 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg backdrop-blur-sm bg-white/15 border border-white/20">
                      <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <g stroke-linecap="round" stroke-linejoin="round" stroke-width="2" set:html={category.iconPath} />
                      </svg>
                    </div>
                    <h2 class="text-4xl md:text-5xl font-bold mb-2">{category.title}</h2>
                    <p class="text-lg text-white/90">{category.docs.length} documents disponibles</p>
                  </div>
                </div>
              </div>
            </ImageReveal>
          </div>
            
            <!-- Documents Grid -->
            <div class="grid gap-6 [grid-template-columns:repeat(auto-fit,minmax(280px,1fr))]">
              {category.docs.map((doc, docIndex) => (
                <div
                  class="doc-card w-full max-w-[360px] justify-self-center outline-none focus:outline-none focus-visible:outline-none"
                  data-doc-card
                  data-doc-text={`${doc.title} ${doc.description}`.toLowerCase()}
                  tabindex="-1"
                >
                  <ImageReveal client:load delay={index * 0.1 + docIndex * 0.05}>
                    <Card
                      hover
                      class="cursor-pointer group h-full flex flex-col"
                    >
                      <div class="flex-1">
                        {category.id === 'pump-instruction-manuals' || category.id === 'parts-lists' || category.id === 'product-catalogs' ? (
                          <div class="h-full flex items-stretch justify-between gap-4">
                            <div class="min-w-0 flex-1 flex flex-col">
                              <div class="w-12 h-12 mb-4 bg-slate-100 rounded-xl flex items-center justify-center text-slate-600 shadow-sm group-hover:bg-slate-200 group-hover:scale-105 transition-transform">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  {category.id === 'parts-lists' || category.id === 'product-catalogs' ? (
                                    <g stroke-linecap="round" stroke-linejoin="round" stroke-width="2" set:html={category.iconPath} />
                                  ) : (
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                  )}
                                </svg>
                              </div>
                              <h3 class={`text-xl font-bold text-gray-900 mb-3 doc-card-title ${category.id === 'product-catalogs' || doc.title === 'FI6000/FI7000/FI8000' ? '' : 'whitespace-nowrap truncate'}`}>
                                {doc.title}
                              </h3>
                              <p class="text-sm text-gray-600 leading-relaxed">{doc.description}</p>
                              <div class="mt-auto pt-2 mb-4 flex items-center text-xs text-gray-500">
                                <span>Taille : {doc.size}</span>
                              </div>
                            </div>
                            <div class="shrink-0 w-24 flex flex-col items-end gap-1">
                              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-slate-100 text-slate-600 border border-slate-200">
                                {doc.type}
                              </span>
