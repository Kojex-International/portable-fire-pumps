---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/ui/Section.astro';
import Card from '../../components/ui/Card.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import PageHero from '../../components/heroes/PageHero.astro';
import ImageReveal from '../../components/react/ImageReveal';
import { Image } from 'astro:assets';
import { HelpCircle, Library } from 'lucide-react';

import gettingStartedImg from '@assets/photo-1451187580459-43490279c0fa.jpg';
import onboardingChecklistImg from '@assets/photo-1486406146926-c627a92ad1ab.jpg';
import serviceOverviewImg from '@assets/photo-1550751827-4bd374c3f58b.jpg';
import pumpCatalogImg from '@assets/pumpcatalog.png';
import catalogCardImg from '@assets/2024CatalogImg.png';
import firepumpManualsImg from '@assets/firepumpmanuals.png';
import partsListImg from '@assets/partslist.png';
import ft300Img from '@assets/ft300.jpg';
import ft500Img from '@assets/ft500.jpg';
import ft510Img from '@assets/ft510.jpg';
import tf516mhImg from '@assets/tf516mh.jpg';
import p572sImg from '@assets/p572s.jpg';
import p555sImg from '@assets/p555s.jpg';
import fk500Img from '@assets/fk500.jpg';
import ff500Img from '@assets/ff500ar.jpg';
import heroBgImg from '@assets/resources-hero.png';
import catalogPdf from '../../data/Shibaura_Catalog2024_9.pdf';
import ft300400ManualPdf from '../../data/manuals/aircooled/ft300-400Manual.pdf';
import ft450500ManualPdf from '../../data/manuals/aircooled/ft450-500Manual.pdf';
import ft510ManualPdf from '../../data/manuals/aircooled/ft510Manual.pdf';
import tf516mhManualPdf from '../../data/manuals/aircooled/tf516mhManual.pdf';
import tf745mhManualPdf from '../../data/manuals/aircooled/tf745mhManual.pdf';
import p572sManualPdf from '../../data/manuals/watercooled/p572sManual.pdf';
import fk500ManualPdf from '../../data/manuals/watercooled/fk500Manual.pdf';
import ff500ManualPdf from '../../data/manuals/watercooled/ff500Manual.pdf';
import fi6000fi7000fi8000PartsPdf from '../../data/parts/fi6000fi7000fi8000partslist.pdf';
import ft300ft400PartsPdf from '../../data/parts/ft300ft400partslist.pdf';
import ft450ft500PartsPdf from '../../data/parts/ft450ft500partslist.pdf';
import ft510PartsPdf from '../../data/parts/ft510partslist.pdf';
import p555PartsPdf from '../../data/parts/p555partslist.pdf';
import p572PartsPdf from '../../data/parts/p572partslist.pdf';

// Icon SVG paths
const iconPaths = {
  catalog:
    '<path d="M12 7v14"/><path d="M16 12h2"/><path d="M16 8h2"/><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"/><path d="M6 12h2"/><path d="M6 8h2"/>',
  manual:
    '<path d="M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z"/><path d="M14 2v5a1 1 0 0 0 1 1h5"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/>',
  parts:
    '<path d="M15 8a1 1 0 0 1-1-1V2a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8z"/><path d="M20 8v12a2 2 0 0 1-2 2h-4.182"/><path d="m3.305 19.53.923-.382"/><path d="M4 10.592V4a2 2 0 0 1 2-2h8"/><path d="m4.228 16.852-.924-.383"/><path d="m5.852 15.228-.383-.923"/><path d="m5.852 20.772-.383.924"/><path d="m8.148 15.228.383-.923"/><path d="m8.53 21.696-.382-.924"/><path d="m9.773 16.852.922-.383"/><path d="m9.773 19.148.922.383"/><circle cx="7" cy="18" r="3"/>'
};

const docCategories = [
  {
    id: 'product-catalogs',
    title: 'Catalogues de produits',
    iconPath: iconPaths.catalog,
    image: pumpCatalogImg,
    color: 'from-[var(--brand-1)] to-[var(--brand-2)]',
    gradient: 'linear-gradient(135deg, var(--brand-1), var(--brand-2))',
    bgColor: 'bg-rose-50',
    iconColor: 'text-rose-600',
    docs: [
      { title: 'Catalogue Shibaura 2024', description: 'Consultez la gamme complète des pompes incendie portatives Shibaura', type: 'PDF', size: '19 Mo', href: catalogPdf, thumb: catalogCardImg }
    ]
  },
  {
    id: 'pump-instruction-manuals',
    title: 'Manuels d’utilisation',
    iconPath: iconPaths.manual,
    image: firepumpManualsImg,
    color: 'from-purple-500 to-pink-500',
    gradient: 'linear-gradient(135deg, #a855f7, #ec4899)',
    bgColor: 'bg-purple-50',
    iconColor: 'text-purple-600',
    docs: [
      { title: 'FT300 / FT400', titleLines: ['FT400', 'FT300'], description: 'Manuel d’utilisation – pompe refroidie à l’air', type: 'PDF', size: '1,8 Mo', href: ft300400ManualPdf, thumb: ft300Img },
      { title: 'FT450 / FT500', titleLines: ['FT500', 'FT450'], description: 'Manuel d’utilisation – pompe refroidie à l’air', type: 'PDF', size: '2,1 Mo', href: ft450500ManualPdf, thumb: ft500Img },
      { title: 'FT510', description: 'Manuel d’utilisation – pompe refroidie à l’air', type: 'PDF', size: '2,1 Mo', href: ft510ManualPdf, thumb: ft510Img },
      { title: 'TF516MH', description: 'Manuel d’utilisation – pompe refroidie à l’air', type: 'PDF', size: '44,6 Ko', href: tf516mhManualPdf, thumb: tf516mhImg },
      { title: 'TF745MH', description: 'Manuel d’utilisation – pompe refroidie à l’air', type: 'PDF', size: '3,9 Mo', href: tf745mhManualPdf },
      { title: 'P572S', description: 'Manuel d’utilisation – pompe refroidie à l’eau', type: 'PDF', size: '0,7 Mo', href: p572sManualPdf, thumb: p572sImg },
      { title: 'FK500', description: 'Manuel d’utilisation – pompe refroidie à l’eau', type: 'PDF', size: '2,5 Mo', href: fk500ManualPdf, thumb: fk500Img },
      { title: 'FF500', description: 'Manuel d’utilisation – pompe refroidie à l’eau', type: 'PDF', size: '2,8 Mo', href: ff500ManualPdf, thumb: ff500Img }
    ]
  },
  {
    id: 'parts-lists',
    title: 'Listes de pièces',
    iconPath: iconPaths.parts,
    image: partsListImg,
    color: 'from-green-500 to-emerald-500',
    gradient: 'linear-gradient(135deg, #22c55e, #10b981)',
    bgColor: 'bg-green-50',
    iconColor: 'text-green-600',
    docs: [
      { title: 'FI6000 / FI7000 / FI8000', titleLines: ['FI8000', 'FI7000', 'FI6000'], titleClass: 'text-base', titleLineHeight: 1.05, description: 'Liste de pièces', type: 'PDF', size: '1,1 Mo', href: fi6000fi7000fi8000PartsPdf, thumb: ff500Img },
      { title: 'FT300 / FT400', titleLines: ['FT400', 'FT300'], description: 'Liste de pièces', type: 'PDF', size: '2,5 Mo', href: ft300ft400PartsPdf, thumb: ft300Img },
      { title: 'FT450 / FT500', titleLines: ['FT500', 'FT450'], description: 'Liste de pièces', type: 'PDF', size: '4,2 Mo', href: ft450ft500PartsPdf, thumb: ft500Img },
      { title: 'FT510', description: 'Liste de pièces', type: 'PDF', size: '4,2 Mo', href: ft510PartsPdf, thumb: ft510Img },
      { title: 'P555', description: 'Liste de pièces', type: 'PDF', size: '0,5 Mo', href: p555PartsPdf, thumb: p555sImg, thumbScale: 0.9 },
      { title: 'P572', description: 'Liste de pièces', type: 'PDF', size: '1,0 Mo', href: p572PartsPdf, thumb: p572sImg }
    ]
  },

];

const storageNotes = [
  'Maintenez le réservoir de carburant plein afin de limiter la condensation et les risques de corrosion interne.',
  'La durée de conservation de l’essence est d’environ six mois. Utilisez un carburant frais pour protéger la fiabilité du moteur.',
  'Un carburant vieillissant peut générer des dépôts affectant le carburateur ou le système d’injection.',
  'Consultez le manuel d’utilisation propre à votre modèle. Les recommandations d’entreposage varient selon le type de pompe.'
];
---

<BaseLayout title="Ressources - Portable Fire Pumps">
  <!-- Hero Section with Professional Background -->
  <PageHero
    backgroundImage={heroBgImg}
    backgroundAlt="Documentation et ressources"
    badge="Centre de documentation technique"
    badgeIconComponent={Library}
    titleClass="text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight animate-fadeInUp"
    descriptionClass="text-xl md:text-2xl text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed animate-fadeInUp"
    descriptionStyle="animation-delay: 0.1s"
  >
    <Fragment slot="title">
      <span class="brand-gradient-text-fill">
        Documentation et listes de pièces
      </span>
    </Fragment>
    <Fragment slot="description">
      Téléchargez les catalogues, les manuels d’utilisation et les listes de pièces.
    </Fragment>
    <div class="flex flex-wrap justify-center gap-4 text-sm text-slate-300 animate-fadeInUp" style="animation-delay: 0.2s">
          <div class="flex items-center">
            <svg class="w-4 h-4 mr-2 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>Toute la documentation des pompes</span>
          </div>
          <div class="flex items-center">
            <svg class="w-4 h-4 mr-2 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>Mises à jour régulières</span>
          </div>
          <div class="flex items-center">
            <svg class="w-4 h-4 mr-2 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>Accès en tout temps</span>
          </div>
        </div>
  </PageHero>

  <!-- Search Bar -->
  <Section background="gray">
    <div class="max-w-4xl mx-auto mb-16">
      <Card class="p-6 shadow-xl border-2 border-gray-100">
        <form id="doc-search-form" class="flex flex-col md:flex-row gap-4">
          <div class="flex-1 relative">
            <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input
              type="text"
              placeholder="Rechercher des documents, des manuels et des ressources…"
              class="w-full pl-12 pr-16 py-4 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all text-lg"
              id="doc-search"
            />
            <button
              id="doc-search-clear"
              type="button"
              class="hidden absolute right-4 top-1/2 -translate-y-1/2 text-sm text-gray-500 hover:text-gray-700"
              aria-label="Effacer la recherche"
            >
              Effacer
            </button>
          </div>
          <button id="doc-search-submit" type="submit" class="brand-cta !px-8 !py-4 !rounded-xl text-base flex items-center justify-center gap-2 transition-transform active:scale-95">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            Rechercher
          </button>
        </form>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="text-sm text-gray-500">Liens rapides :</span>
          <a href="#product-catalogs" class="text-sm text-blue-600 hover:text-blue-800 font-medium">Catalogues de produits</a>
          <span class="text-gray-300">•</span>
          <a href="#pump-instruction-manuals" class="text-sm text-blue-600 hover:text-blue-800 font-medium">Manuels d’utilisation</a>
          <span class="text-gray-300">•</span>
          <a href="#parts-lists" class="text-sm text-blue-600 hover:text-blue-800 font-medium">Listes de pièces</a>
          <span class="text-gray-300">•</span>
          <a href="#fire-pump-storage-notes" class="text-sm text-blue-600 hover:text-blue-800 font-medium">Consignes d’entreposage</a>
        </div>
        <p id="doc-search-feedback" class="mt-3 text-sm text-gray-500" aria-live="polite"></p>
      </Card>
    </div>

    <SectionHeader
      badge="Bibliothèque documentaire"
      badgeIconComponent={Library}
      title="Parcourir les"
      highlight="ressources disponibles"
      description="Accédez aux catalogues, manuels et listes de pièces au même endroit."
      class="mb-16"
    />

    <!-- Documentation Categories -->
    <div class="space-y-20">
      {docCategories.map((category, index) => {
        const categoryId = category.id ?? category.title.toLowerCase().replace(/\s+/g, '-');
        return (
        <div class="animate-fadeInUp" style={`animation-delay: ${index * 0.1}s`} id={categoryId} data-doc-category>
          <!-- Category Header with Image -->
          <div class="mb-8">
            <ImageReveal client:load delay={index * 0.1}>
              <div class="relative h-64 rounded-2xl overflow-hidden shadow-2xl group">
                <Image 
                  src={category.image}
                  alt={category.title}
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                  width={2070}
                  height={1380}
                />
                <div class="absolute inset-0 bg-linear-to-r from-slate-900/15 via-slate-800/35 to-slate-900/55"></div>
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="text-center text-white">
                    <div class="w-20 h-20 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg backdrop-blur-sm bg-white/15 border border-white/20">
                      <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <g stroke-linecap="round" stroke-linejoin="round" stroke-width="2" set:html={category.iconPath} />
                      </svg>
                    </div>
                    <h2 class="text-4xl md:text-5xl font-bold mb-2">{category.title}</h2>
                    <p class="text-lg text-white/90">
                      {category.docs.length} {category.docs.length > 1 ? 'documents disponibles' : 'document disponible'}
                    </p>
                  </div>
                </div>
              </div>
            </ImageReveal>
          </div>
            
            <!-- Documents Grid -->
            <div class="grid gap-6 [grid-template-columns:repeat(auto-fit,minmax(280px,1fr))]">
              {category.docs.map((doc, docIndex) => (
                <div
                  class="doc-card w-full max-w-[360px] justify-self-center outline-none focus:outline-none focus-visible:outline-none"
                  data-doc-card
                  data-doc-text={`${doc.title} ${doc.description}`.toLowerCase()}
                  tabindex="-1"
                >
                  <ImageReveal client:load delay={index * 0.1 + docIndex * 0.05}>
                    <Card
                      hover
                      class="cursor-pointer group h-full flex flex-col"
                    >
                      <div class="flex-1">
                        {category.id === 'pump-instruction-manuals' || category.id === 'parts-lists' || category.id === 'product-catalogs' ? (
                          <div class="h-full flex items-stretch justify-between gap-4">
                            <div class="min-w-0 flex-1 flex flex-col">
                              <div class="w-12 h-12 mb-4 bg-slate-100 rounded-xl flex items-center justify-center text-slate-600 shadow-sm group-hover:bg-slate-200 group-hover:scale-105 transition-transform">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  {category.id === 'parts-lists' || category.id === 'product-catalogs' ? (
                                    <g stroke-linecap="round" stroke-linejoin="round" stroke-width="2" set:html={category.iconPath} />
                                  ) : (
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                  )}
                                </svg>
                              </div>
                              <h3 class={`${doc.titleClass ?? 'text-xl'} font-bold text-gray-900 mb-3 doc-card-title min-h-[3rem] ${category.id === 'product-catalogs' || doc.titleLines ? '' : 'whitespace-nowrap truncate'}`}>
                                {doc.titleLines ? (
                                  <span class="block" style={`line-height:${doc.titleLineHeight ?? 1.2};`}>
                                    {doc.titleLines.map((line, lineIndex) => (
                                      <span class="block" style={lineIndex === doc.titleLines.length - 1 ? 'margin-bottom:0;' : ''}>
                                        {line}
                                      </span>
                                    ))}
                                  </span>
                                ) : (
                                  doc.title
                                )}
                              </h3>
                              <p class="text-sm text-gray-600 leading-relaxed min-h-[2.5rem]">{doc.description}</p>
                              <div class="mt-auto pt-2 mb-4 flex items-center text-xs text-gray-500">
                                <span>Taille : {doc.size}</span>
                              </div>
                            </div>
                            <div class="shrink-0 w-24 flex flex-col items-end gap-1">
                              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-slate-100 text-slate-600 border border-slate-200">
                                {doc.type}
                              </span>
                              <div class="w-24 flex-1 min-h-0 mt-4 mb-4 bg-white rounded-md overflow-hidden flex items-center justify-center">
                                {doc.thumb ? (
                                  <Image
                                    src={doc.thumb}
                                    alt={doc.title}
                                    class="w-full h-full object-contain"
                                    width={96}
                                    height={96}
                                    style={`transform: scale(${doc.thumbScale ?? 1}); transform-origin: center;`}
                                  />
                                ) : (
                                  <svg class="w-9 h-9 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 8a1 1 0 0 1-1-1V2a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 8v12a2 2 0 0 1-2 2h-4.182"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m3.305 19.53.923-.382"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 10.592V4a2 2 0 0 1 2-2h8"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m4.228 16.852-.924-.383"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m5.852 15.228-.383-.923"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m5.852 20.772-.383.924"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8.148 15.228.383-.923"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8.53 21.696-.382-.924"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m9.773 16.852.922-.383"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m9.773 19.148.922.383"/>
                                    <circle cx="7" cy="18" r="3" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
                                  </svg>
                                )}
                              </div>
                            </div>
                          </div>
                        ) : (
                          <>
                            <div class="flex items-start justify-between mb-4">
                              <div class="w-12 h-12 bg-slate-100 rounded-xl flex items-center justify-center text-slate-600 shadow-sm group-hover:bg-slate-200 group-hover:scale-105 transition-transform">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  {category.id === 'product-catalogs' || category.id === 'parts-lists' ? (
                                    <g stroke-linecap="round" stroke-linejoin="round" stroke-width="2" set:html={category.iconPath} />
                                  ) : (
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                  )}
                                </svg>
                              </div>
                              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-slate-100 text-slate-600 border border-slate-200">
                                {doc.type}
                              </span>
                            </div>
                            <h3 class="text-xl font-bold text-gray-900 mb-3 doc-card-title">
                              {doc.title}
                            </h3>
                            <p class="text-sm text-gray-600 mb-4 leading-relaxed">{doc.description}</p>
                          </>
                        )}

                        {category.id !== 'pump-instruction-manuals' && category.id !== 'parts-lists' && category.id !== 'product-catalogs' && (
                          <div class="flex items-center text-xs text-gray-500 mb-4">
                            <span>Size: {doc.size}</span>
                          </div>
                        )}
                      </div>

                      {doc.href ? (
                        <a
                          href={doc.href}
                          class="w-full mt-auto inline-flex items-center justify-center gap-2 rounded-lg px-4 py-3 font-semibold text-white bg-slate-800 shadow-md transition focus-visible:ring-2 focus-visible:ring-offset-2 hover:bg-slate-700"
                          download
                        >
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                          </svg>
                          <span>Télécharger</span>
                        </a>
                      ) : (
                        <button
                          class="w-full mt-auto inline-flex items-center justify-center gap-2 rounded-lg px-4 py-3 font-semibold text-white bg-slate-800 shadow-md transition focus-visible:ring-2 focus-visible:ring-offset-2 hover:bg-slate-700"
                        >
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                          </svg>
                          <span>Télécharger</span>
                        </button>
                      )}
                    </Card>
                  </ImageReveal>
                </div>
              ))}
            </div>
          </div>
        );
      })}
    </div>

    <div id="fire-pump-storage-notes" class="mt-20">
      <SectionHeader
        badge="Consignes d’entreposage"
        badgeIconComponent={HelpCircle}
        title="Entreposage des"
        highlight="pompes incendie"
        description="Un entreposage approprié contribue au maintien des performances et à la fiabilité à long terme."
        class="mb-8"
      />

      <Card class="p-8 border border-slate-200 shadow-sm">
        <div class="space-y-4 text-slate-700 leading-relaxed">
          <p>
            Les pompes incendie portatives sont souvent entreposées pendant de longues périodes. Des pratiques adéquates permettent de préserver leur état de fonctionnement et de réduire les interventions de service inutiles.
          </p>
          <ul class="list-disc pl-6 space-y-2">
            {storageNotes.map((note) => (
              <li>{note}</li>
            ))}
          </ul>
        </div>
      </Card>
    </div>
  </Section>

  <script>
    const searchForm = document.querySelector('#doc-search-form');
    const searchInput = document.querySelector('#doc-search');
    const searchSubmit = document.querySelector('#doc-search-submit');
    const searchFeedback = document.querySelector('#doc-search-feedback');
    const searchClear = document.querySelector('#doc-search-clear');
    const docCards = Array.from(document.querySelectorAll('[data-doc-card]'));
    const docCategories = Array.from(document.querySelectorAll('[data-doc-category]'));

    const applyFilter = (value) => {
      const term = value.toLowerCase().trim();
      let visibleCount = 0;
      docCards.forEach((card) => {
        const text = card.dataset.docText || '';
        const isHidden = term.length > 0 && !text.includes(term);
        card.classList.toggle('hidden', isHidden);
        if (!isHidden) visibleCount += 1;
      });

      docCategories.forEach((category) => {
        const visibleCards = category.querySelectorAll('[data-doc-card]:not(.hidden)').length;
        category.classList.toggle('hidden', term.length > 0 && visibleCards === 0);
      });

      if (searchFeedback) {
        if (!term) {
          searchFeedback.textContent = `${docCards.length} ressources affichées`;
        } else {
          searchFeedback.textContent = `${visibleCount} résultat${visibleCount === 1 ? '' : 's'} pour "${value.trim()}"`;
        }
      }

      if (searchClear) {
        searchClear.classList.toggle('hidden', !term);
      }
    };

    const getFirstVisibleCard = () => docCards.find((card) => !card.classList.contains('hidden'));

    const flashSearchInput = () => {
      if (!searchInput) return;
      searchInput.classList.add('border-blue-400');
      searchInput.style.boxShadow = '0 0 0 2px rgba(96, 165, 250, 0.45)';
      window.setTimeout(() => {
        searchInput.classList.remove('border-blue-400');
        searchInput.style.boxShadow = '';
      }, 180);
    };

    const pressSearchButton = () => {
      if (!searchSubmit) return;
      searchSubmit.animate(
        [
          { transform: 'scale(1)' },
          { transform: 'scale(0.96)' },
          { transform: 'scale(1)' },
        ],
        { duration: 180, easing: 'ease-out' }
      );
    };

    const scrollToFirstVisibleCard = () => {
      const firstVisibleCard = getFirstVisibleCard();
      if (!firstVisibleCard) return;
      const rect = firstVisibleCard.getBoundingClientRect();
      const scrollTop = window.scrollY + rect.top - 110;
      window.scrollTo({ top: Math.max(scrollTop, 0), behavior: 'smooth' });
      window.setTimeout(() => {
        firstVisibleCard.focus({ preventScroll: true });
      }, 220);
    };

    if (searchInput) {
      searchInput.addEventListener('input', (event) => {
        applyFilter(event.target.value);
      });
    }

    if (searchForm && searchInput) {
      searchForm.addEventListener('submit', (event) => {
        event.preventDefault();
        applyFilter(searchInput.value);
        flashSearchInput();
        pressSearchButton();
        scrollToFirstVisibleCard();
      });
    }

    if (searchClear && searchInput) {
      searchClear.addEventListener('click', () => {
        searchInput.value = '';
        applyFilter('');
        searchInput.focus();
      });
    }

    applyFilter(searchInput?.value || '');
  </script>

