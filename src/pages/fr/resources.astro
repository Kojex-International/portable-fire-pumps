    gradient: 'linear-gradient(135deg, #a855f7, #ec4899)',
    bgColor: 'bg-purple-50',
    iconColor: 'text-purple-600',
    docs: [
      { title: 'FT300 / FT400', description: "Manuel d'exploitation pompe refroidie à l'air", type: 'PDF', size: '1.8 MB', href: ft300400ManualPdf, thumb: ft300Img },
      { title: 'FT450/FT500', description: "Manuel d'exploitation pompe refroidie à l'air", type: 'PDF', size: '2.1 MB', href: ft450500ManualPdf, thumb: ft500Img },
      { title: 'FT510', description: "Manuel d'exploitation pompe refroidie à l'air", type: 'PDF', size: '2.1 MB', href: ft510ManualPdf, thumb: ft510Img },
      { title: 'TF516MH', description: "Manuel d'exploitation pompe refroidie à l'air", type: 'PDF', size: '44.6 KB', href: tf516mhManualPdf, thumb: tf516mhImg },
      { title: 'TF745MH', description: "Manuel d'exploitation pompe refroidie à l'air", type: 'PDF', size: '3.9 MB', href: tf745mhManualPdf },
      { title: 'P572S', description: "Manuel d'exploitation pompe refroidie à l'eau", type: 'PDF', size: '0.7 MB', href: p572sManualPdf, thumb: p572sImg },
      { title: 'FK500', description: "Manuel d'exploitation pompe refroidie à l'eau", type: 'PDF', size: '2.5 MB', href: fk500ManualPdf, thumb: fk500Img },
      { title: 'FF500', description: "Manuel d'exploitation pompe refroidie à l'eau", type: 'PDF', size: '2.8 MB', href: ff500ManualPdf, thumb: ff500Img }
