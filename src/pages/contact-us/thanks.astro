---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Thank You - Portable Fire Pumps" locale="en" robots="noindex, follow">
  <script is:inline>
    (() => {
      const params = new URLSearchParams(window.location.search);
      const explicit = params.get('lang') || params.get('locale');
      const currentPath = window.location.pathname || '';
      const referrerPath = (() => {
        try {
          const ref = document.referrer ? new URL(document.referrer) : null;
          return ref ? ref.pathname : '';
        } catch {
          return '';
        }
      })();

      const isFrench =
        explicit === 'fr' ||
        currentPath.startsWith('/fr/') ||
        referrerPath.startsWith('/fr/');
      const target = isFrench ? '/fr/contact-us/thanks/' : '/en/contact-us/thanks/';

      const heading = document.getElementById('thanks-redirect-heading');
      const body = document.getElementById('thanks-redirect-body');
      const enLink = document.getElementById('thanks-redirect-en');
      const frLink = document.getElementById('thanks-redirect-fr');

      if (isFrench) {
        document.documentElement.lang = 'fr';
        if (heading) heading.textContent = 'Redirection vers votre page de confirmation…';
        if (body) body.textContent = 'Si la redirection ne fonctionne pas, choisissez votre langue :';
      }

      if (enLink) enLink.setAttribute('href', '/en/contact-us/thanks/');
      if (frLink) frLink.setAttribute('href', '/fr/contact-us/thanks/');

      if (window.location.pathname !== target) {
        window.location.replace(target);
      }
    })();
  </script>
  <main class="min-h-[40vh] flex items-center justify-center px-6 text-center">
    <div class="space-y-3">
      <p id="thanks-redirect-heading" class="text-slate-700">Redirecting to your confirmation page…</p>
      <p id="thanks-redirect-body" class="text-sm text-slate-500">
        If you are not redirected, choose your language:
        <a id="thanks-redirect-en" href="/en/contact-us/thanks/" class="ml-1 text-[var(--brand-1)] hover:underline">EN</a>
        /
        <a id="thanks-redirect-fr" href="/fr/contact-us/thanks/" class="ml-1 text-[var(--brand-1)] hover:underline">FR</a>
      </p>
    </div>
  </main>
</BaseLayout>
